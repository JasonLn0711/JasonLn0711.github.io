---
import Footer from "../components/layout/Footer.astro";
import Navbar from "../components/layout/Navbar.astro";
import Head from "../components/seo/Head.astro";
import { normalizePathname } from "../lib/site";
import {
  getLocaleFromPathname,
  getLocaleMeta,
  getLocalizedSite,
  getPageCopy
} from "../lib/i18n";
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
  image?: string;
  pathname?: string;
  type?: "website" | "article";
  schema?: Record<string, unknown> | Array<Record<string, unknown>>;
  noindex?: boolean;
  publishedTime?: string;
  modifiedTime?: string;
}

const {
  title,
  description,
  image,
  pathname = Astro.url.pathname,
  type = "website",
  schema,
  noindex = false,
  publishedTime,
  modifiedTime
} = Astro.props;

const currentPathname = normalizePathname(pathname);
const locale = getLocaleFromPathname(currentPathname);
const localeInfo = getLocaleMeta(locale);
const localizedSite = getLocalizedSite(locale);
const copy = getPageCopy(locale);
const scrollDepthThresholds = localizedSite.analytics.scrollDepthThresholds;
---

<!doctype html>
<html lang={localeInfo.htmlLang} data-device="desktop" data-input="fine" data-motion="full">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Instrument+Sans:wght@400;500;600;700&family=Newsreader:opsz,wght@6..72,400;6..72,500;6..72,600;6..72,700&display=swap"
      rel="stylesheet"
    />
    <script is:inline>
      (() => {
        const root = document.documentElement;
        const queries = {
          mobile: window.matchMedia("(max-width: 47.99rem)"),
          tablet: window.matchMedia("(min-width: 48rem) and (max-width: 79.99rem)"),
          coarse: window.matchMedia("(pointer: coarse)"),
          reducedMotion: window.matchMedia("(prefers-reduced-motion: reduce)"),
          landscape: window.matchMedia("(orientation: landscape)")
        };

        const applyDeviceProfile = () => {
          root.dataset.device = queries.mobile.matches ? "mobile" : queries.tablet.matches ? "tablet" : "desktop";
          root.dataset.input = queries.coarse.matches ? "coarse" : "fine";
          root.dataset.motion = queries.reducedMotion.matches ? "reduced" : "full";
          root.dataset.orientation = queries.landscape.matches ? "landscape" : "portrait";
        };

        applyDeviceProfile();
      })();
    </script>
    <Head
      title={title}
      description={description}
      image={image}
      pathname={pathname}
      type={type}
      schema={schema}
      noindex={noindex}
      publishedTime={publishedTime}
      modifiedTime={modifiedTime}
      locale={locale}
    />
  </head>
  <body class="min-h-screen">
    <a href="#content" class="skip-link">{copy.common.skipToContent}</a>
    <div class="flex min-h-screen flex-col">
      <Navbar locale={locale} pathname={currentPathname} />
      <main id="content" tabindex="-1" class="flex-1 focus:outline-none">
        <slot />
      </main>
      <Footer locale={locale} pathname={currentPathname} />
    </div>
    <script is:inline define:vars={{ currentPathname, locale, scrollDepthThresholds }}>
      const normalizeHref = (href) => {
        try {
          return new URL(href, window.location.origin);
        } catch {
          return null;
        }
      };

      const trimValue = (value) => String(value).replace(/\s+/g, " ").trim();

      const toSnakeCase = (value) =>
        value
          .replace(/^[A-Z]/, (match) => match.toLowerCase())
          .replace(/[A-Z]/g, (match) => `_${match.toLowerCase()}`);

      const stripLocaleFromPath = (pathname) => {
        const normalized = pathname.replace(/\/{2,}/g, "/").replace(/\/index\.html$/i, "/");
        const stripped = normalized.replace(/^\/(zh-tw|ja)(?=\/|$)/i, "");
        return stripped === "" ? "/" : stripped.endsWith("/") ? stripped : `${stripped}/`;
      };

      const getPageType = (pathname) => {
        const strippedPath = stripLocaleFromPath(pathname);

        if (/^\/projects\/[^/]+\/$/i.test(strippedPath)) return "project_detail";
        if (strippedPath === "/projects/") return "projects_index";
        if (/^\/blog\/[^/]+\/$/i.test(strippedPath)) return "blog_detail";
        if (strippedPath === "/blog/") return "blog_index";
        if (/^\/research\/[^/]+\/$/i.test(strippedPath)) return "research_direction";
        if (strippedPath === "/research/") return "research_index";
        if (/^\/talks\/[^/]+\/$/i.test(strippedPath)) return "talk_detail";
        if (strippedPath === "/talks/") return "talks_index";
        if (strippedPath === "/contact/") return "contact";
        if (strippedPath === "/links/") return "links";
        if (strippedPath === "/resume/") return "resume";
        if (strippedPath === "/about/") return "about";
        return strippedPath === "/" ? "home" : "page";
      };

      const getLocation = (target) => {
        const scopedLocation = target.closest("[data-analytics-location]")?.dataset.analyticsLocation;

        if (scopedLocation) {
          return scopedLocation;
        }

        if (target.closest("header")) return "header";
        if (target.closest("footer")) return "footer";
        if (target.closest("aside")) return "sidebar";
        return "content";
      };

      const getReadableLabel = (target) => {
        const explicitLabel = target.dataset.analyticsLabel || target.getAttribute("aria-label") || target.getAttribute("title");

        if (explicitLabel) {
          return trimValue(explicitLabel);
        }

        const structuredLabel = target.querySelector("h1, h2, h3, strong");

        if (structuredLabel?.textContent) {
          return trimValue(structuredLabel.textContent).slice(0, 120);
        }

        const text = trimValue(target.textContent || "");
        return text ? text.slice(0, 120) : undefined;
      };

      const sanitizeProps = (rawProps) => {
        const props = {};

        Object.entries(rawProps).forEach(([key, value]) => {
          if (value === undefined || value === null) {
            return;
          }

          const trimmed = trimValue(value);

          if (!trimmed) {
            return;
          }

          props[key] = trimmed.slice(0, 180);
        });

        return Object.keys(props).length > 0 ? props : undefined;
      };

      const collectProps = (target, url) => {
        const props = {
          location: getLocation(target)
        };

        Object.entries(target.dataset).forEach(([key, value]) => {
          if (!key.startsWith("analytics") || key === "analyticsLocation") {
            return;
          }

          props[toSnakeCase(key.slice("analytics".length))] = value;
        });

        if (target.dataset.plausibleProject) {
          props.project = target.dataset.plausibleProject;
        }

        if (target.dataset.plausibleSlug) {
          props.slug = target.dataset.plausibleSlug;
        }

        if (url && url.origin !== window.location.origin) {
          props.domain = url.hostname.replace(/^www\./i, "");
        }

        const label = getReadableLabel(target);

        if (label && !props.label) {
          props.label = label;
        }

        return sanitizeProps(props);
      };

      const withBaseProps = (target, url, baseProps = {}) =>
        sanitizeProps({
          ...baseProps,
          ...(collectProps(target, url) || {})
        });

      const track = (eventName, { props, interactive = true, clarityEvent = true } = {}) => {
        const payload = {};

        if (props) {
          payload.props = props;
        }

        if (interactive === false) {
          payload.interactive = false;
        }

        if (typeof window.plausible === "function") {
          window.plausible(eventName, Object.keys(payload).length > 0 ? payload : undefined);
        }

        if (clarityEvent && typeof window.clarity === "function") {
          window.clarity("event", eventName);
        }
      };

      window.__siteAnalytics = { track };

      const currentPageType = getPageType(currentPathname);

      const applyClarityTags = () => {
        if (typeof window.clarity !== "function") {
          return false;
        }

        window.clarity("set", "locale", locale);
        window.clarity("set", "page_type", currentPageType);
        window.clarity("set", "path", stripLocaleFromPath(currentPathname));
        window.clarity("set", "device_profile", document.documentElement.dataset.device || "unknown");
        return true;
      };

      applyClarityTags();
      window.addEventListener("load", applyClarityTags, { once: true });
      window.setTimeout(applyClarityTags, 1500);

      const isInternalLink = (url) => Boolean(url) && url.origin === window.location.origin;
      const isCta = (target) =>
        target.classList.contains("button-primary") ||
        target.classList.contains("button-secondary") ||
        target.classList.contains("surface-link") ||
        target.classList.contains("panel") ||
        target.classList.contains("action-link");
      const isNavigationLink = (target) => {
        const location = getLocation(target);
        return location.startsWith("navbar") || location.startsWith("footer_");
      };

      const deriveDestination = (pathname) => {
        const strippedPath = stripLocaleFromPath(pathname);
        if (strippedPath === "/") return "home";
        const [firstSegment] = strippedPath.split("/").filter(Boolean);
        return firstSegment || "page";
      };

      const resolveTrackedEvent = (target) => {
        const url = target instanceof HTMLAnchorElement ? normalizeHref(target.href) : null;
        const explicitEventName = target.dataset.plausibleEvent;

        if (explicitEventName) {
          return {
            eventName: explicitEventName,
            props: collectProps(target, url),
            interactive: target.dataset.analyticsInteractive !== "false"
          };
        }

        if (!(target instanceof HTMLAnchorElement) || !url) {
          return null;
        }

        if (target.href.startsWith("mailto:")) {
          return {
            eventName: "contact_click",
            props: withBaseProps(target, url, { method: "email" })
          };
        }

        if (!isInternalLink(url)) {
          return {
            eventName: "external_link_click",
            props: collectProps(target, url)
          };
        }

        if (url.pathname === window.location.pathname && url.hash) {
          return null;
        }

        const strippedPath = stripLocaleFromPath(url.pathname);
        const projectMatch = strippedPath.match(/^\/projects\/([^/]+)\/$/i);
        const blogMatch = strippedPath.match(/^\/blog\/([^/]+)\/$/i);
        const researchDirectionMatch = strippedPath.match(/^\/research\/([^/]+)\/$/i);
        const talkMatch = strippedPath.match(/^\/talks\/([^/]+)\/$/i);

        if (strippedPath === "/contact/") {
          return {
            eventName: "contact_click",
            props: withBaseProps(target, url, { method: "internal_page" })
          };
        }

        if (projectMatch) {
          return {
            eventName: "project_open",
            props: withBaseProps(target, url, { slug: projectMatch[1] })
          };
        }

        if (blogMatch) {
          return {
            eventName: "blog_open",
            props: withBaseProps(target, url, { slug: blogMatch[1] })
          };
        }

        if (researchDirectionMatch) {
          return {
            eventName: "research_direction_open",
            props: withBaseProps(target, url, { slug: researchDirectionMatch[1] })
          };
        }

        if (talkMatch) {
          return {
            eventName: "talk_open",
            props: withBaseProps(target, url, { slug: talkMatch[1] })
          };
        }

        if (isCta(target)) {
          return {
            eventName: "cta_click",
            props: withBaseProps(target, url, {
              destination: deriveDestination(url.pathname),
              label: getReadableLabel(target)
            })
          };
        }

        if (isNavigationLink(target)) {
          return {
            eventName: "navigation_click",
            props: withBaseProps(target, url, {
              destination: deriveDestination(url.pathname),
              label: getReadableLabel(target)
            })
          };
        }

        return null;
      };

      document.addEventListener(
        "click",
        (event) => {
          const target = event.target instanceof Element ? event.target.closest("a, button") : null;

          if (!(target instanceof HTMLElement)) {
            return;
          }

          const trackedEvent = resolveTrackedEvent(target);

          if (!trackedEvent) {
            return;
          }

          track(trackedEvent.eventName, {
            props: trackedEvent.props,
            interactive: trackedEvent.interactive
          });
        },
        { capture: true }
      );

      const trackedScrollDepths = new Set();
      const normalizedThresholds = Array.isArray(scrollDepthThresholds)
        ? scrollDepthThresholds
            .map((value) => Number(value))
            .filter((value) => Number.isFinite(value) && value > 0 && value < 100)
            .sort((left, right) => left - right)
        : [];

      let scrollTicking = false;

      const reportScrollDepth = () => {
        if (normalizedThresholds.length === 0) {
          return;
        }

        const scrollRoot = document.documentElement;
        const scrollableHeight = scrollRoot.scrollHeight - window.innerHeight;

        if (scrollableHeight <= 0) {
          return;
        }

        const depth = Math.min(100, Math.round(((window.scrollY + window.innerHeight) / scrollRoot.scrollHeight) * 100));

        normalizedThresholds.forEach((threshold) => {
          if (depth < threshold || trackedScrollDepths.has(threshold)) {
            return;
          }

          trackedScrollDepths.add(threshold);
          track("scroll_depth", {
            props: sanitizeProps({
              depth: threshold,
              page_type: currentPageType
            }),
            interactive: false,
            clarityEvent: false
          });
        });
      };

      const queueScrollDepthReport = () => {
        if (scrollTicking) {
          return;
        }

        scrollTicking = true;
        window.requestAnimationFrame(() => {
          scrollTicking = false;
          reportScrollDepth();
        });
      };

      reportScrollDepth();
      window.addEventListener("scroll", queueScrollDepthReport, { passive: true });
      window.addEventListener("resize", queueScrollDepthReport, { passive: true });

      (() => {
        const root = document.documentElement;
        const queries = {
          mobile: window.matchMedia("(max-width: 47.99rem)"),
          tablet: window.matchMedia("(min-width: 48rem) and (max-width: 79.99rem)"),
          coarse: window.matchMedia("(pointer: coarse)"),
          reducedMotion: window.matchMedia("(prefers-reduced-motion: reduce)"),
          landscape: window.matchMedia("(orientation: landscape)")
        };

        const applyDeviceProfile = () => {
          root.dataset.device = queries.mobile.matches ? "mobile" : queries.tablet.matches ? "tablet" : "desktop";
          root.dataset.input = queries.coarse.matches ? "coarse" : "fine";
          root.dataset.motion = queries.reducedMotion.matches ? "reduced" : "full";
          root.dataset.orientation = queries.landscape.matches ? "landscape" : "portrait";
        };

        Object.values(queries).forEach((query) => query.addEventListener?.("change", applyDeviceProfile));
        window.addEventListener("resize", applyDeviceProfile, { passive: true });
      })();
    </script>
  </body>
</html>
