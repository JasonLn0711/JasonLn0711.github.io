---
import Footer from "../components/layout/Footer.astro";
import Navbar from "../components/layout/Navbar.astro";
import Head from "../components/seo/Head.astro";
import { absoluteUrl, normalizePathname } from "../lib/site";
import {
  getLocaleFromPathname,
  getLocaleMeta,
  getLocalizedProfile,
  getLocalizedSpeaking,
  getPageCopy,
  localizePath
} from "../lib/i18n";
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
  image?: string;
  pathname?: string;
  type?: "website" | "article";
  schema?: Record<string, unknown> | Array<Record<string, unknown>>;
  noindex?: boolean;
  publishedTime?: string;
  modifiedTime?: string;
}

const {
  title,
  description,
  image,
  pathname = Astro.url.pathname,
  type = "website",
  schema,
  noindex = false,
  publishedTime,
  modifiedTime
} = Astro.props;

const currentPathname = normalizePathname(pathname);
const locale = getLocaleFromPathname(currentPathname);
const localeInfo = getLocaleMeta(locale);
const localizedProfile = getLocalizedProfile(locale);
const localizedSpeaking = getLocalizedSpeaking(locale);
const copy = getPageCopy(locale);
const officialSessionUrl = localizedSpeaking.featuredEngagement.url;
const speakerProfileUrl = localizedProfile.externalProfiles.cybersecSpeaker.url;
const talkStoryUrl = absoluteUrl(localizePath(localizedSpeaking.featuredEngagement.storyHref, locale));
---

<!doctype html>
<html lang={localeInfo.htmlLang} data-device="desktop" data-input="fine" data-motion="full">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <script is:inline>
      (() => {
        const root = document.documentElement;
        const queries = {
          mobile: window.matchMedia("(max-width: 47.99rem)"),
          tablet: window.matchMedia("(min-width: 48rem) and (max-width: 79.99rem)"),
          coarse: window.matchMedia("(pointer: coarse)"),
          reducedMotion: window.matchMedia("(prefers-reduced-motion: reduce)"),
          landscape: window.matchMedia("(orientation: landscape)")
        };

        const applyDeviceProfile = () => {
          root.dataset.device = queries.mobile.matches ? "mobile" : queries.tablet.matches ? "tablet" : "desktop";
          root.dataset.input = queries.coarse.matches ? "coarse" : "fine";
          root.dataset.motion = queries.reducedMotion.matches ? "reduced" : "full";
          root.dataset.orientation = queries.landscape.matches ? "landscape" : "portrait";
        };

        applyDeviceProfile();
      })();
    </script>
    <Head
      title={title}
      description={description}
      image={image}
      pathname={pathname}
      type={type}
      schema={schema}
      noindex={noindex}
      publishedTime={publishedTime}
      modifiedTime={modifiedTime}
      locale={locale}
    />
  </head>
  <body>
    <a href="#content" class="skip-link">{copy.common.skipToContent}</a>
    <div class="flex min-h-screen flex-col">
      <Navbar locale={locale} pathname={currentPathname} />
      <main id="content" tabindex="-1" class="flex-1 focus:outline-none">
        <slot />
      </main>
      <Footer locale={locale} />
    </div>
    <script is:inline define:vars={{ officialSessionUrl, speakerProfileUrl, talkStoryUrl }}>
      const normalizeHref = (href) => {
        try {
          return new URL(href, window.location.origin).toString();
        } catch {
          return href;
        }
      };

      const collectProps = (target) => {
        const props = {};

        if (target.dataset.plausibleProject) {
          props.project = target.dataset.plausibleProject;
        }

        if (target.dataset.plausibleSlug) {
          props.slug = target.dataset.plausibleSlug;
        }

        return Object.keys(props).length > 0 ? props : undefined;
      };

      document.addEventListener(
        "click",
        (event) => {
          const target = event.target instanceof Element ? event.target.closest("a, button") : null;

          if (!(target instanceof HTMLElement)) {
            return;
          }

          let eventName = target.dataset.plausibleEvent;

          if (!eventName && target instanceof HTMLAnchorElement) {
            const href = normalizeHref(target.href);

            if (target.href.startsWith("mailto:")) {
              eventName = "email_click";
            } else if (href === officialSessionUrl) {
              eventName = "official_session_click";
            } else if (href === speakerProfileUrl) {
              eventName = "speaker_profile_click";
            } else if (href === talkStoryUrl) {
              eventName = "talk_story_click";
            }
          }

          if (!eventName || typeof window.plausible !== "function") {
            return;
          }

          const props = collectProps(target);

          if (props) {
            window.plausible(eventName, { props });
            return;
          }

          window.plausible(eventName);
        },
        { capture: true }
      );

      (() => {
        const root = document.documentElement;
        const queries = {
          mobile: window.matchMedia("(max-width: 47.99rem)"),
          tablet: window.matchMedia("(min-width: 48rem) and (max-width: 79.99rem)"),
          coarse: window.matchMedia("(pointer: coarse)"),
          reducedMotion: window.matchMedia("(prefers-reduced-motion: reduce)"),
          landscape: window.matchMedia("(orientation: landscape)")
        };

        const applyDeviceProfile = () => {
          root.dataset.device = queries.mobile.matches ? "mobile" : queries.tablet.matches ? "tablet" : "desktop";
          root.dataset.input = queries.coarse.matches ? "coarse" : "fine";
          root.dataset.motion = queries.reducedMotion.matches ? "reduced" : "full";
          root.dataset.orientation = queries.landscape.matches ? "landscape" : "portrait";
        };

        Object.values(queries).forEach((query) => query.addEventListener?.("change", applyDeviceProfile));
        window.addEventListener("resize", applyDeviceProfile, { passive: true });
      })();
    </script>
  </body>
</html>
