---
import Footer from "../components/layout/Footer.astro";
import Navbar from "../components/layout/Navbar.astro";
import Head from "../components/seo/Head.astro";
import { profile } from "../data/profile";
import { speaking } from "../data/speaking";
import { absoluteUrl } from "../lib/site";
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
  image?: string;
  pathname?: string;
  type?: "website" | "article";
  schema?: Record<string, unknown> | Array<Record<string, unknown>>;
  noindex?: boolean;
  publishedTime?: string;
  modifiedTime?: string;
}

const {
  title,
  description,
  image,
  pathname = "/",
  type = "website",
  schema,
  noindex = false,
  publishedTime,
  modifiedTime
} = Astro.props;

const officialSessionUrl = speaking.featuredEngagement.url;
const speakerProfileUrl = profile.externalProfiles.cybersecSpeaker.url;
const talkStoryUrl = absoluteUrl(speaking.featuredEngagement.storyHref);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <Head
      title={title}
      description={description}
      image={image}
      pathname={pathname}
      type={type}
      schema={schema}
      noindex={noindex}
      publishedTime={publishedTime}
      modifiedTime={modifiedTime}
    />
  </head>
  <body>
    <a href="#content" class="skip-link">Skip to content</a>
    <div class="flex min-h-screen flex-col">
      <Navbar />
      <main id="content" class="flex-1">
        <slot />
      </main>
      <Footer />
    </div>
    <script is:inline define:vars={{ officialSessionUrl, speakerProfileUrl, talkStoryUrl }}>
      const normalizeHref = (href) => {
        try {
          return new URL(href, window.location.origin).toString();
        } catch {
          return href;
        }
      };

      const collectProps = (target) => {
        const props = {};

        if (target.dataset.plausibleProject) {
          props.project = target.dataset.plausibleProject;
        }

        if (target.dataset.plausibleSlug) {
          props.slug = target.dataset.plausibleSlug;
        }

        return Object.keys(props).length > 0 ? props : undefined;
      };

      document.addEventListener(
        "click",
        (event) => {
          const target = event.target instanceof Element ? event.target.closest("a, button") : null;

          if (!(target instanceof HTMLElement)) {
            return;
          }

          let eventName = target.dataset.plausibleEvent;

          if (!eventName && target instanceof HTMLAnchorElement) {
            const href = normalizeHref(target.href);

            if (target.href.startsWith("mailto:")) {
              eventName = "email_click";
            } else if (href === officialSessionUrl) {
              eventName = "official_session_click";
            } else if (href === speakerProfileUrl) {
              eventName = "speaker_profile_click";
            } else if (href === talkStoryUrl) {
              eventName = "talk_story_click";
            }
          }

          if (!eventName || typeof window.plausible !== "function") {
            return;
          }

          const props = collectProps(target);

          if (props) {
            window.plausible(eventName, { props });
            return;
          }

          window.plausible(eventName);
        },
        { capture: true }
      );
    </script>
  </body>
</html>
