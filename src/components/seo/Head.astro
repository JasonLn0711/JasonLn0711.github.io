---
import { profile } from "../../data/profile";
import { personSchema, webPageSchema, websiteSchema } from "../../lib/schema";
import { absoluteUrl } from "../../lib/site";
import {
  defaultLocale,
  getAlternateLocaleLinks,
  getLocaleFromPathname,
  getLocaleMeta,
  getLocalizedSite,
  localizePath,
  stripLocaleFromPathname,
  type SiteLocale
} from "../../lib/i18n";

interface Props {
  title?: string;
  description?: string;
  image?: string;
  pathname?: string;
  type?: "website" | "article";
  schema?: JsonLd | JsonLd[];
  noindex?: boolean;
  publishedTime?: string;
  modifiedTime?: string;
  locale?: SiteLocale;
}

type JsonLd = Record<string, unknown>;

const {
  title: rawTitle,
  description: rawDescription,
  image: rawImage,
  pathname = "/",
  type = "website",
  schema = [],
  noindex = false,
  publishedTime,
  modifiedTime,
  locale: requestedLocale
} = Astro.props;

const locale = requestedLocale ?? getLocaleFromPathname(pathname);
const localeInfo = getLocaleMeta(locale);
const localizedSite = getLocalizedSite(locale);
const title = rawTitle ?? localizedSite.defaultTitle;
const description = rawDescription ?? localizedSite.description;
const image = rawImage ?? localizedSite.ogImage;
const canonical = absoluteUrl(pathname);
const socialImage = image.startsWith("http") ? image : absoluteUrl(image);
const pageName = title === localizedSite.defaultTitle ? localizedSite.name : title.split(" | ")[0] ?? title;
const extraSchemas = Array.isArray(schema) ? schema : schema ? [schema] : [];
const isHomePath = stripLocaleFromPathname(pathname) === "/";
const baseSchemas: JsonLd[] = noindex
  ? []
  : isHomePath
    ? [personSchema(profile), websiteSchema(profile), webPageSchema({ name: pageName, description, pathname, image })]
    : [webPageSchema({ name: pageName, description, pathname, image })];
const allSchemas: JsonLd[] = [...baseSchemas, ...extraSchemas];
const plausibleSnippet = localizedSite.analytics.plausibleSnippet.trim();
const clarityProjectId = localizedSite.analytics.clarityProjectId.trim();
const googleSiteVerificationToken = localizedSite.verification.googleSiteVerificationToken.trim();
const alternateLocaleLinks = getAlternateLocaleLinks(pathname);
const defaultAlternate = absoluteUrl(localizePath(stripLocaleFromPathname(pathname), defaultLocale));
---

<title>{title}</title>
<meta name="description" content={description} />
<meta name="robots" content={noindex ? "noindex, follow" : "index, follow"} />
<meta name="theme-color" content="#0b1020" />
<meta name="language" content={localeInfo.hreflang} />
<link rel="canonical" href={canonical} />
<link rel="alternate" hreflang="x-default" href={defaultAlternate} />
{alternateLocaleLinks.map((entry) => <link rel="alternate" hreflang={entry.hreflang} href={absoluteUrl(entry.href)} />)}
<link rel="alternate" type="application/rss+xml" title={`${localizedSite.name} RSS Feed`} href={absoluteUrl("/rss.xml")} />
{googleSiteVerificationToken && <meta name="google-site-verification" content={googleSiteVerificationToken} />}
<meta property="og:type" content={type} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:url" content={canonical} />
<meta property="og:site_name" content={localizedSite.name} />
<meta property="og:locale" content={localeInfo.ogLocale} />
<meta property="og:image" content={socialImage} />
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={socialImage} />
{type === "article" && publishedTime && <meta property="article:published_time" content={publishedTime} />}
{type === "article" && modifiedTime && <meta property="article:modified_time" content={modifiedTime} />}
{allSchemas.map((entry) => <script is:inline type="application/ld+json" set:html={JSON.stringify(entry)} />)}
{plausibleSnippet && <Fragment set:html={plausibleSnippet} />}
{clarityProjectId && (
  <script is:inline define:vars={{ clarityProjectId }}>
    (function(c, l, a, r, i, t, y) {
      c[a] =
        c[a] ||
        function() {
          (c[a].q = c[a].q || []).push(arguments);
        };
      t = l.createElement(r);
      t.async = 1;
      t.src = "https://www.clarity.ms/tag/" + i;
      y = l.getElementsByTagName(r)[0];
      y.parentNode.insertBefore(t, y);
    })(window, document, "clarity", "script", clarityProjectId);
  </script>
)}
{pathname === "/404.html" && (
  <script is:inline>
    document.addEventListener("DOMContentLoaded", () => {
      window.plausible?.("404");
    });
  </script>
)}
