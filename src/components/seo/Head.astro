---
import { profile } from "../../data/profile";
import { personSchema, webPageSchema, websiteSchema } from "../../lib/schema";
import { absoluteUrl, site } from "../../lib/site";

interface Props {
  title?: string;
  description?: string;
  image?: string;
  pathname?: string;
  type?: "website" | "article";
  schema?: JsonLd | JsonLd[];
  noindex?: boolean;
  publishedTime?: string;
  modifiedTime?: string;
}

type JsonLd = Record<string, unknown>;

const {
  title = site.defaultTitle,
  description = site.description,
  image = site.ogImage,
  pathname = "/",
  type = "website",
  schema = [],
  noindex = false,
  publishedTime,
  modifiedTime
} = Astro.props;

const canonical = absoluteUrl(pathname);
const socialImage = image.startsWith("http") ? image : absoluteUrl(image);
const pageName = title === site.defaultTitle ? site.name : title.split(" | ")[0] ?? title;
const extraSchemas = Array.isArray(schema) ? schema : schema ? [schema] : [];
const baseSchemas: JsonLd[] = noindex
  ? []
  : pathname === "/"
    ? [personSchema(profile), websiteSchema(profile), webPageSchema({ name: pageName, description, pathname, image })]
    : [webPageSchema({ name: pageName, description, pathname, image })];
const allSchemas: JsonLd[] = [...baseSchemas, ...extraSchemas];
const plausibleSnippet = site.analytics.plausibleSnippet.trim();
const googleSiteVerificationToken = site.verification.googleSiteVerificationToken.trim();
---

<title>{title}</title>
<meta name="description" content={description} />
<meta name="robots" content={noindex ? "noindex, follow" : "index, follow"} />
<meta name="theme-color" content="#0b1020" />
<link rel="canonical" href={canonical} />
<link rel="alternate" type="application/rss+xml" title={`${site.name} RSS Feed`} href={absoluteUrl("/rss.xml")} />
{googleSiteVerificationToken && <meta name="google-site-verification" content={googleSiteVerificationToken} />}
<meta property="og:type" content={type} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:url" content={canonical} />
<meta property="og:site_name" content={site.name} />
<meta property="og:locale" content={site.locale} />
<meta property="og:image" content={socialImage} />
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={socialImage} />
{type === "article" && publishedTime && <meta property="article:published_time" content={publishedTime} />}
{type === "article" && modifiedTime && <meta property="article:modified_time" content={modifiedTime} />}
{allSchemas.map((entry) => <script is:inline type="application/ld+json" set:html={JSON.stringify(entry)} />)}
{plausibleSnippet && <Fragment set:html={plausibleSnippet} />}
{pathname === "/404.html" && (
  <script is:inline>
    document.addEventListener("DOMContentLoaded", () => {
      window.plausible?.("404");
    });
  </script>
)}
