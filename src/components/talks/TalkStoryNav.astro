---
interface StoryLink {
  chapter: string;
  id: string;
  navLabel: string;
}

interface Props {
  sections: ReadonlyArray<StoryLink>;
  mode?: "desktop" | "mobile";
}

const { sections, mode = "desktop" } = Astro.props;
const isDesktop = mode === "desktop";
---

{isDesktop ? (
  <nav aria-label="Talk chapters" class="toc-card">
    <p class="muted-label">Talk chapters</p>
    <ol class="mt-4 space-y-2">
      {sections.map((section) => (
        <li>
          <a
            href={`#${section.id}`}
            class="flex items-start gap-3 rounded-2xl border border-transparent px-3 py-3 text-[var(--color-muted)] transition hover:border-[rgba(31,27,23,0.12)] hover:bg-[rgba(31,27,23,0.03)] hover:text-[var(--color-ink)] focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-[var(--color-accent)]"
          >
            <span class="min-w-10 muted-label">{section.chapter}</span>
            <span class="text-sm leading-6">{section.navLabel}</span>
          </a>
        </li>
      ))}
    </ol>
  </nav>
) : (
  <div class="toc-card xl:hidden">
    <details class="group">
      <summary class="flex cursor-pointer list-none items-center justify-between gap-4 rounded-2xl px-2 py-1 text-sm font-semibold text-[var(--color-ink)]">
        <span>Jump to a chapter</span>
        <span class="muted-label">{sections.length} sections</span>
      </summary>

      <ol class="mt-4 grid gap-2 sm:grid-cols-2">
        {sections.map((section) => (
          <li>
            <a
              href={`#${section.id}`}
              class="flex items-start gap-3 rounded-2xl border border-[rgba(31,27,23,0.08)] bg-[rgba(255,252,247,0.6)] px-3 py-3 text-[var(--color-muted)] transition hover:border-[rgba(31,27,23,0.14)] hover:text-[var(--color-ink)] focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-[var(--color-accent)]"
            >
              <span class="min-w-10 muted-label">{section.chapter}</span>
              <span class="text-sm leading-6">{section.navLabel}</span>
            </a>
          </li>
        ))}
      </ol>
    </details>
  </div>
)}

<style>
  summary::-webkit-details-marker {
    display: none;
  }
</style>
