---
interface Action {
  href: string;
  label: string;
  variant?: "primary" | "secondary" | "link";
  external?: boolean;
}

interface Stat {
  label: string;
  value: string;
}

interface Props {
  eyebrow?: string;
  kicker?: string;
  title: string;
  summary?: string;
  actions?: ReadonlyArray<Action>;
  stats?: ReadonlyArray<Stat>;
  split?: boolean;
  titleClass?: string;
  summaryClass?: string;
  className?: string;
}

const {
  eyebrow,
  kicker,
  title,
  summary,
  actions = [],
  stats = [],
  split = false,
  titleClass = "",
  summaryClass = "",
  className = ""
} = Astro.props;

const hasMedia = Astro.slots.has("media");
const hasAside = Astro.slots.has("aside");
---

<section class:list={["page-hero", split && (hasMedia || hasAside) && "page-hero--split", className]}>
  <div class="page-hero__copy">
    {eyebrow && <span class="eyebrow">{eyebrow}</span>}
    {kicker && <p class="page-kicker">{kicker}</p>}
    <h1 class:list={["display-title", titleClass]}>{title}</h1>
    {summary && <p class:list={["page-summary", summaryClass]}>{summary}</p>}

    {actions.length > 0 && (
      <div class="page-actions">
        {actions.map((action) => (
          <a
            href={action.href}
            class:list={[
              action.variant === "secondary"
                ? "button-secondary"
                : action.variant === "link"
                  ? "action-link"
                  : "button-primary"
            ]}
            target={action.external ? "_blank" : undefined}
            rel={action.external ? "noreferrer" : undefined}
          >
            {action.label}
          </a>
        ))}
      </div>
    )}

    {stats.length > 0 && (
      <dl class="page-hero__stats">
        {stats.map((stat) => (
          <div class="stat-card">
            <dt>{stat.label}</dt>
            <dd>{stat.value}</dd>
          </div>
        ))}
      </dl>
    )}
  </div>

  {hasMedia && (
    <div class="page-hero__media">
      <slot name="media" />
    </div>
  )}

  {hasAside && (
    <div class="page-hero__aside">
      <slot name="aside" />
    </div>
  )}
</section>
