---
interface Item {
  label: string;
  value: string | string[];
}

interface Props {
  items: Item[];
  className?: string;
}

const { items, className = "" } = Astro.props;
---

<div class:list={["meta-rail", className]}>
  {items.map((item) => (
    <div class="meta-rail__item">
      <p class="meta-rail__label">{item.label}</p>
      {Array.isArray(item.value) ? (
        <div class="meta-rail__value flex flex-wrap gap-2">
          {item.value.map((value) => <span class="pill">{value}</span>)}
        </div>
      ) : (
        <p class="meta-rail__value">{item.value}</p>
      )}
    </div>
  ))}
</div>
