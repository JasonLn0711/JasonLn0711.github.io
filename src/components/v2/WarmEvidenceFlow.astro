---
import { getWarmStudio, type WarmStudioPage } from "../../data/siteV2";
import {
  defaultLocale,
  getLocalizedProfile,
  localizePath,
  type SiteLocale
} from "../../lib/i18n";

interface Props {
  locale?: SiteLocale;
  page: WarmStudioPage;
}

const { locale = defaultLocale, page } = Astro.props;
const studio = getWarmStudio(locale);
const profile = getLocalizedProfile(locale);
const guide = studio.pages[page];
const actionHref = guide.action.href === "mailto" ? `mailto:${profile.email}` : localizePath(guide.action.href, locale);
---

<section class="warm-flow" data-analytics-location={`warm_evidence_flow_${page}`}>
  <div class="warm-flow__intro">
    <p class="section-kicker">{guide.eyebrow}</p>
    <h2>{guide.title}</h2>
    <p>{guide.description}</p>
  </div>

  <ol class="warm-flow__steps" aria-label={guide.title}>
    {guide.path.map((step, index) => (
      <li class="warm-flow__step">
        <span class="warm-flow__index">{String(index + 1).padStart(2, "0")}</span>
        <div>
          <p class="mono-label">{step.label}</p>
          <h3>{step.title}</h3>
          <p>{step.text}</p>
        </div>
      </li>
    ))}
  </ol>

  <div class="warm-flow__action">
    <p class="mono-label">{studio.boundaryLabel}</p>
    <p>{guide.path[3]?.text}</p>
    <a href={actionHref} class="button-primary">{guide.action.label}</a>
  </div>
</section>
