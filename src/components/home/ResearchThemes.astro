---
import { defaultLocale, getLocalizedHome, getLocalizedResearch, getPageCopy, localizePath, type SiteLocale } from "../../lib/i18n";
import SectionIntro from "../ui/SectionIntro.astro";

interface Props {
  locale?: SiteLocale;
}

const { locale = defaultLocale } = Astro.props;
const home = getLocalizedHome(locale);
const research = getLocalizedResearch(locale);
const copy = getPageCopy(locale);
---

<section class="section" data-analytics-location="home_research">
  <div class="shell space-y-8">
    <SectionIntro eyebrow={home.research.eyebrow} title={home.research.title} copy={home.research.description}>
      <Fragment slot="actions">
        <a href={localizePath("/research/", locale)} class="button-secondary">{home.research.browseLabel}</a>
      </Fragment>
    </SectionIntro>

    <div class="grid gap-6 md:grid-cols-2 xl:grid-cols-3" data-analytics-location="home_research_directions">
      {research.pillars.map((theme) => (
        <a
          href={localizePath(`/research/${theme.slug}/`, locale)}
          class="surface-link group flex h-full flex-col gap-5 p-6 sm:p-7"
        >
          <h3 class="font-[var(--font-display)] text-[2rem] leading-[0.98] tracking-[-0.03em]">{theme.title}</h3>
          <p class="text-sm leading-7">{theme.description}</p>
          <div class="mt-auto space-y-4">
            <div class="flex flex-wrap gap-2">
              {theme.tags.map((tag) => <span class="pill">{tag}</span>)}
            </div>
            <span class="action-link">
              {copy.researchDirectionPage.openDirection}
              <span aria-hidden="true">→</span>
            </span>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>
