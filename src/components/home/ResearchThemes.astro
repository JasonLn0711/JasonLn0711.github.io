---
import SectionHeader from "../common/SectionHeader.astro";
import { signatureThemes } from "../../data/research";
---

<section class="section">
  <div class="shell space-y-8">
    <SectionHeader
      eyebrow="Signature Themes"
      title="A research profile shaped by deployment, trust, and operational reality."
      description="These themes organize the site and make clear what I build toward: AI systems that remain useful when the setting is complex, constrained, and consequential."
    />

    <div class="grid gap-6 md:grid-cols-2">
      {signatureThemes.map((theme) => (
        <article class="panel flex h-full flex-col gap-5 p-6 sm:p-7">
          <span class="pill w-fit">{theme.title}</span>
          <h3 class="text-2xl font-semibold tracking-tight text-[var(--color-ink)]">{theme.title}</h3>
          <p class="text-sm leading-7 text-[var(--color-muted)]">{theme.description}</p>
        </article>
      ))}
    </div>
  </div>
</section>
