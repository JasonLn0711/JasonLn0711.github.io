---
import { defaultLocale, getLocalizedHome, getLocalizedResearch, getPageCopy, localizePath, type SiteLocale } from "../../lib/i18n";

interface Props {
  locale?: SiteLocale;
}

const { locale = defaultLocale } = Astro.props;
const home = getLocalizedHome(locale);
const research = getLocalizedResearch(locale);
const copy = getPageCopy(locale);
---

<section class="section" data-analytics-location="home_research">
  <div class="shell space-y-8">
    <div class="grid gap-5 lg:grid-cols-[minmax(0,0.82fr)_auto] lg:items-end">
      <div class="section-intro">
        <span class="section-kicker">{home.research.eyebrow}</span>
        <h2 class="section-title">{home.research.title}</h2>
        <p class="section-copy">
          {home.research.description}
        </p>
      </div>
      <a href={localizePath("/research/", locale)} class="button-secondary">{home.research.browseLabel}</a>
    </div>

    <div class="research-matrix" data-analytics-location="home_research_directions">
      {research.pillars.map((theme) => (
        <a
          href={localizePath(`/research/${theme.slug}/`, locale)}
          class="research-matrix__item group"
        >
          <div>
            <p class="mono-label">Direction</p>
            <h3 class="mt-3 text-2xl font-semibold tracking-tight text-white">{theme.title}</h3>
          </div>
          <p class="text-sm leading-7 text-slate-300">{theme.description}</p>
          <div class="space-y-4">
            <div class="flex flex-wrap gap-2">
              {theme.tags.map((tag) => <span class="pill">{tag}</span>)}
            </div>
            <span class="inline-flex items-center gap-2 text-sm font-semibold text-[var(--color-accent)] transition group-hover:text-[var(--color-accent-strong)]">
              {copy.researchDirectionPage.openDirection}
              <span aria-hidden="true">→</span>
            </span>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>
