---
import { defaultLocale, getLocalizedHome, getLocalizedResearch, localizePath, type SiteLocale } from "../../lib/i18n";

interface Props {
  locale?: SiteLocale;
}

const { locale = defaultLocale } = Astro.props;
const home = getLocalizedHome(locale);
const research = getLocalizedResearch(locale);
---

<section class="section">
  <div class="shell space-y-8">
    <div class="flex flex-col gap-4 md:flex-row md:items-end md:justify-between">
      <div>
      <span class="eyebrow">{home.research.eyebrow}</span>
      <h2 class="section-title">{home.research.title}</h2>
      <p class="section-copy">
        {home.research.description}
      </p>
      </div>
      <a href={localizePath("/research/", locale)} class="button-secondary">{home.research.browseLabel}</a>
    </div>

    <div class="grid gap-6 md:grid-cols-2 xl:grid-cols-3">
      {research.pillars.map((theme) => (
        <article class="panel flex h-full flex-col gap-5 p-6 sm:p-7">
          <h3 class="text-2xl font-semibold tracking-tight text-white">{theme.title}</h3>
          <p class="text-sm leading-7 text-slate-300">{theme.description}</p>
          <div class="mt-auto flex flex-wrap gap-2">
            {theme.tags.map((tag) => <span class="pill">{tag}</span>)}
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
