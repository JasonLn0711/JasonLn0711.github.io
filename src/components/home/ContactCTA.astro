---
import {
  defaultLocale,
  getLocalizedHome,
  getLocalizedProfile,
  getPageCopy,
  localizePath,
  type SiteLocale
} from "../../lib/i18n";

interface Props {
  locale?: SiteLocale;
}

const { locale = defaultLocale } = Astro.props;
const home = getLocalizedHome(locale);
const profile = getLocalizedProfile(locale);
const copy = getPageCopy(locale);
---

<section class="section pt-8">
  <div class="shell">
    <div class="dossier-panel grid gap-8 p-8 sm:p-10 lg:grid-cols-[1.2fr_0.8fr]">
      <div class="space-y-5">
        <span class="section-kicker">{home.contact.eyebrow}</span>
        <h2 class="section-title">{home.contact.title}</h2>
        <p class="max-w-2xl text-base leading-8 text-slate-300">{profile.contactPrompt}</p>
        <p class="max-w-2xl text-base leading-8 text-slate-300">{home.contact.description}</p>
        <div class="grid gap-3 sm:grid-cols-3">
          {profile.contactTopics.map((topic) => (
            <div class="surface-card">
              <p class="text-sm leading-7 text-slate-300">{topic}</p>
            </div>
          ))}
        </div>
      </div>

      <div class="flex flex-col gap-4 sm:max-w-sm sm:justify-center">
        <div class="surface-card">
          <p class="mono-label">{copy.home.helpfulFirstMessage}</p>
          <p class="mt-3 text-sm leading-7 text-slate-300">
            {copy.home.helpfulFirstMessageCopy}
          </p>
        </div>
        <a href={`mailto:${profile.email}`} class="button-primary">{copy.common.emailJason}</a>
        <a href={localizePath("/contact/", locale)} class="button-secondary">{copy.home.openContactPage}</a>
        <a href={profile.linkedin} target="_blank" rel="noreferrer" class="button-secondary">
          LinkedIn
        </a>
      </div>
    </div>
  </div>
</section>
