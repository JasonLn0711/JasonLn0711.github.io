---
import {
  defaultLocale,
  getLocalizedHome,
  getLocalizedProfile,
  getPageCopy,
  localizePath,
  type SiteLocale
} from "../../lib/i18n";
import CTASection from "../ui/CTASection.astro";

interface Props {
  locale?: SiteLocale;
}

const { locale = defaultLocale } = Astro.props;
const home = getLocalizedHome(locale);
const profile = getLocalizedProfile(locale);
const copy = getPageCopy(locale);
---

<section class="section pt-8">
  <div class="shell">
    <CTASection
      eyebrow={home.contact.eyebrow}
      title={home.contact.title}
      copy={profile.contactPrompt}
      actions={[
        { href: `mailto:${profile.email}`, label: copy.common.emailJason },
        { href: localizePath("/contact/", locale), label: copy.home.openContactPage, variant: "secondary" },
        { href: profile.linkedin, label: "LinkedIn", variant: "secondary", external: true }
      ]}
    />
  </div>
</section>
