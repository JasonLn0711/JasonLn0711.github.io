---
import { home } from "../../data/home";
import { profile } from "../../data/profile";
---

<section class="section pt-8">
  <div class="shell">
    <div class="panel grid gap-8 p-8 sm:p-10 lg:grid-cols-[1.2fr_0.8fr]">
      <div class="space-y-5">
        <span class="eyebrow">{home.contact.eyebrow}</span>
        <h2 class="section-title">{home.contact.title}</h2>
        <p class="max-w-2xl text-base leading-8 text-slate-300">{profile.contactPrompt}</p>
        <p class="max-w-2xl text-base leading-8 text-slate-300">{home.contact.description}</p>
        <div class="grid gap-3 sm:grid-cols-3">
          {profile.contactTopics.map((topic) => (
            <div class="rounded-3xl border border-white/[0.08] bg-white/[0.03] p-4">
              <p class="text-sm leading-7 text-slate-300">{topic}</p>
            </div>
          ))}
        </div>
      </div>

      <div class="flex flex-col gap-4 sm:max-w-sm sm:justify-center">
        <div class="rounded-3xl border border-white/[0.08] bg-white/[0.03] p-5">
          <p class="text-xs uppercase tracking-[0.18em] text-slate-500">Helpful first message</p>
          <p class="mt-3 text-sm leading-7 text-slate-300">
            Share your context, why the conversation fits, and what kind of next step would be most useful.
          </p>
        </div>
        <a href={`mailto:${profile.email}`} class="button-primary">Email Jason</a>
        <a href="/contact/" class="button-secondary">Open contact page</a>
        <a href={profile.linkedin} target="_blank" rel="noreferrer" class="button-secondary">
          LinkedIn
        </a>
      </div>
    </div>
  </div>
</section>
