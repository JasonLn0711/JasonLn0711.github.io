---
import { home } from "../../data/home";
import type { CollectionEntry } from "astro:content";
import BlogCard from "../blog/BlogCard.astro";

interface Props {
  posts: CollectionEntry<"blog">[];
}

const { posts } = Astro.props;
---

<section class="section">
  <div class="shell space-y-8">
    <div class="flex flex-col gap-4 md:flex-row md:items-end md:justify-between">
      <div class="max-w-3xl">
        <span class="eyebrow">{home.writing.eyebrow}</span>
        <h2 class="section-title">{home.writing.title}</h2>
        <p class="section-copy">{home.writing.description}</p>
      </div>
      <a href="/blog/" class="button-secondary">
        {home.writing.browseLabel}
      </a>
    </div>

    {posts.length > 0 ? (
      <div class="grid gap-6 lg:grid-cols-3">
        {posts.map((post) => <BlogCard post={post} eventName="writing_card_click" />)}
      </div>
    ) : (
      <div class="panel p-8">
        <h3 class="text-2xl font-semibold text-white">Writing in progress</h3>
        <p class="mt-4 max-w-2xl text-sm leading-7 text-slate-300">
          New essays, research notes, and technical perspectives will appear here as the body of work continues to grow.
        </p>
      </div>
    )}
  </div>
</section>
