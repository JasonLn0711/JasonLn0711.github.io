---
import type { CollectionEntry } from "astro:content";
import { defaultLocale, getLocalizedHome, getPageCopy, localizePath, type SiteLocale } from "../../lib/i18n";
import BlogCard from "../blog/BlogCard.astro";

interface Props {
  posts: CollectionEntry<"blog">[];
  locale?: SiteLocale;
}

const { posts, locale = defaultLocale } = Astro.props;
const home = getLocalizedHome(locale);
const copy = getPageCopy(locale);
---

<section class="section" data-analytics-location="home_writing">
  <div class="shell space-y-8">
    <div class="flex flex-col gap-4 md:flex-row md:items-end md:justify-between">
      <div class="max-w-3xl">
        <span class="eyebrow">{home.writing.eyebrow}</span>
        <h2 class="section-title">{home.writing.title}</h2>
        <p class="section-copy">{home.writing.description}</p>
      </div>
      <a href={localizePath("/blog/", locale)} class="button-secondary">
        {home.writing.browseLabel}
      </a>
    </div>

    {posts.length > 0 ? (
      <div class="grid gap-6 lg:grid-cols-3" data-analytics-location="home_writing_preview">
        {posts.map((post) => <BlogCard post={post} analyticsLocation="home_writing_preview" locale={locale} />)}
      </div>
    ) : (
      <div class="panel p-8">
        <h3 class="text-2xl font-semibold text-white">{copy.home.writingInProgress}</h3>
        <p class="mt-4 max-w-2xl text-sm leading-7 text-slate-300">
          {copy.home.writingInProgressCopy}
        </p>
      </div>
    )}
  </div>
</section>
