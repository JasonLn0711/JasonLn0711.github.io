---
import type { CollectionEntry } from "astro:content";
import SectionHeader from "../common/SectionHeader.astro";
import BlogCard from "../blog/BlogCard.astro";

interface Props {
  posts: CollectionEntry<"blog">[];
}

const { posts } = Astro.props;
---

<section class="section">
  <div class="shell space-y-8">
    <div class="flex flex-col gap-4 md:flex-row md:items-end md:justify-between">
      <SectionHeader
        eyebrow="Selected Writing"
        title="Research notes that explain the system logic behind the work."
        description="The writing archive is intended as a long-term record of technical thinking around trustworthy AI, speech systems, and operational deployment."
      />
      <a href="/writing/" class="text-sm font-semibold text-[var(--color-accent)] transition hover:text-[var(--color-accent-strong)]">
        View the archive →
      </a>
    </div>

    {posts.length > 0 ? (
      <div class="grid gap-6 lg:grid-cols-3">
        {posts.map((post) => <BlogCard post={post} basePath="/writing" />)}
      </div>
    ) : (
      <div class="panel p-8">
        <h3 class="text-2xl font-semibold text-[var(--color-ink)]">Writing in progress</h3>
        <p class="mt-4 max-w-2xl text-sm leading-7 text-[var(--color-muted)]">
          New essays and engineering notes will appear here as the research portfolio grows.
        </p>
      </div>
    )}
  </div>
</section>
