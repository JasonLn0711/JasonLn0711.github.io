---
import { home } from "../../data/home";
import { profile } from "../../data/profile";
import { speaking } from "../../data/speaking";
---

<section class="section">
  <div class="shell space-y-8">
    <div class="flex flex-col gap-4 md:flex-row md:items-end md:justify-between">
      <div class="max-w-3xl">
        <span class="eyebrow">{home.speaking.eyebrow}</span>
        <h2 class="section-title">{home.speaking.title}</h2>
        <p class="section-copy">{home.speaking.description}</p>
      </div>
      <a href="/talks/" class="text-sm font-semibold text-[var(--color-accent)] transition hover:text-[var(--color-accent-strong)]">
        {home.speaking.browseLabel}
      </a>
    </div>

    <article class="panel flex flex-col gap-4 p-6 sm:p-7">
      <div class="flex flex-wrap items-center gap-3">
        <span class="pill">{speaking.featuredEngagement.label}</span>
        <span class="text-xs uppercase tracking-[0.18em] text-slate-500">{speaking.featuredEngagement.event}</span>
      </div>
      <h3 class="text-xl font-semibold tracking-tight text-white">{speaking.featuredEngagement.title}</h3>
      <p class="text-sm leading-7 text-slate-300">{speaking.featuredEngagement.summary}</p>
      <div class="flex flex-wrap gap-3 text-xs uppercase tracking-[0.18em] text-slate-500">
        <span>{speaking.featuredEngagement.schedule}</span>
        <span>{speaking.featuredEngagement.track}</span>
      </div>
      <div class="flex flex-wrap gap-3">
        <a
          href={speaking.featuredEngagement.url}
          target="_blank"
          rel="noreferrer"
          class="text-sm font-semibold text-[var(--color-accent)] transition hover:text-[var(--color-accent-strong)]"
        >
          Official session page →
        </a>
        <a
          href={profile.externalProfiles.cybersecSpeaker.url}
          target="_blank"
          rel="noreferrer"
          class="text-sm font-semibold text-[var(--color-accent)] transition hover:text-[var(--color-accent-strong)]"
        >
          CYBERSEC speaker profile →
        </a>
      </div>
    </article>

    <div class="grid gap-6 xl:grid-cols-3">
      {speaking.topics.map((topic) => (
        <article class="panel flex h-full flex-col gap-5 p-6 sm:p-7">
          <h3 class="text-2xl font-semibold tracking-tight text-white">{topic.title}</h3>
          <p class="text-sm leading-7 text-slate-300">{topic.description}</p>
          <p class="mt-auto text-xs uppercase tracking-[0.18em] text-slate-500">{topic.audience}</p>
        </article>
      ))}
    </div>
  </div>
</section>
