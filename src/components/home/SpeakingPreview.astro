---
import {
  defaultLocale,
  getLocalizedHome,
  getLocalizedProfile,
  getLocalizedSpeaking,
  getPageCopy,
  localizePath,
  type SiteLocale
} from "../../lib/i18n";

interface Props {
  locale?: SiteLocale;
}

const { locale = defaultLocale } = Astro.props;
const home = getLocalizedHome(locale);
const profile = getLocalizedProfile(locale);
const speaking = getLocalizedSpeaking(locale);
const copy = getPageCopy(locale);
---

<section class="section">
  <div class="shell space-y-8">
    <div class="grid gap-5 lg:grid-cols-[minmax(0,0.82fr)_auto] lg:items-end">
      <div class="section-intro">
        <span class="section-kicker">{home.speaking.eyebrow}</span>
        <h2 class="section-title">{home.speaking.title}</h2>
        <p class="section-copy">{home.speaking.description}</p>
      </div>
      <a href={localizePath("/talks/", locale)} class="button-secondary">
        {home.speaking.browseLabel}
      </a>
    </div>

    <div class="timeline-stack">
      <article class="timeline-item">
        <div class="flex flex-wrap items-center gap-3">
          <span class="pill">{speaking.featuredEngagement.label}</span>
          <span class="mono-label">{speaking.featuredEngagement.event}</span>
        </div>
        <h3 class="mt-4 text-2xl font-semibold tracking-tight text-white">{speaking.featuredEngagement.title}</h3>
        <p class="mt-3 max-w-3xl text-sm leading-7 text-slate-300">{speaking.featuredEngagement.summary}</p>
        <div class="mt-4 flex flex-wrap gap-3 text-sm text-slate-400">
          <span>{speaking.featuredEngagement.schedule}</span>
          <span>{speaking.featuredEngagement.track}</span>
        </div>
        <div class="mt-5 flex flex-wrap gap-3">
          <a
            href={speaking.featuredEngagement.url}
            target="_blank"
            rel="noreferrer"
            class="action-link"
          >
            {copy.common.officialSessionPageShort}
            <span aria-hidden="true">→</span>
          </a>
          <a
            href={profile.externalProfiles.cybersecSpeaker.url}
            target="_blank"
            rel="noreferrer"
            class="action-link"
          >
            {copy.common.speakerProfile}
            <span aria-hidden="true">→</span>
          </a>
        </div>
      </article>

      {speaking.additionalEngagements.map((engagement) => (
        <article class="timeline-item">
          <div class="flex flex-wrap items-center gap-3">
            <span class="pill">{engagement.label}</span>
            <span class="mono-label">{engagement.event}</span>
          </div>
          <h3 class="mt-4 text-xl font-semibold tracking-tight text-white">{engagement.title}</h3>
          <p class="mt-3 max-w-3xl text-sm leading-7 text-slate-300">{engagement.summary}</p>
          <div class="mt-4 flex flex-wrap gap-3 text-sm text-slate-400">
            <span>{engagement.schedule}</span>
            <span>{engagement.track}</span>
          </div>
          <div class="mt-5 flex flex-wrap gap-3">
            {(engagement.links ?? [{ label: engagement.ctaLabel, url: engagement.url }]).map((link) => (
              <a
                href={link.url}
                target="_blank"
                rel="noreferrer"
                class="action-link"
              >
                {link.label}
                <span aria-hidden="true">→</span>
              </a>
            ))}
          </div>
        </article>
      ))}
    </div>

    <div class="grid gap-6 xl:grid-cols-3">
      {speaking.topics.map((topic) => (
        <article class="surface-card flex h-full flex-col gap-5">
          <h3 class="text-2xl font-semibold tracking-tight text-white">{topic.title}</h3>
          <p class="text-sm leading-7 text-slate-300">{topic.description}</p>
          <p class="mono-label mt-auto">{topic.audience}</p>
        </article>
      ))}
    </div>
  </div>
</section>
