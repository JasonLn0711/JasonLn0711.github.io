---
import {
  defaultLocale,
  getLocalizedHome,
  getLocalizedProfile,
  getLocalizedSpeaking,
  getPageCopy,
  localizePath,
  type SiteLocale
} from "../../lib/i18n";
import SectionIntro from "../ui/SectionIntro.astro";

interface Props {
  locale?: SiteLocale;
}

const { locale = defaultLocale } = Astro.props;
const home = getLocalizedHome(locale);
const profile = getLocalizedProfile(locale);
const speaking = getLocalizedSpeaking(locale);
const copy = getPageCopy(locale);
---

<section class="section">
  <div class="shell space-y-8">
    <SectionIntro eyebrow={home.speaking.eyebrow} title={home.speaking.title} copy={home.speaking.description}>
      <Fragment slot="actions">
        <a href={localizePath("/talks/", locale)} class="button-secondary">
          {home.speaking.browseLabel}
        </a>
      </Fragment>
    </SectionIntro>

    <article class="section-card flex flex-col gap-5 p-6 sm:p-7">
      <div class="flex flex-wrap items-center gap-3">
        <span class="pill">{speaking.featuredEngagement.label}</span>
        <span class="muted-label">{speaking.featuredEngagement.event}</span>
      </div>
      <h3 class="font-[var(--font-display)] text-[2.2rem] leading-[0.98] tracking-[-0.03em]">{speaking.featuredEngagement.title}</h3>
      <p class="max-w-4xl text-sm leading-7">{speaking.featuredEngagement.summary}</p>
      <div class="meta-row">
        <span>{speaking.featuredEngagement.schedule}</span>
        <span>{speaking.featuredEngagement.track}</span>
      </div>
      <div class="flex flex-wrap gap-3">
        <a
          href={speaking.featuredEngagement.url}
          target="_blank"
          rel="noreferrer"
          class="action-link"
        >
          {copy.common.officialSessionPageShort}
          <span aria-hidden="true">→</span>
        </a>
        <a
          href={profile.externalProfiles.cybersecSpeaker.url}
          target="_blank"
          rel="noreferrer"
          class="action-link"
        >
          {copy.common.speakerProfile}
          <span aria-hidden="true">→</span>
        </a>
      </div>
    </article>

    {speaking.additionalEngagements.length > 0 && (
      <div class="grid gap-6 xl:grid-cols-2">
        {speaking.additionalEngagements.map((engagement) => (
          <article class="surface-card flex h-full flex-col gap-4 p-6 sm:p-7">
            <div class="flex flex-wrap items-center gap-3">
              <span class="pill">{engagement.label}</span>
              <span class="muted-label">{engagement.event}</span>
            </div>
            <h3 class="text-xl font-semibold tracking-tight">{engagement.title}</h3>
            <p class="text-sm leading-7">{engagement.summary}</p>
            <div class="meta-row">
              <span>{engagement.schedule}</span>
              <span>{engagement.track}</span>
            </div>
            <div class="mt-auto flex flex-wrap gap-3">
              {(engagement.links ?? [{ label: engagement.ctaLabel, url: engagement.url }]).map((link) => (
                <a
                  href={link.url}
                  target="_blank"
                  rel="noreferrer"
                  class="action-link"
                >
                  {link.label}
                  <span aria-hidden="true">→</span>
                </a>
              ))}
            </div>
          </article>
        ))}
      </div>
    )}

    <div class="grid gap-6 xl:grid-cols-3">
      {speaking.topics.map((topic) => (
        <article class="surface-card flex h-full flex-col gap-5 p-6 sm:p-7">
          <h3 class="font-[var(--font-display)] text-[1.9rem] leading-[1] tracking-[-0.03em]">{topic.title}</h3>
          <p class="text-sm leading-7">{topic.description}</p>
          <p class="mt-auto muted-label">{topic.audience}</p>
        </article>
      ))}
    </div>
  </div>
</section>
