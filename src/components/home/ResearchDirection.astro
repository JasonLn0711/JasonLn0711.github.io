---
import SectionHeader from "../common/SectionHeader.astro";
import { currentResearchThemes, selectedQuestions } from "../../data/research";
---

<section class="section">
  <div class="shell grid gap-8 xl:grid-cols-[1.05fr_0.95fr]">
    <div class="space-y-8">
      <SectionHeader
        eyebrow="Research Direction"
        title="Questions that shape my doctoral work."
        description="I care about the gap between benchmark capability and deployment reality: what it takes for a system to remain trustworthy once it meets risk, governance, and real operators."
      />

      <div class="grid gap-4 sm:grid-cols-2">
        {currentResearchThemes.map((theme) => (
          <article class="surface-note">
            <h3 class="text-xl font-semibold text-[var(--color-ink)]">{theme.title}</h3>
            <p class="mt-3 text-sm leading-7 text-[var(--color-muted)]">{theme.body}</p>
          </article>
        ))}
      </div>
    </div>

    <aside class="panel p-7 sm:p-8">
      <p class="text-[11px] uppercase tracking-[0.18em] text-[var(--color-soft)]">Selected Questions</p>
      <h3 class="mt-4 text-2xl font-semibold tracking-tight text-[var(--color-ink)]">
        The questions I keep returning to.
      </h3>
      <ol class="mt-6 space-y-4">
        {selectedQuestions.map((question, index) => (
          <li class="flex gap-4">
            <span class="pill h-fit">{index + 1}</span>
            <p class="text-sm leading-7 text-[var(--color-muted)]">{question}</p>
          </li>
        ))}
      </ol>
      <a href="/research/" class="mt-8 inline-flex items-center gap-2 text-sm font-semibold text-[var(--color-accent)] transition hover:text-[var(--color-accent-strong)]">
        Read the full research overview
        <span aria-hidden="true">→</span>
      </a>
    </aside>
  </div>
</section>
