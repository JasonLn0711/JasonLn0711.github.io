---
import type { CollectionEntry } from "astro:content";
import SectionHeader from "../common/SectionHeader.astro";
import ProjectCard from "../project/ProjectCard.astro";

interface Props {
  projects: CollectionEntry<"projects">[];
}

const { projects } = Astro.props;
---

<section class="section">
  <div class="shell space-y-8">
    <div class="flex flex-col gap-4 md:flex-row md:items-end md:justify-between">
      <SectionHeader
        eyebrow="Selected Work"
        title="A curated set of systems and case studies."
        description="Rather than a repository dump, this section highlights work that best reflects how I approach trustworthy AI, system design, and real-world technical constraints."
      />
      <a href="/projects/" class="text-sm font-semibold text-[var(--color-accent)] transition hover:text-[var(--color-accent-strong)]">
        Browse all projects →
      </a>
    </div>

    <div class="grid gap-6 lg:grid-cols-2">
      {projects.map((project) => <ProjectCard project={project} />)}
    </div>
  </div>
</section>
