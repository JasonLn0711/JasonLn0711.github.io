---
import type { CollectionEntry } from "astro:content";
import ProjectCard from "../project/ProjectCard.astro";

interface Props {
  projects: CollectionEntry<"projects">[];
}

const { projects } = Astro.props;
---

<section class="section">
  <div class="shell space-y-8">
    <div class="flex flex-col gap-4 md:flex-row md:items-end md:justify-between">
      <div>
        <span class="eyebrow">Featured Projects</span>
        <h2 class="section-title">Representative case studies from research and engineering work.</h2>
      </div>
      <a href="/projects/" class="text-sm font-semibold text-[var(--color-accent)] transition hover:text-[var(--color-accent-strong)]">
        Browse all projects →
      </a>
    </div>

    <div class="grid gap-6 xl:grid-cols-3">
      {projects.map((project) => <ProjectCard project={project} />)}
    </div>
  </div>
</section>
