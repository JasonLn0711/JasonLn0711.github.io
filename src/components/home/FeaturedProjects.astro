---
import type { CollectionEntry } from "astro:content";
import { formatDate, formatLabel } from "../../lib/content";
import { defaultLocale, getLocalizedHome, getPageCopy, localizePath, type SiteLocale } from "../../lib/i18n";

interface Props {
  projects: CollectionEntry<"projects">[];
  locale?: SiteLocale;
}

const { projects, locale = defaultLocale } = Astro.props;
const home = getLocalizedHome(locale);
const copy = getPageCopy(locale);
---

<section class="section" data-analytics-location="home_projects">
  <div class="shell space-y-8">
    <div class="grid gap-5 lg:grid-cols-[minmax(0,0.82fr)_auto] lg:items-end">
      <div class="section-intro">
        <span class="section-kicker">{home.projects.eyebrow}</span>
        <h2 class="section-title">{home.projects.title}</h2>
        <p class="section-copy">{home.projects.description}</p>
      </div>
      <a href={localizePath("/projects/", locale)} class="button-secondary">
        {home.projects.browseLabel}
      </a>
    </div>

    <div class="case-study-wall" data-analytics-location="home_featured_projects">
      {projects.map((project, index) => {
        const readiness = project.data.readiness;
        return (
          <a
            href={localizePath(`/projects/${project.slug}/`, locale)}
            class:list={["case-study-card group", index === 0 && "case-study-card--lead"]}
            data-analytics-label={project.data.title}
          >
            <img
              src={project.data.cover}
              alt={`${project.data.title} cover`}
              class:list={[index === 0 ? "aspect-[16/10]" : "aspect-[16/8]"]}
              loading="lazy"
            />
            <div class="flex h-full flex-col gap-5 p-5 sm:p-6">
              <div class="flex flex-wrap items-center gap-3">
                <span class="mono-label">{formatLabel(project.data.category, locale)}</span>
                <span class="status-token">{project.data.year}</span>
                <span class="status-token">{project.data.status}</span>
              </div>
              <div class="space-y-3">
                <h3 class:list={["font-semibold tracking-tight text-white transition group-hover:text-[var(--color-accent-strong)]", index === 0 ? "text-3xl" : "text-2xl"]}>
                  {project.data.title}
                </h3>
                <p class="max-w-[62ch] text-sm leading-7 text-slate-300">{project.data.summary}</p>
              </div>
              {readiness && (
                <div class="readiness-cardlet mt-auto">
                  <div class="flex flex-wrap items-center justify-between gap-2">
                    <p class="mono-label">{copy.common.readiness}</p>
                    <span>{readiness.level}</span>
                  </div>
                  <p>{readiness.summary}</p>
                  <p class="readiness-cardlet__date">{copy.common.lastReviewed}: {formatDate(readiness.updated, locale)}</p>
                </div>
              )}
              <div class="flex flex-wrap gap-2">
                {project.data.stack.slice(0, index === 0 ? 5 : 3).map((item) => <span class="pill">{item}</span>)}
              </div>
              <span class="action-link">
                {copy.common.openCaseStudy}
                <span aria-hidden="true">→</span>
              </span>
            </div>
          </a>
        );
      })}
    </div>

    <section class="readiness-guide" aria-labelledby="project-readiness-title">
      <div class="max-w-2xl">
        <span class="section-kicker">{home.projectReadiness.eyebrow}</span>
        <h3 id="project-readiness-title" class="text-2xl font-semibold tracking-tight text-white">{home.projectReadiness.title}</h3>
        <p class="mt-3 text-sm leading-7 text-slate-300">{home.projectReadiness.description}</p>
      </div>
      <div class="grid gap-3 md:grid-cols-2 xl:grid-cols-5">
        {home.projectReadiness.levels.map((level) => (
          <article class="readiness-guide__item">
            <h4>{level.level}</h4>
            <p>{level.description}</p>
          </article>
        ))}
      </div>
    </section>
  </div>
</section>
