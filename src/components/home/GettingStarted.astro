---
import { defaultLocale, getLocalizedHome, localizePath, type SiteLocale } from "../../lib/i18n";

interface Props {
  locale?: SiteLocale;
}

const { locale = defaultLocale } = Astro.props;
const home = getLocalizedHome(locale);
const cards = home.gettingStarted.cards.map((card, index) => ({
  ...card,
  number: String(index + 1).padStart(2, "0")
}));
---

<section class="section technical-band" data-analytics-location="home_getting_started">
  <div class="shell space-y-8">
    <div class="section-intro">
      <span class="section-kicker">{home.gettingStarted.eyebrow}</span>
      <h2 class="section-title">{home.gettingStarted.title}</h2>
      <p class="section-copy">{home.gettingStarted.description}</p>
    </div>

    <div class="route-board">
      {cards.map((card) => (
        <a href={localizePath(card.href, locale)} class="route-board__item group">
          <span class="route-board__number">{card.number}</span>
          <span class="block text-xl font-semibold tracking-tight text-white">{card.title}</span>
          <span class="block text-sm leading-7 text-slate-300">{card.description}</span>
          <span class="action-link">
            {card.cta}
            <span aria-hidden="true">→</span>
          </span>
        </a>
      ))}
    </div>
  </div>
</section>
