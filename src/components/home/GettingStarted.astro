---
import { defaultLocale, getLocalizedHome, localizePath, type SiteLocale } from "../../lib/i18n";

interface Props {
  locale?: SiteLocale;
}

const { locale = defaultLocale } = Astro.props;
const home = getLocalizedHome(locale);
const cards = home.gettingStarted.cards.map((card, index) => ({
  ...card,
  number: String(index + 1).padStart(2, "0")
}));
---

<section class="section technical-band" data-analytics-location="home_getting_started">
  <div class="shell space-y-8">
    <div class="section-intro">
      <span class="eyebrow">{home.gettingStarted.eyebrow}</span>
      <h2 class="section-title">{home.gettingStarted.title}</h2>
      <p class="section-copy">{home.gettingStarted.description}</p>
    </div>

    <div class="grid gap-4 md:grid-cols-2 xl:grid-cols-4">
      {cards.map((card) => (
        <a href={localizePath(card.href, locale)} class="technical-card group">
          <span class="technical-card__index">{card.number}</span>
          <span class="block text-lg font-semibold text-white">{card.title}</span>
          <span class="mt-3 block text-sm leading-7 text-slate-300">{card.description}</span>
          <span class="action-link mt-5">
            {card.cta}
            <span aria-hidden="true">→</span>
          </span>
        </a>
      ))}
    </div>
  </div>
</section>
