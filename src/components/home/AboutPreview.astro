---
import {
  defaultLocale,
  getLocalizedHome,
  getLocalizedProfile,
  getPageCopy,
  localizePath,
  type SiteLocale
} from "../../lib/i18n";

interface Props {
  locale?: SiteLocale;
}

const { locale = defaultLocale } = Astro.props;
const home = getLocalizedHome(locale);
const profile = getLocalizedProfile(locale);
const copy = getPageCopy(locale);
---

<section class="section">
  <div class="shell">
    <div class="panel grid gap-8 overflow-hidden p-6 sm:p-8 lg:grid-cols-[280px_minmax(0,1fr)] lg:p-10">
      <div class="overflow-hidden rounded-3xl border border-white/[0.08]">
        <img src={profile.avatar} alt={profile.name} class="aspect-[4/5] h-full w-full object-cover" />
      </div>

      <div class="flex flex-col justify-center gap-5">
        <span class="eyebrow">{home.about.eyebrow}</span>
        <h2 class="section-title">{home.about.title}</h2>
        <p class="max-w-3xl text-base leading-8 text-slate-300">{home.about.description}</p>
        <p class="max-w-3xl text-base leading-8 text-slate-300">{profile.shortBio}</p>
        <div class="grid gap-3 sm:grid-cols-3">
          {profile.quickFacts.map((fact) => (
            <div class="rounded-3xl border border-white/[0.08] bg-white/[0.03] p-4">
              <p class="text-xs uppercase tracking-[0.18em] text-slate-500">{fact.label}</p>
              <p class="mt-2 text-sm leading-7 text-slate-200">{fact.value}</p>
            </div>
          ))}
        </div>
        <div class="flex flex-wrap gap-3">
          <a href={localizePath("/about/", locale)} class="button-secondary">{copy.home.aboutJason}</a>
          <a href={localizePath("/blog/investigation-and-trustworthy-ai/", locale)} class="button-secondary">{copy.home.backgroundEssay}</a>
          <a href={profile.lab.url} target="_blank" rel="noreferrer" class="button-secondary">
            {copy.common.labWebsite}
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
