---
import {
  defaultLocale,
  getLocalizedHome,
  getLocalizedProfile,
  getPageCopy,
  localizePath,
  type SiteLocale
} from "../../lib/i18n";
import MediaFrame from "../ui/MediaFrame.astro";
import SectionIntro from "../ui/SectionIntro.astro";

interface Props {
  locale?: SiteLocale;
}

const { locale = defaultLocale } = Astro.props;
const home = getLocalizedHome(locale);
const profile = getLocalizedProfile(locale);
const copy = getPageCopy(locale);
---

<section class="section">
  <div class="shell">
    <div class="section-card grid gap-8 lg:grid-cols-[320px_minmax(0,1fr)]">
      <MediaFrame
        src={profile.avatar}
        alt={profile.name}
        width="1693"
        height="2540"
        imageClass="aspect-[4/5] h-full w-full object-cover object-[center_24%]"
      />

      <div class="flex flex-col justify-center gap-5">
        <SectionIntro eyebrow={home.about.eyebrow} title={home.about.title} copy={home.about.description} />
        <p class="max-w-3xl text-base leading-8">{profile.shortBio}</p>
        <div class="grid gap-3 sm:grid-cols-3">
          {profile.quickFacts.map((fact) => (
            <div class="surface-card">
              <p class="muted-label">{fact.label}</p>
              <p class="mt-2 text-sm leading-7 text-[var(--color-charcoal)]">{fact.value}</p>
            </div>
          ))}
        </div>
        <div class="flex flex-wrap gap-3">
          <a href={localizePath("/about/", locale)} class="button-secondary">{copy.home.aboutJason}</a>
          <a href={localizePath("/blog/investigation-and-trustworthy-ai/", locale)} class="button-secondary">{copy.home.backgroundEssay}</a>
          <a href={profile.lab.url} target="_blank" rel="noreferrer" class="button-secondary">
            {copy.common.labWebsite}
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
