---
import {
  defaultLocale,
  getLocalizedHome,
  getLocalizedProfile,
  getPageCopy,
  localizePath,
  type SiteLocale
} from "../../lib/i18n";
import HeroScene from "../three/HeroScene";

interface Props {
  locale?: SiteLocale;
}

const { locale = defaultLocale } = Astro.props;
const home = getLocalizedHome(locale);
const profile = getLocalizedProfile(locale);
const copy = getPageCopy(locale);
---

<section class="section pt-8 sm:pt-12">
  <div class="shell grid gap-8 xl:grid-cols-[minmax(0,1.05fr)_360px] xl:items-start">
    <div class="space-y-7">
      <span class="eyebrow">{home.hero.eyebrow}</span>
      <div class="space-y-5">
        <h1 class="max-w-4xl text-4xl font-semibold tracking-tight text-white sm:text-5xl lg:text-6xl">
          {home.hero.headline}
        </h1>
        <p class="max-w-2xl text-lg leading-8 text-slate-300">
          {home.hero.description}
        </p>
      </div>

      <div class="max-w-3xl rounded-[2rem] border border-white/[0.1] bg-gradient-to-br from-white/[0.08] via-white/[0.04] to-transparent p-4 shadow-panel sm:p-5">
        <div class="grid gap-4 sm:grid-cols-[112px_minmax(0,1fr)] sm:items-center">
          <div class="overflow-hidden rounded-[1.5rem] border border-white/[0.08] bg-slate-950/40">
            <img
              src={profile.avatar}
              alt={profile.name}
              class="aspect-[4/5] h-full w-full object-cover object-[center_32%]"
              loading="eager"
              fetchpriority="high"
            />
          </div>

          <div class="min-w-0 space-y-3">
            <div class="flex flex-wrap gap-2">
              {copy.home.heroPills.map((pill) => <span class="pill">{pill}</span>)}
            </div>

            <div class="space-y-1">
              <p class="text-xs uppercase tracking-[0.2em] text-slate-500">{copy.home.meetJason}</p>
              <h2 class="text-2xl font-semibold tracking-tight text-white">{profile.name}</h2>
              <p class="text-sm leading-7 text-slate-300">
                {copy.home.heroInstitutionSummary}
              </p>
            </div>

            <p class="text-sm leading-7 text-slate-300">
              {copy.home.heroSummary}
            </p>
          </div>
        </div>
      </div>

      <div class="flex flex-wrap gap-4">
        <a href={localizePath(home.hero.primaryCta.href, locale)} class="button-primary" data-plausible-event="hero_primary_cta_click">
          {home.hero.primaryCta.label}
        </a>
        <a href={localizePath(home.hero.secondaryCta.href, locale)} class="button-secondary" data-plausible-event="hero_secondary_cta_click">
          {home.hero.secondaryCta.label}
        </a>
        <a href={localizePath("/contact/", locale)} class="action-link">
          {copy.home.heroContact}
          <span aria-hidden="true">→</span>
        </a>
      </div>

      <dl class="grid max-w-4xl gap-4 rounded-4xl border border-white/10 bg-white/[0.03] p-6 sm:grid-cols-3">
        {home.hero.metrics.map((metric) => (
          <div>
            <dt class="text-xs uppercase tracking-[0.2em] text-slate-500">{metric.label}</dt>
            <dd class="mt-2 text-sm leading-7 text-slate-200">{metric.value}</dd>
          </div>
        ))}
      </dl>
    </div>

    <div class="space-y-4">
      <section class="panel p-6 sm:p-7">
        <div class="space-y-5">
          <div class="space-y-2">
            <p class="text-xs uppercase tracking-[0.2em] text-slate-500">{copy.home.startHere}</p>
            <h2 class="text-2xl font-semibold tracking-tight text-white">{copy.home.choosePath}</h2>
          </div>

          <div class="grid gap-3">
            {home.hero.routes.map((route) => (
              <a href={localizePath(route.href, locale)} class="rounded-3xl border border-white/[0.08] bg-white/[0.03] px-5 py-4 transition hover:border-white/20 hover:bg-white/[0.05]">
                <span class="block text-sm font-semibold text-white">{route.title}</span>
                <span class="mt-2 block text-sm leading-6 text-slate-400">{route.description}</span>
              </a>
            ))}
          </div>

          <div class="rounded-3xl border border-white/[0.08] bg-white/[0.03] p-5">
            <p class="text-xs uppercase tracking-[0.18em] text-slate-500">{copy.home.whatYouWillFind}</p>
            <ul class="mt-3 space-y-3">
              {home.hero.siteMap.map((item) => <li class="text-sm leading-7 text-slate-300">{item}</li>)}
            </ul>
          </div>
        </div>
      </section>

      <div class="panel hidden h-[280px] overflow-hidden md:block motion-reduce:hidden" aria-hidden="true">
        <HeroScene client:idle />
      </div>

      <div class="panel flex min-h-[220px] flex-col justify-between overflow-hidden p-8 md:hidden" aria-hidden="true">
        <div class="flex items-center justify-between">
          <span class="pill">{copy.home.signalMesh}</span>
          <span class="text-xs uppercase tracking-[0.18em] text-slate-500">{copy.home.staticFallback}</span>
        </div>
        <div class="relative mt-8 flex-1">
          <div class="absolute left-4 top-2 h-20 w-20 rounded-full bg-sky-400/20 blur-3xl"></div>
          <div class="absolute bottom-4 right-6 h-28 w-28 rounded-full bg-sky-300/10 blur-3xl"></div>
          <div class="grid h-full grid-cols-4 gap-3">
            {Array.from({ length: 12 }).map(() => <span class="rounded-full border border-white/[0.12] bg-white/[0.04]"></span>)}
          </div>
        </div>
      </div>

      <div class="panel hidden min-h-[220px] items-center justify-center p-8 text-center md:flex motion-safe:hidden" aria-hidden="true">
        <div class="space-y-4">
          <span class="eyebrow">{copy.home.reducedMotion}</span>
          <h2 class="text-2xl font-semibold text-white">{copy.home.visualPreviewDisabled}</h2>
          <p class="mx-auto max-w-md text-sm leading-7 text-slate-300">
            {copy.home.visualPreviewCopy}
          </p>
        </div>
      </div>
    </div>
  </div>
</section>
