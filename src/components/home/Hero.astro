---
import {
  defaultLocale,
  getLocalizedHome,
  getLocalizedProfile,
  getPageCopy,
  localizePath,
  type SiteLocale
} from "../../lib/i18n";
import MediaFrame from "../ui/MediaFrame.astro";
import PageHero from "../ui/PageHero.astro";

interface Props {
  locale?: SiteLocale;
}

const { locale = defaultLocale } = Astro.props;
const home = getLocalizedHome(locale);
const profile = getLocalizedProfile(locale);
const copy = getPageCopy(locale);
---

<section class="section pt-10 sm:pt-14">
  <div class="shell-wide">
    <PageHero
      eyebrow={home.hero.eyebrow}
      title={home.hero.headline}
      summary={home.hero.description}
      split={true}
      actions={[
        { href: localizePath(home.hero.primaryCta.href, locale), label: home.hero.primaryCta.label },
        { href: localizePath(home.hero.secondaryCta.href, locale), label: home.hero.secondaryCta.label, variant: "secondary" },
        { href: localizePath("/contact/", locale), label: copy.home.heroContact, variant: "link" }
      ]}
      stats={home.hero.metrics}
    >
      <div slot="media" class="space-y-5">
        <MediaFrame
          src={profile.avatar}
          alt={profile.name}
          width="1693"
          height="2540"
          loading="eager"
          fetchpriority="high"
          imageClass="aspect-[4/5] w-full object-cover object-[center_24%]"
          caption={copy.home.heroInstitutionSummary}
        />

        <div class="section-card space-y-4">
          <p class="muted-label">{copy.home.whatYouWillFind}</p>
          <ul class="compact-list">
            {home.hero.siteMap.map((item) => <li class="text-sm leading-7">{item}</li>)}
          </ul>
        </div>
      </div>
    </PageHero>

    <div class="mt-10 grid gap-4 lg:grid-cols-3" data-analytics-location="hero_routes">
      {home.hero.routes.map((route) => (
        <a href={localizePath(route.href, locale)} class="surface-link">
          <p class="muted-label">{copy.home.startHere}</p>
          <h2 class="mt-3 font-[var(--font-display)] text-[2rem] leading-none tracking-[-0.03em]">{route.title}</h2>
          <p class="mt-3 max-w-[40ch] text-sm leading-7">{route.description}</p>
        </a>
      ))}
    </div>
  </div>
</section>
