---
import { profile } from "../../data/profile";
import SystemsSurface from "../visual/SystemsSurface";
---

<section class="section pt-10 sm:pt-16">
  <div class="shell grid gap-12 lg:grid-cols-[0.95fr_1.05fr] lg:items-center">
    <div class="space-y-8">
      <span class="eyebrow">{profile.hero.eyebrow}</span>
      <div class="space-y-5">
        <h1 class="page-title max-w-4xl">{profile.hero.headline}</h1>
        <p class="page-copy">{profile.hero.subheadline}</p>
      </div>

      <div class="flex flex-wrap gap-4">
        <a href="/research/" class="button-primary">Explore Research</a>
        <a href="/projects/" class="button-secondary">View Projects</a>
        <a href="/contact/" class="button-secondary">Get in Touch</a>
      </div>

      <dl class="grid gap-4 sm:grid-cols-3">
        {profile.quickFacts.map((fact) => (
          <div class="surface-note">
            <dt class="text-[11px] uppercase tracking-[0.18em] text-[var(--color-soft)]">{fact.label}</dt>
            <dd class="mt-3 text-sm leading-6 text-[var(--color-ink)]">{fact.value}</dd>
          </div>
        ))}
      </dl>
    </div>

    <div class="space-y-4">
      <SystemsSurface />
      <div class="surface-note">
        <p class="text-[11px] uppercase tracking-[0.18em] text-[var(--color-soft)]">Working principle</p>
        <p class="mt-3 text-sm leading-7 text-[var(--color-muted)]">
          I build AI systems for settings where evidence traceability, security posture, and deployment fit matter as much as raw model capability.
        </p>
      </div>
    </div>
  </div>
</section>
