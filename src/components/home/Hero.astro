---
import { home } from "../../data/home";
import HeroScene from "../three/HeroScene";
---

<section class="section pt-8 sm:pt-12">
  <div class="shell grid gap-8 xl:grid-cols-[minmax(0,1.05fr)_360px] xl:items-start">
    <div class="space-y-7">
      <span class="eyebrow">{home.hero.eyebrow}</span>
      <div class="space-y-5">
        <h1 class="max-w-4xl text-4xl font-semibold tracking-tight text-white sm:text-5xl lg:text-6xl">
          {home.hero.headline}
        </h1>
        <p class="max-w-2xl text-lg leading-8 text-slate-300">
          {home.hero.description}
        </p>
      </div>

      <div class="flex flex-wrap gap-4">
        <a href={home.hero.primaryCta.href} class="button-primary" data-plausible-event="hero_primary_cta_click">
          {home.hero.primaryCta.label}
        </a>
        <a href={home.hero.secondaryCta.href} class="button-secondary" data-plausible-event="hero_secondary_cta_click">
          {home.hero.secondaryCta.label}
        </a>
        <a href="/contact/" class="action-link">
          Contact Jason
          <span aria-hidden="true">→</span>
        </a>
      </div>

      <dl class="grid max-w-4xl gap-4 rounded-4xl border border-white/10 bg-white/[0.03] p-6 sm:grid-cols-3">
        {home.hero.metrics.map((metric) => (
          <div>
            <dt class="text-xs uppercase tracking-[0.2em] text-slate-500">{metric.label}</dt>
            <dd class="mt-2 text-sm leading-7 text-slate-200">{metric.value}</dd>
          </div>
        ))}
      </dl>
    </div>

    <div class="space-y-4">
      <section class="panel p-6 sm:p-7">
        <div class="space-y-5">
          <div class="space-y-2">
            <p class="text-xs uppercase tracking-[0.2em] text-slate-500">Start here</p>
            <h2 class="text-2xl font-semibold tracking-tight text-white">Choose the path that matches your visit.</h2>
          </div>

          <div class="grid gap-3">
            {home.hero.routes.map((route) => (
              <a href={route.href} class="rounded-3xl border border-white/[0.08] bg-white/[0.03] px-5 py-4 transition hover:border-white/20 hover:bg-white/[0.05]">
                <span class="block text-sm font-semibold text-white">{route.title}</span>
                <span class="mt-2 block text-sm leading-6 text-slate-400">{route.description}</span>
              </a>
            ))}
          </div>

          <div class="rounded-3xl border border-white/[0.08] bg-white/[0.03] p-5">
            <p class="text-xs uppercase tracking-[0.18em] text-slate-500">What you'll find here</p>
            <ul class="mt-3 space-y-3">
              {home.hero.siteMap.map((item) => <li class="text-sm leading-7 text-slate-300">{item}</li>)}
            </ul>
          </div>
        </div>
      </section>

      <div class="panel hidden h-[280px] overflow-hidden md:block motion-reduce:hidden" aria-hidden="true">
        <HeroScene client:idle />
      </div>

      <div class="panel flex min-h-[220px] flex-col justify-between overflow-hidden p-8 md:hidden" aria-hidden="true">
        <div class="flex items-center justify-between">
          <span class="pill">Signal Mesh</span>
          <span class="text-xs uppercase tracking-[0.18em] text-slate-500">Static fallback</span>
        </div>
        <div class="relative mt-8 flex-1">
          <div class="absolute left-4 top-2 h-20 w-20 rounded-full bg-sky-400/20 blur-3xl"></div>
          <div class="absolute bottom-4 right-6 h-28 w-28 rounded-full bg-sky-300/10 blur-3xl"></div>
          <div class="grid h-full grid-cols-4 gap-3">
            {Array.from({ length: 12 }).map(() => <span class="rounded-full border border-white/[0.12] bg-white/[0.04]"></span>)}
          </div>
        </div>
      </div>

      <div class="panel hidden min-h-[220px] items-center justify-center p-8 text-center md:flex motion-safe:hidden" aria-hidden="true">
        <div class="space-y-4">
          <span class="eyebrow">Reduced Motion</span>
          <h2 class="text-2xl font-semibold text-white">Visual preview disabled</h2>
          <p class="mx-auto max-w-md text-sm leading-7 text-slate-300">
            The interactive network visualization is disabled to respect reduced-motion preferences.
          </p>
        </div>
      </div>
    </div>
  </div>
</section>
