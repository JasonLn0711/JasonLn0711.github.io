---
import {
  defaultLocale,
  getLocalizedHome,
  getLocalizedProfile,
  localizePath,
  type SiteLocale
} from "../../lib/i18n";

interface Props {
  locale?: SiteLocale;
}

const { locale = defaultLocale } = Astro.props;
const home = getLocalizedHome(locale);
const profile = getLocalizedProfile(locale);
const trace = home.hero.trace.map((item, index) => ({
  ...item,
  number: String(index + 1).padStart(2, "0")
}));
---

<section class="home-hero" style={`--hero-image: url("${profile.avatar}")`} data-analytics-location="home_hero">
  <div class="home-hero__pattern" aria-hidden="true"></div>
  <div class="home-hero__image" aria-hidden="true"></div>

  <div class="shell relative z-10 grid gap-8 py-14 lg:grid-cols-[minmax(0,1fr)_minmax(20rem,0.46fr)] lg:items-end lg:py-20">
    <div class="max-w-4xl space-y-7">
      <div class="space-y-4">
        <span class="eyebrow">{home.hero.eyebrow}</span>
        <p class="max-w-2xl text-sm font-semibold text-emerald-100/90">{profile.title}</p>
      </div>

      <div class="space-y-5">
        <h1 class="max-w-4xl text-5xl font-semibold text-white sm:text-6xl lg:text-7xl">
          {profile.name}
        </h1>
        <p class="max-w-3xl text-2xl font-semibold leading-9 text-emerald-50 sm:text-3xl">
          {home.hero.headline}
        </p>
        <p class="max-w-3xl text-base leading-8 text-slate-200 sm:text-lg">
          {home.hero.description}
        </p>
      </div>

      <div class="flex flex-col gap-3 sm:flex-row sm:flex-wrap" data-analytics-location="hero_actions">
        <a href={localizePath(home.hero.primaryCta.href, locale)} class="button-primary">
          {home.hero.primaryCta.label}
        </a>
        <a href={localizePath(home.hero.secondaryCta.href, locale)} class="button-secondary">
          {home.hero.secondaryCta.label}
        </a>
        <a href={localizePath(home.hero.tertiaryCta.href, locale)} class="button-secondary">
          {home.hero.tertiaryCta.label}
        </a>
      </div>

      <ul class="grid max-w-4xl gap-3 md:grid-cols-3">
        {home.hero.capabilities.map((capability) => (
          <li class="hero-capability">
            <span class="hero-capability__mark" aria-hidden="true"></span>
            <span>{capability}</span>
          </li>
        ))}
      </ul>
    </div>

    <aside class="hero-console" aria-label="Homepage system trace">
      <div class="hero-console__header">
        <span>{profile.handle}</span>
        <span>{profile.institutionShort}</span>
      </div>
      <ol class="hero-console__trace">
        {trace.map((item) => (
          <li>
            <span>{item.number}</span>
            <div>
              <strong>{item.label}</strong>
              <p>{item.value}</p>
            </div>
          </li>
        ))}
      </ol>
    </aside>
  </div>
</section>
