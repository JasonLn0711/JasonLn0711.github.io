---
import { defaultLocale, getLocalizedHome, localizePath, type SiteLocale } from "../../lib/i18n";

interface Props {
  locale?: SiteLocale;
}

const { locale = defaultLocale } = Astro.props;
const home = getLocalizedHome(locale);
const architecture = home.architecture;
---

<section class="section" data-analytics-location="home_capability_map">
  <div class="shell space-y-8">
    <div class="grid gap-8 lg:grid-cols-[minmax(0,0.8fr)_minmax(0,1fr)] lg:items-end">
      <div class="section-intro">
        <span class="eyebrow">{architecture.eyebrow}</span>
        <h2 class="section-title">{architecture.title}</h2>
        <p class="section-copy">{architecture.description}</p>
      </div>

      <div class="technical-diagram" aria-label={architecture.diagramTitle}>
        <div class="technical-diagram__intro">
          <h3>{architecture.diagramTitle}</h3>
          <p>{architecture.diagramDescription}</p>
        </div>
        <ol class="technical-diagram__flow">
          {architecture.layers.map((layer, index) => (
            <li>
              <span>{String(index + 1).padStart(2, "0")}</span>
              <div>
                <strong>{layer.label}</strong>
                <p>{layer.value}</p>
              </div>
            </li>
          ))}
        </ol>
      </div>
    </div>

    <div class="grid gap-4 lg:grid-cols-3">
      {architecture.capabilities.map((capability) => (
        <a href={localizePath(capability.href, locale)} class="technical-card group">
          <h3 class="text-xl font-semibold tracking-tight text-white">{capability.title}</h3>
          <p class="mt-3 text-sm leading-7 text-slate-300">{capability.description}</p>
          <div class="mt-5 flex flex-wrap gap-2">
            {capability.tags.map((tag) => <span class="pill">{tag}</span>)}
          </div>
        </a>
      ))}
    </div>
  </div>
</section>
