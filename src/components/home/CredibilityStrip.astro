---
import {
  defaultLocale,
  getLocalizedProfile,
  getLocalizedSpeaking,
  getPageCopy,
  localizePath,
  type SiteLocale
} from "../../lib/i18n";

interface Props {
  locale?: SiteLocale;
}

const { locale = defaultLocale } = Astro.props;
const profile = getLocalizedProfile(locale);
const speaking = getLocalizedSpeaking(locale);
const copy = getPageCopy(locale);
---

<section class="pb-4">
  <div class="shell">
    <div class="proof-strip">
      <div class="proof-strip__item">
        <p class="proof-label">{copy.home.researchBase}</p>
        <p class="text-sm leading-7 text-slate-200">{profile.trustSignals[0]}</p>
      </div>
      <div class="proof-strip__item">
        <p class="proof-label">{copy.home.speakingSignal}</p>
        <p class="text-sm leading-7 text-slate-200">{profile.trustSignals[1]}</p>
      </div>
      <div class="proof-strip__item">
        <p class="proof-label">{copy.home.publicationActivity}</p>
        <p class="text-sm leading-7 text-slate-200">{profile.trustSignals[2]}</p>
      </div>
      <a href={localizePath(speaking.featuredEngagement.storyHref, locale)} class="proof-strip__cta flex items-center justify-between gap-3 p-5">
        <span class="text-sm font-semibold text-white">{copy.home.readWebKeynote}</span>
        <span class="text-[var(--color-accent)]" aria-hidden="true">→</span>
      </a>
    </div>
  </div>
</section>
