---
import { profile } from "../../data/profile";
import { speaking } from "../../data/speaking";
---

<section class="pb-4">
  <div class="shell">
    <div class="panel grid gap-4 p-5 sm:p-6 lg:grid-cols-[repeat(3,minmax(0,1fr))_auto] lg:items-center">
      <div class="space-y-1">
        <p class="text-xs uppercase tracking-[0.18em] text-slate-500">Research base</p>
        <p class="text-sm leading-7 text-slate-200">{profile.trustSignals[0]}</p>
      </div>
      <div class="space-y-1">
        <p class="text-xs uppercase tracking-[0.18em] text-slate-500">Speaking signal</p>
        <p class="text-sm leading-7 text-slate-200">{profile.trustSignals[1]}</p>
      </div>
      <div class="space-y-1">
        <p class="text-xs uppercase tracking-[0.18em] text-slate-500">Publication activity</p>
        <p class="text-sm leading-7 text-slate-200">{profile.trustSignals[2]}</p>
      </div>
      <a href={speaking.featuredEngagement.storyHref} class="action-link whitespace-nowrap">
        Read the web keynote
        <span aria-hidden="true">→</span>
      </a>
    </div>
  </div>
</section>
