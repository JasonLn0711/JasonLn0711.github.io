---
import type { CollectionEntry } from "astro:content";

interface Props {
  project: CollectionEntry<"projects">;
  filters?: string[];
}

const { project, filters = [project.data.category] } = Astro.props;
const tags = Array.from(new Set(filters));
---

<article
  data-project-card
  data-category={tags.join(",")}
  class="panel group flex h-full flex-col overflow-hidden"
>
  <img
    src={project.data.cover}
    alt={`${project.data.title} cover`}
    class="aspect-[16/9] w-full object-cover"
    loading="lazy"
  />
  <div class="flex flex-1 flex-col gap-5 p-6 sm:p-7">
    <div class="flex flex-wrap items-center gap-3 text-xs uppercase tracking-[0.2em] text-slate-400">
      <span>{project.data.category}</span>
      <span class="h-1 w-1 rounded-full bg-white/20"></span>
      <span>{project.data.year}</span>
    </div>
    <div class="space-y-3">
      <h3 class="text-2xl font-semibold tracking-tight text-white">
        <a href={`/projects/${project.slug}/`} class="transition group-hover:text-[var(--color-accent-strong)]">
          {project.data.title}
        </a>
      </h3>
      <p class="text-sm leading-7 text-slate-300">{project.data.summary}</p>
    </div>
    <div class="flex flex-wrap gap-2">
      {project.data.stack.slice(0, 5).map((item) => <span class="pill">{item}</span>)}
    </div>
    <div class="mt-auto flex items-center justify-between gap-3">
      <p class="text-xs uppercase tracking-[0.18em] text-slate-500">{project.data.role}</p>
      <a href={`/projects/${project.slug}/`} class="text-sm font-semibold text-[var(--color-accent)] transition hover:text-[var(--color-accent-strong)]">
        View case study →
      </a>
    </div>
  </div>
</article>
