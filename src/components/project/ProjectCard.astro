---
import type { CollectionEntry } from "astro:content";
import { formatLabel } from "../../lib/content";
import { defaultLocale, getPageCopy, localizePath, type SiteLocale } from "../../lib/i18n";

interface Props {
  project: CollectionEntry<"projects">;
  filters?: string[];
  eventName?: string;
  analyticsLocation?: string;
  locale?: SiteLocale;
}

const { project, filters = [project.data.category], eventName, analyticsLocation, locale = defaultLocale } = Astro.props;
const tags = Array.from(new Set(filters));
const copy = getPageCopy(locale);
---

<article
  data-project-card
  data-category={tags.join(",")}
  data-analytics-location={analyticsLocation}
  class="panel overflow-hidden transition hover:border-white/20 hover:bg-white/[0.05]"
>
  <a
    href={localizePath(`/projects/${project.slug}/`, locale)}
    class="group flex h-full flex-col focus-visible:outline-none"
    data-plausible-event={eventName}
    data-plausible-project={project.data.title}
    data-plausible-slug={project.slug}
    data-analytics-label={project.data.title}
  >
    <img
      src={project.data.cover}
      alt={`${project.data.title} cover`}
      class="aspect-[16/9] w-full object-cover"
      loading="lazy"
    />
    <div class="flex flex-1 flex-col gap-5 p-6 sm:p-7">
      <div class="meta-row text-xs uppercase tracking-[0.2em]">
        <span>{formatLabel(project.data.category, locale)}</span>
        <span class="h-1 w-1 rounded-full bg-white/20"></span>
        <span>{project.data.year}</span>
        <span class="h-1 w-1 rounded-full bg-white/20"></span>
        <span>{project.data.status}</span>
      </div>
      <div class="space-y-3">
        <h3 class="text-2xl font-semibold tracking-tight text-white transition group-hover:text-[var(--color-accent-strong)]">
          {project.data.title}
        </h3>
        <p class="max-w-[54ch] text-sm leading-7 text-slate-300">{project.data.summary}</p>
      </div>
      <div class="flex flex-wrap gap-2">
        {project.data.stack.slice(0, 5).map((item) => <span class="pill">{item}</span>)}
      </div>
      <div class="mt-auto flex items-center justify-between gap-3">
        <p class="text-xs uppercase tracking-[0.18em] text-slate-500">{project.data.role}</p>
        <span class="action-link">
          {copy.common.openCaseStudy}
          <span aria-hidden="true">→</span>
        </span>
      </div>
    </div>
  </a>
</article>
