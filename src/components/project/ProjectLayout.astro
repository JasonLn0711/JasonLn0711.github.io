---
import type { CollectionEntry } from "astro:content";
import UntranslatedNotice from "../layout/UntranslatedNotice.astro";
import CTASection from "../ui/CTASection.astro";
import MediaFrame from "../ui/MediaFrame.astro";
import MetaRail from "../ui/MetaRail.astro";
import PageHero from "../ui/PageHero.astro";
import QuoteBlock from "../ui/QuoteBlock.astro";
import { formatLabel } from "../../lib/content";
import { defaultLocale, getPageCopy, localizePath, type SiteLocale } from "../../lib/i18n";

interface Props {
  project: CollectionEntry<"projects">;
  previousProject?: CollectionEntry<"projects">;
  nextProject?: CollectionEntry<"projects">;
  locale?: SiteLocale;
}

const { project, previousProject, nextProject, locale = defaultLocale } = Astro.props;
const copy = getPageCopy(locale);

const links = [
  project.data.repo ? { label: "Repository", href: project.data.repo, kind: "repository" } : undefined,
  project.data.demo ? { label: "Demo", href: project.data.demo, kind: "demo" } : undefined,
  project.data.paper ? { label: "Paper", href: project.data.paper, kind: "paper" } : undefined
].filter((link): link is { label: string; href: string; kind: string } => Boolean(link));

const metaItems = [
  { label: "Category", value: formatLabel(project.data.category, locale) },
  { label: "Year", value: String(project.data.year) },
  { label: "Status", value: project.data.status },
  { label: "Role", value: project.data.role },
  ...(project.data.location ? [{ label: "Location", value: project.data.location }] : []),
  ...(project.data.scope ? [{ label: "Scope", value: project.data.scope }] : []),
  { label: "Stack", value: project.data.stack }
];
---

<section class="page-frame">
  <div class="page-stack">
    <a href={localizePath("/projects/", locale)} class="quiet-link">
      <span aria-hidden="true">←</span>
      {copy.common.backToProjects}
    </a>

    <PageHero
      eyebrow={`${formatLabel(project.data.category, locale)} case study`}
      kicker={`${project.data.year} · ${project.data.status}`}
      title={project.data.title}
      titleClass="display-title-sm"
      summary={project.data.subtitle ?? project.data.summary}
      split={true}
      actions={[
        ...links.map((link) => ({
          href: link.href,
          label: link.label,
          variant: "secondary" as const,
          external: true
        }))
      ]}
    >
      <MediaFrame
        slot="media"
        src={project.data.cover}
        alt={`${project.data.title} hero visual`}
        imageClass="aspect-[16/11] w-full object-cover"
        caption={project.data.summary}
      />
    </PageHero>

    <div class="detail-shell">
      <aside class="detail-aside lg:sticky lg:top-28 lg:h-fit">
        <div class="toc-card">
          <p class="muted-label">{copy.common.projectSnapshot}</p>
          <MetaRail items={metaItems} className="mt-4" />
        </div>

        <div class="surface-card space-y-3" data-analytics-location="project_detail_next_steps">
          <p class="muted-label">{copy.common.bestNextSteps}</p>
          <p class="text-sm leading-7">
            If this work overlaps with your research, product direction, or event, the most useful next step is usually a comparison with the broader agenda or a direct conversation.
          </p>
          <div class="page-actions">
            <a href={localizePath("/research/", locale)} class="button-secondary">{copy.common.seeResearch}</a>
            <a href={localizePath("/contact/", locale)} class="button-primary">{copy.common.discussThisWork}</a>
          </div>
        </div>
      </aside>

      <article class="space-y-6 min-w-0">
        {locale !== "en" && <UntranslatedNotice locale={locale} kind="project" />}
        {project.data.quote && <QuoteBlock quote={project.data.quote} />}
        <div class="reading-panel">
          <div class="article-body">
            <slot />
          </div>
        </div>

        <CTASection
          title={copy.common.continueFromThisPiece}
          copy="Case studies are most useful in relation to the broader agenda. Compare the work with the research direction, adjacent writing, or reach out if the fit looks promising."
          actions={[
            { href: localizePath("/research/", locale), label: copy.common.research, variant: "secondary" },
            { href: localizePath("/blog/", locale), label: copy.common.writing, variant: "secondary" },
            { href: localizePath("/contact/", locale), label: copy.common.contact }
          ]}
        />
      </article>
    </div>

    {(previousProject || nextProject) && (
      <div class="grid gap-4 sm:grid-cols-2" data-analytics-location="project_detail_pagination">
        {previousProject ? (
          <a href={localizePath(`/projects/${previousProject.slug}/`, locale)} class="surface-link block p-6">
            <p class="muted-label">{copy.common.previousProject}</p>
            <p class="mt-3 text-lg font-semibold">{previousProject.data.title}</p>
          </a>
        ) : (
          <a href={localizePath("/projects/", locale)} class="surface-link block p-6">
            <p class="muted-label">{copy.common.browse}</p>
            <p class="mt-3 text-lg font-semibold">{copy.common.allProjects}</p>
          </a>
        )}

        {nextProject && (
          <a href={localizePath(`/projects/${nextProject.slug}/`, locale)} class="surface-link block p-6 text-left sm:text-right">
            <p class="muted-label">{copy.common.nextProject}</p>
            <p class="mt-3 text-lg font-semibold">{nextProject.data.title}</p>
          </a>
        )}

        {!nextProject && (
          <a href={localizePath("/contact/", locale)} class="surface-link block p-6 text-left sm:text-right">
            <p class="muted-label">{copy.common.needContext}</p>
            <p class="mt-3 text-lg font-semibold">{copy.common.contactJason}</p>
          </a>
        )}
      </div>
    )}
  </div>
</section>
