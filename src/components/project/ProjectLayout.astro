---
import type { CollectionEntry } from "astro:content";

interface Props {
  project: CollectionEntry<"projects">;
  previousProject?: CollectionEntry<"projects">;
  nextProject?: CollectionEntry<"projects">;
}

const { project, previousProject, nextProject } = Astro.props;

const links = [
  project.data.repo ? { label: "Repository", href: project.data.repo, eventName: "project_repo_click" } : undefined,
  project.data.demo ? { label: "Demo", href: project.data.demo, eventName: "project_demo_click" } : undefined,
  project.data.paper ? { label: "Paper", href: project.data.paper, eventName: "project_paper_click" } : undefined
].filter((link): link is { label: string; href: string; eventName: string } => Boolean(link));
---

<section class="section pt-12 sm:pt-16">
  <div class="shell space-y-10">
    <a href="/projects/" class="action-link">
      <span aria-hidden="true">←</span>
      Back to all projects
    </a>

    <div class="grid gap-8 lg:grid-cols-[1.05fr_0.95fr] lg:items-end">
      <div class="space-y-5">
        <span class="eyebrow">{project.data.category} Case Study</span>
        <h1 class="max-w-3xl text-4xl font-semibold tracking-tight text-white sm:text-5xl">
          {project.data.title}
        </h1>
        <p class="max-w-2xl text-lg leading-8 text-slate-300">{project.data.summary}</p>
        <div class="flex flex-wrap gap-2">
          <span class="pill">{project.data.status}</span>
          <span class="pill">{project.data.year}</span>
          <span class="pill">{project.data.role}</span>
        </div>
        {links.length > 0 && (
          <div class="flex flex-wrap gap-3">
            {links.map((link) => (
              <a
                href={link.href}
                target="_blank"
                rel="noreferrer"
                class="button-secondary px-4 py-2"
                data-plausible-event={link.eventName}
                data-plausible-project={project.data.title}
                data-plausible-slug={project.slug}
              >
                {link.label}
              </a>
            ))}
          </div>
        )}
      </div>
      <div class="panel overflow-hidden">
        <img src={project.data.cover} alt={`${project.data.title} hero visual`} class="aspect-[16/10] w-full object-cover" />
      </div>
    </div>

    <div class="grid gap-8 lg:grid-cols-[320px_minmax(0,1fr)]">
      <aside class="panel h-fit space-y-6 p-6">
        <div class="space-y-3">
          <h2 class="text-sm font-semibold uppercase tracking-[0.2em] text-slate-200">Project Snapshot</h2>
          <dl class="space-y-3 text-sm text-slate-300">
            <div class="space-y-1">
              <dt class="text-xs uppercase tracking-[0.18em] text-slate-500">Role</dt>
              <dd>{project.data.role}</dd>
            </div>
            <div class="space-y-1">
              <dt class="text-xs uppercase tracking-[0.18em] text-slate-500">Year</dt>
              <dd>{project.data.year}</dd>
            </div>
            <div class="space-y-1">
              <dt class="text-xs uppercase tracking-[0.18em] text-slate-500">Status</dt>
              <dd>{project.data.status}</dd>
            </div>
            <div class="space-y-1">
              <dt class="text-xs uppercase tracking-[0.18em] text-slate-500">Stack</dt>
              <dd class="flex flex-wrap gap-2">
                {project.data.stack.map((item) => <span class="pill">{item}</span>)}
              </dd>
            </div>
          </dl>
        </div>

        <div class="space-y-3 rounded-3xl border border-white/[0.08] bg-white/[0.03] p-5">
          <h2 class="text-sm font-semibold uppercase tracking-[0.2em] text-slate-200">Best next steps</h2>
          <p class="text-sm leading-7 text-slate-300">
            If this work is relevant to your research, team, or event, the next useful move is usually to compare it with the broader agenda or reach out directly.
          </p>
          <div class="flex flex-wrap gap-3">
            <a href="/research/" class="button-secondary px-4 py-2">See research</a>
            <a href="/contact/" class="button-primary px-4 py-2">Discuss this work</a>
          </div>
        </div>
      </aside>

      <article class="panel p-6 sm:p-8 lg:p-10">
        <div class="article-body">
          <slot />
        </div>
      </article>
    </div>

    {(previousProject || nextProject) && (
      <div class="grid gap-4 sm:grid-cols-2">
        {previousProject ? (
          <a href={`/projects/${previousProject.slug}/`} class="panel block p-6 transition hover:border-white/20">
            <p class="text-xs uppercase tracking-[0.2em] text-slate-500">Previous project</p>
            <p class="mt-3 text-lg font-semibold text-white">{previousProject.data.title}</p>
          </a>
        ) : (
          <a href="/projects/" class="panel block p-6 transition hover:border-white/20">
            <p class="text-xs uppercase tracking-[0.2em] text-slate-500">Browse</p>
            <p class="mt-3 text-lg font-semibold text-white">All projects</p>
          </a>
        )}

        {nextProject && (
          <a href={`/projects/${nextProject.slug}/`} class="panel block p-6 text-left transition hover:border-white/20 sm:text-right">
            <p class="text-xs uppercase tracking-[0.2em] text-slate-500">Next project</p>
            <p class="mt-3 text-lg font-semibold text-white">{nextProject.data.title}</p>
          </a>
        )}

        {!nextProject && (
          <a href="/contact/" class="panel block p-6 text-left transition hover:border-white/20 sm:text-right">
            <p class="text-xs uppercase tracking-[0.2em] text-slate-500">Need context?</p>
            <p class="mt-3 text-lg font-semibold text-white">Contact Jason</p>
          </a>
        )}
      </div>
    )}
  </div>
</section>
