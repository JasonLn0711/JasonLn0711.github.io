---
import type { CollectionEntry } from "astro:content";
import { projectKindLabel, projectModeLabel } from "../../lib/content";

interface Props {
  project: CollectionEntry<"projects">;
  previousProject?: CollectionEntry<"projects">;
  nextProject?: CollectionEntry<"projects">;
}

const { project, previousProject, nextProject } = Astro.props;

const links = [
  project.data.repo ? { label: "Repository", href: project.data.repo } : undefined,
  project.data.demo ? { label: "Demo", href: project.data.demo } : undefined,
  project.data.paper ? { label: "Paper", href: project.data.paper } : undefined
].filter((link): link is { label: string; href: string } => Boolean(link));

const meta = [
  { label: "Category", value: project.data.category },
  { label: "Kind", value: projectKindLabel(project.data.kind) },
  { label: "Mode", value: projectModeLabel(project.data.mode) },
  { label: "Year", value: String(project.data.year) },
  { label: "Status", value: project.data.status }
];
---

<section class="section pt-12 sm:pt-16">
  <div class="shell space-y-10">
    <div class="grid gap-8 lg:grid-cols-[minmax(0,1fr)_320px]">
      <div class="space-y-6">
        <span class="eyebrow">{projectKindLabel(project.data.kind)} · {project.data.category}</span>
        <h1 class="page-title !text-4xl sm:!text-5xl">{project.data.title}</h1>
        <p class="page-copy">{project.data.summary}</p>

        <div class="grid gap-4 sm:grid-cols-2">
          <div class="surface-note">
            <p class="text-[11px] uppercase tracking-[0.18em] text-[var(--color-soft)]">Problem</p>
            <p class="mt-3 text-sm leading-7 text-[var(--color-muted)]">{project.data.problem}</p>
          </div>
          <div class="surface-note">
            <p class="text-[11px] uppercase tracking-[0.18em] text-[var(--color-soft)]">Why it matters</p>
            <p class="mt-3 text-sm leading-7 text-[var(--color-muted)]">{project.data.importance}</p>
          </div>
        </div>

        {links.length > 0 && (
          <div class="flex flex-wrap gap-3">
            {links.map((link) => (
              <a href={link.href} target="_blank" rel="noreferrer" class="button-secondary px-4 py-2">
                {link.label}
              </a>
            ))}
          </div>
        )}
      </div>

      <aside class="panel h-fit space-y-6 p-6">
        <div class="space-y-3">
          <h2 class="text-sm font-semibold uppercase tracking-[0.2em] text-[var(--color-ink)]">Project frame</h2>
          <dl class="space-y-3 text-sm text-[var(--color-muted)]">
            {meta.map((item) => (
              <div class="space-y-1">
                <dt class="text-xs uppercase tracking-[0.18em] text-[var(--color-soft)]">{item.label}</dt>
                <dd>{item.value}</dd>
              </div>
            ))}
            <div class="space-y-1">
              <dt class="text-xs uppercase tracking-[0.18em] text-[var(--color-soft)]">Role</dt>
              <dd>{project.data.role}</dd>
            </div>
            <div class="space-y-1">
              <dt class="text-xs uppercase tracking-[0.18em] text-[var(--color-soft)]">Stack</dt>
              <dd class="flex flex-wrap gap-2">
                {project.data.stack.map((item) => <span class="pill">{item}</span>)}
              </dd>
            </div>
          </dl>
        </div>

        <div class="surface-note">
          <p class="text-[11px] uppercase tracking-[0.18em] text-[var(--color-soft)]">Note</p>
          <p class="mt-3 text-sm leading-7 text-[var(--color-muted)]">
            Some entries here are public repositories, while others are structured research case studies representing ongoing work and system direction.
          </p>
        </div>
      </aside>
    </div>

    <div class="grid gap-8 lg:grid-cols-[320px_minmax(0,1fr)]">
      <aside></aside>
      <article class="panel p-6 sm:p-8 lg:p-10">
        <div class="article-body">
          <slot />
        </div>
      </article>
    </div>

    {(previousProject || nextProject) && (
      <div class="grid gap-4 sm:grid-cols-2">
        {previousProject ? (
          <a href={`/projects/${previousProject.slug}/`} class="panel block p-6 transition hover:border-[var(--color-ink)]/15">
            <p class="text-xs uppercase tracking-[0.2em] text-[var(--color-soft)]">Previous project</p>
            <p class="mt-3 text-lg font-semibold text-[var(--color-ink)]">{previousProject.data.title}</p>
          </a>
        ) : (
          <div></div>
        )}

        {nextProject && (
          <a href={`/projects/${nextProject.slug}/`} class="panel block p-6 text-left transition hover:border-[var(--color-ink)]/15 sm:text-right">
            <p class="text-xs uppercase tracking-[0.2em] text-[var(--color-soft)]">Next project</p>
            <p class="mt-3 text-lg font-semibold text-[var(--color-ink)]">{nextProject.data.title}</p>
          </a>
        )}
      </div>
    )}
  </div>
</section>
