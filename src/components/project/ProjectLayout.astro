---
import type { CollectionEntry } from "astro:content";
import UntranslatedNotice from "../layout/UntranslatedNotice.astro";
import { defaultLocale, getPageCopy, localizePath, type SiteLocale } from "../../lib/i18n";

interface Props {
  project: CollectionEntry<"projects">;
  previousProject?: CollectionEntry<"projects">;
  nextProject?: CollectionEntry<"projects">;
  locale?: SiteLocale;
}

const { project, previousProject, nextProject, locale = defaultLocale } = Astro.props;
const copy = getPageCopy(locale);

const links = [
  project.data.repo ? { label: "Repository", href: project.data.repo, kind: "repository" } : undefined,
  project.data.demo ? { label: "Demo", href: project.data.demo, kind: "demo" } : undefined,
  project.data.paper ? { label: "Paper", href: project.data.paper, kind: "paper" } : undefined
].filter((link): link is { label: string; href: string; kind: string } => Boolean(link));
---

<section class="page-frame">
  <div class="page-stack">
    <a href={localizePath("/projects/", locale)} class="action-link">
      <span aria-hidden="true">←</span>
      {copy.common.backToProjects}
    </a>

    <div class="grid gap-8 lg:grid-cols-[1.05fr_0.95fr] lg:items-end">
      <div class="page-intro">
        <span class="eyebrow">{project.data.category} Case Study</span>
        <h1 class="max-w-3xl text-4xl font-semibold tracking-tight text-white sm:text-5xl">
          {project.data.title}
        </h1>
        <p class="page-summary">{project.data.summary}</p>
        <div class="flex flex-wrap gap-2">
          <span class="pill">{project.data.status}</span>
          <span class="pill">{project.data.year}</span>
          <span class="pill">{project.data.role}</span>
        </div>
        {links.length > 0 && (
          <div class="page-actions" data-analytics-location="project_detail_primary_links">
            {links.map((link) => (
              <a
                href={link.href}
                target="_blank"
                rel="noreferrer"
                class="button-secondary px-4 py-2"
                data-plausible-project={project.data.title}
                data-plausible-slug={project.slug}
                data-analytics-link-kind={link.kind}
                data-analytics-label={`${project.data.title} ${link.label}`}
              >
                {link.label}
              </a>
            ))}
          </div>
        )}
      </div>
      <div class="panel overflow-hidden">
        <img src={project.data.cover} alt={`${project.data.title} hero visual`} class="aspect-[16/10] w-full object-cover" />
      </div>
    </div>

    <div class="grid gap-8 lg:grid-cols-[320px_minmax(0,1fr)]">
      <aside class="section-card h-fit space-y-6 lg:sticky lg:top-28">
        <div class="space-y-3">
          <h2 class="text-sm font-semibold uppercase tracking-[0.2em] text-slate-200">{copy.common.projectSnapshot}</h2>
          <dl class="space-y-3 text-sm text-slate-300">
            <div class="space-y-1">
              <dt class="text-xs uppercase tracking-[0.18em] text-slate-500">Role</dt>
              <dd>{project.data.role}</dd>
            </div>
            <div class="space-y-1">
              <dt class="text-xs uppercase tracking-[0.18em] text-slate-500">Year</dt>
              <dd>{project.data.year}</dd>
            </div>
            <div class="space-y-1">
              <dt class="text-xs uppercase tracking-[0.18em] text-slate-500">Status</dt>
              <dd>{project.data.status}</dd>
            </div>
            <div class="space-y-1">
              <dt class="text-xs uppercase tracking-[0.18em] text-slate-500">Stack</dt>
              <dd class="flex flex-wrap gap-2">
                {project.data.stack.map((item) => <span class="pill">{item}</span>)}
              </dd>
            </div>
          </dl>
        </div>

        <div class="surface-card space-y-3" data-analytics-location="project_detail_next_steps">
          <h2 class="text-sm font-semibold uppercase tracking-[0.2em] text-slate-200">{copy.common.bestNextSteps}</h2>
          <p class="text-sm leading-7 text-slate-300">
            If this work is relevant to your research, team, or event, the next useful move is usually to compare it with the broader agenda or reach out directly.
          </p>
          <div class="page-actions">
            <a href={localizePath("/research/", locale)} class="button-secondary px-4 py-2">{copy.common.seeResearch}</a>
            <a href={localizePath("/contact/", locale)} class="button-primary px-4 py-2">{copy.common.discussThisWork}</a>
          </div>
        </div>
      </aside>

      <article class="space-y-6">
        {locale !== "en" && <UntranslatedNotice locale={locale} kind="project" />}
        <div class="reading-panel">
          <div class="article-body">
            <slot />
          </div>
        </div>
      </article>
    </div>

    {(previousProject || nextProject) && (
      <div class="grid gap-4 sm:grid-cols-2" data-analytics-location="project_detail_pagination">
        {previousProject ? (
          <a href={localizePath(`/projects/${previousProject.slug}/`, locale)} class="panel block p-6 transition hover:border-white/20">
            <p class="text-xs uppercase tracking-[0.2em] text-slate-500">{copy.common.previousProject}</p>
            <p class="mt-3 text-lg font-semibold text-white">{previousProject.data.title}</p>
          </a>
        ) : (
          <a href={localizePath("/projects/", locale)} class="panel block p-6 transition hover:border-white/20">
            <p class="text-xs uppercase tracking-[0.2em] text-slate-500">{copy.common.browse}</p>
            <p class="mt-3 text-lg font-semibold text-white">{copy.common.allProjects}</p>
          </a>
        )}

        {nextProject && (
          <a href={localizePath(`/projects/${nextProject.slug}/`, locale)} class="panel block p-6 text-left transition hover:border-white/20 sm:text-right">
            <p class="text-xs uppercase tracking-[0.2em] text-slate-500">{copy.common.nextProject}</p>
            <p class="mt-3 text-lg font-semibold text-white">{nextProject.data.title}</p>
          </a>
        )}

        {!nextProject && (
          <a href={localizePath("/contact/", locale)} class="panel block p-6 text-left transition hover:border-white/20 sm:text-right">
            <p class="text-xs uppercase tracking-[0.2em] text-slate-500">{copy.common.needContext}</p>
            <p class="mt-3 text-lg font-semibold text-white">{copy.common.contactJason}</p>
          </a>
        )}
      </div>
    )}
  </div>
</section>
