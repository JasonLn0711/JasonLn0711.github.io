---
import { formatDate, formatLabel } from "../../lib/content";
import type { CollectionEntry } from "astro:content";

interface Props {
  post: CollectionEntry<"blog">;
  featured?: boolean;
  eventName?: string;
}

const { post, featured = false, eventName } = Astro.props;
---

<article class="panel h-full overflow-hidden">
  <a
    href={`/blog/${post.slug}/`}
    class:list={["group flex h-full flex-col focus-visible:outline-none", featured && "lg:grid lg:grid-cols-[1fr_1.1fr]"]}
    data-plausible-event={eventName}
    data-plausible-slug={eventName ? post.slug : undefined}
  >
    <img
      src={post.data.cover}
      alt={`${post.data.title} cover`}
      class:list={[
        "w-full object-cover",
        featured ? "h-full min-h-[16rem]" : "aspect-[16/9]"
      ]}
      loading="lazy"
    />
    <div class="flex h-full flex-col gap-4 p-6 sm:p-7">
      <div class="flex flex-wrap items-center gap-3 text-xs uppercase tracking-[0.2em] text-slate-400">
        <span>{formatLabel(post.data.category)}</span>
        <span class="h-1 w-1 rounded-full bg-white/20"></span>
        <span>{formatDate(post.data.pubDate)}</span>
      </div>
      <h3 class="text-2xl font-semibold tracking-tight text-white transition group-hover:text-[var(--color-accent-strong)]">
        {post.data.title}
      </h3>
      <p class="text-sm leading-7 text-slate-300">{post.data.description}</p>
      <div class="mt-auto flex flex-wrap gap-2">
        {post.data.tags.slice(0, 3).map((tag) => <span class="pill">{tag}</span>)}
      </div>
      <span class="action-link mt-2">
        Read article
        <span aria-hidden="true">→</span>
      </span>
    </div>
  </a>
</article>
