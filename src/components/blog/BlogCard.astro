---
import { formatDate, formatLabel, getBlogPath } from "../../lib/content";
import type { CollectionEntry } from "astro:content";
import { defaultLocale, getPageCopy, type SiteLocale } from "../../lib/i18n";

interface Props {
  post: CollectionEntry<"blog">;
  featured?: boolean;
  eventName?: string;
  analyticsLocation?: string;
  locale?: SiteLocale;
}

const { post, featured = false, eventName, analyticsLocation, locale = defaultLocale } = Astro.props;
const copy = getPageCopy(locale);
---

<article class="panel h-full overflow-hidden transition hover:border-white/20 hover:bg-white/[0.05]" data-analytics-location={analyticsLocation}>
  <a
    href={getBlogPath(post, locale)}
    class:list={["group flex h-full flex-col focus-visible:outline-none", featured && "lg:grid lg:grid-cols-[1fr_1.1fr]"]}
    data-plausible-event={eventName}
    data-plausible-slug={post.data.routeSlug ?? post.slug}
    data-analytics-label={post.data.title}
  >
    <img
      src={post.data.cover}
      alt={`${post.data.title} cover`}
      class:list={[
        "w-full object-cover",
        featured ? "h-full min-h-[16rem]" : "aspect-[16/9]"
      ]}
      loading="lazy"
    />
    <div class="flex h-full flex-col gap-4 p-6 sm:p-7">
      <div class="meta-row text-xs uppercase tracking-[0.2em]">
        <span>{formatLabel(post.data.category, locale)}</span>
        <span class="h-1 w-1 rounded-full bg-white/20"></span>
        <span>{formatDate(post.data.pubDate, locale)}</span>
      </div>
      <h3 class="text-2xl font-semibold tracking-tight text-white transition group-hover:text-[var(--color-accent-strong)]">
        {post.data.title}
      </h3>
      <p class="max-w-[54ch] text-sm leading-7 text-slate-300">{post.data.description}</p>
      <div class="mt-auto flex flex-wrap gap-2">
        {post.data.tags.slice(0, 3).map((tag) => <span class="pill">{tag}</span>)}
      </div>
      <span class="action-link mt-2">
        {copy.common.readArticle}
        <span aria-hidden="true">→</span>
      </span>
    </div>
  </a>
</article>
