---
import { formatDate, formatLabel, getBlogPath } from "../../lib/content";
import type { CollectionEntry } from "astro:content";
import { defaultLocale, getPageCopy, type SiteLocale } from "../../lib/i18n";

interface Props {
  post: CollectionEntry<"blog">;
  featured?: boolean;
  eventName?: string;
  analyticsLocation?: string;
  locale?: SiteLocale;
}

const { post, featured = false, eventName, analyticsLocation, locale = defaultLocale } = Astro.props;
const copy = getPageCopy(locale);
---

<article class="panel h-full transition duration-300 ease-out hover:-translate-y-0.5 hover:shadow-[var(--shadow-card)]" data-analytics-location={analyticsLocation}>
  <a
    href={getBlogPath(post, locale)}
    class:list={["group flex h-full flex-col focus-visible:outline-none", featured && "lg:grid lg:grid-cols-[1fr_1.05fr]"]}
    data-plausible-event={eventName}
    data-plausible-slug={post.data.routeSlug ?? post.slug}
    data-analytics-label={post.data.title}
  >
    <div class:list={["image-frame", featured ? "m-4" : "m-4 mb-0"]}>
      <img
        src={post.data.cover}
        alt={`${post.data.title} cover`}
        class:list={[
          "w-full object-cover transition duration-500 ease-out group-hover:scale-[1.03]",
          featured ? "h-full min-h-[18rem]" : "aspect-[4/3]"
        ]}
        loading="lazy"
      />
    </div>
    <div class="flex h-full flex-col gap-4 p-6 sm:p-7">
      <div class="meta-row">
        <span>{formatLabel(post.data.category, locale)}</span>
        <span class="dot"></span>
        <span>{formatDate(post.data.pubDate, locale)}</span>
      </div>
      <h3 class="font-[var(--font-display)] text-[2rem] leading-[0.98] tracking-[-0.03em] transition group-hover:text-[var(--color-bark)]">
        {post.data.title}
      </h3>
      <p class="max-w-[54ch] text-sm leading-7">{post.data.description}</p>
      <div class="mt-auto flex flex-wrap gap-2">
        {post.data.tags.slice(0, 2).map((tag) => <span class="pill">{tag}</span>)}
      </div>
      <span class="action-link mt-2">
        {copy.common.readArticle}
        <span aria-hidden="true">→</span>
      </span>
    </div>
  </a>
</article>
