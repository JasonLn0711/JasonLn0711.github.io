---
import { execSync } from "node:child_process";
import {
  getLocalizedProfile,
  getLocalizedSite,
  getPageCopy,
  localizePath,
  type SiteLocale
} from "../../lib/i18n";

interface Props {
  locale: SiteLocale;
  pathname: string;
}

const { locale } = Astro.props;
const profile = getLocalizedProfile(locale);
const localizedSite = getLocalizedSite(locale);
const copy = getPageCopy(locale);
const year = new Date().getFullYear();

function readCommand(command: string) {
  try {
    return execSync(command, { cwd: Astro.root.pathname, stdio: ["ignore", "pipe", "ignore"] }).toString().trim();
  } catch {
    return null;
  }
}

function normalizeRepoUrl(remote: string | null) {
  if (!remote) {
    return null;
  }

  if (remote.startsWith("git@github.com:")) {
    return `https://github.com/${remote.slice("git@github.com:".length).replace(/\.git$/, "")}`;
  }

  return remote.replace(/\.git$/, "");
}

const repoUrl = normalizeRepoUrl(readCommand("git config --get remote.origin.url"));
const repoName = repoUrl ? repoUrl.split("/").at(-1) : null;
const branchName = readCommand("git rev-parse --abbrev-ref HEAD");
const commitHash = readCommand("git rev-parse --short HEAD");
const commitDate = readCommand("git log -1 --format=%cs");
const packageVersion = process.env.npm_package_version ?? null;
const branchUrl = repoUrl && branchName ? `${repoUrl}/tree/${branchName}` : repoUrl;
const commitUrl = repoUrl && commitHash ? `${repoUrl}/commit/${commitHash}` : repoUrl;
const localeCode = locale === "zh-tw" ? "zh-TW" : locale === "ja" ? "ja-JP" : "en-US";
const lastUpdated = commitDate
  ? new Intl.DateTimeFormat(localeCode, { year: "numeric", month: "short", day: "numeric" }).format(new Date(`${commitDate}T00:00:00Z`))
  : null;
---

<footer class="border-t border-white/[0.08] py-10">
  <div class="shell grid gap-10 lg:grid-cols-[minmax(0,1.1fr)_minmax(0,0.9fr)]">
    <div class="space-y-5">
      <div class="space-y-3">
        <p class="text-sm font-semibold uppercase tracking-[0.2em] text-slate-200">{profile.name}</p>
        <p class="max-w-2xl text-sm leading-7 text-slate-400">
          {copy.footer.description}
        </p>
      </div>

      <div class="flex flex-wrap gap-3">
        <a href={localizePath("/contact/", locale)} class="button-primary">{copy.footer.contactCta}</a>
        <a href={localizePath("/about/", locale)} class="button-secondary">{copy.footer.aboutCta}</a>
      </div>

      <p class="text-xs text-slate-500">© {year} {profile.name}</p>
    </div>

    <div class="grid gap-8 sm:grid-cols-2">
      <section>
        <h2 class="text-sm font-semibold uppercase tracking-[0.2em] text-slate-200">{copy.common.explore}</h2>
        <nav class="mt-4 space-y-3" aria-label="Footer">
          {localizedSite.nav.map((item) => (
            <a href={localizePath(item.href, locale)} class="block rounded-3xl border border-white/[0.08] bg-white/[0.03] px-4 py-4 transition hover:border-white/20 hover:bg-white/[0.05]">
              <span class="block text-sm font-semibold text-white">{item.label}</span>
              <span class="mt-1 block text-sm leading-6 text-slate-400">{item.description}</span>
            </a>
          ))}
        </nav>
      </section>

      <section>
        <h2 class="text-sm font-semibold uppercase tracking-[0.2em] text-slate-200">{copy.common.connect}</h2>
        <div class="mt-4 space-y-3 text-sm text-slate-400">
          <a href={`mailto:${profile.email}`} class="block rounded-3xl border border-white/[0.08] bg-white/[0.03] px-4 py-4 transition hover:border-white/20 hover:bg-white/[0.05] hover:text-white">
            <span class="block text-sm font-semibold text-white">{copy.common.email}</span>
            <span class="mt-1 block">{profile.email}</span>
          </a>
          <a href={profile.lab.url} target="_blank" rel="noreferrer" class="block rounded-3xl border border-white/[0.08] bg-white/[0.03] px-4 py-4 transition hover:border-white/20 hover:bg-white/[0.05] hover:text-white">
            <span class="block text-sm font-semibold text-white">{copy.footer.researchLab}</span>
            <span class="mt-1 block">{profile.lab.name}</span>
          </a>
          <a href={profile.github} target="_blank" rel="noreferrer" class="block rounded-3xl border border-white/[0.08] bg-white/[0.03] px-4 py-4 transition hover:border-white/20 hover:bg-white/[0.05] hover:text-white">
            <span class="block text-sm font-semibold text-white">GitHub</span>
            <span class="mt-1 block">{copy.footer.githubDescription}</span>
          </a>
          <a href={profile.linkedin} target="_blank" rel="noreferrer" class="block rounded-3xl border border-white/[0.08] bg-white/[0.03] px-4 py-4 transition hover:border-white/20 hover:bg-white/[0.05] hover:text-white">
            <span class="block text-sm font-semibold text-white">LinkedIn</span>
            <span class="mt-1 block">{copy.footer.linkedInDescription}</span>
          </a>
          <div class="flex flex-wrap gap-4 pl-1 text-xs uppercase tracking-[0.18em] text-slate-500">
            <a href={localizePath("/links/", locale)} class="transition hover:text-white">
              {copy.common.links}
            </a>
            <a href="/rss.xml" class="transition hover:text-white">
              RSS
            </a>
          </div>
        </div>
      </section>

      <section class="sm:col-span-2">
        <h2 class="text-sm font-semibold uppercase tracking-[0.2em] text-slate-200">{copy.footer.versionControl}</h2>
        <div class="mt-4 grid gap-3 sm:grid-cols-2 xl:grid-cols-[minmax(0,1.25fr)_repeat(4,minmax(0,0.75fr))]">
          <a
            href={repoUrl ?? profile.github}
            target="_blank"
            rel="noreferrer"
            class="rounded-3xl border border-white/[0.08] bg-white/[0.03] px-4 py-4 transition hover:border-white/20 hover:bg-white/[0.05] hover:text-white"
          >
            <span class="block text-sm font-semibold text-white">{copy.footer.repositoryLabel}</span>
            <span class="mt-1 block text-sm leading-6 text-slate-400">{repoName ?? "GitHub"}</span>
          </a>

          <div class="rounded-3xl border border-white/[0.08] bg-white/[0.03] px-4 py-4">
            <span class="block text-sm font-semibold text-white">{copy.footer.versionLabel}</span>
            <span class="mt-1 block text-sm leading-6 text-slate-400">{packageVersion ? `v${packageVersion}` : "local"}</span>
          </div>

          <a
            href={branchUrl ?? repoUrl ?? profile.github}
            target="_blank"
            rel="noreferrer"
            class="rounded-3xl border border-white/[0.08] bg-white/[0.03] px-4 py-4 transition hover:border-white/20 hover:bg-white/[0.05] hover:text-white"
          >
            <span class="block text-sm font-semibold text-white">{copy.footer.branchLabel}</span>
            <span class="mt-1 block text-sm leading-6 text-slate-400">{branchName ?? "main"}</span>
          </a>

          <a
            href={commitUrl ?? repoUrl ?? profile.github}
            target="_blank"
            rel="noreferrer"
            class="rounded-3xl border border-white/[0.08] bg-white/[0.03] px-4 py-4 transition hover:border-white/20 hover:bg-white/[0.05] hover:text-white"
          >
            <span class="block text-sm font-semibold text-white">{copy.footer.commitLabel}</span>
            <span class="mt-1 block text-sm leading-6 text-slate-400">{commitHash ?? "local"}</span>
          </a>

          <div class="rounded-3xl border border-white/[0.08] bg-white/[0.03] px-4 py-4">
            <span class="block text-sm font-semibold text-white">{copy.common.lastUpdated}</span>
            <span class="mt-1 block text-sm leading-6 text-slate-400">{lastUpdated ?? "Pending"}</span>
          </div>
        </div>
      </section>
    </div>
  </div>
</footer>
