---
import { execSync } from "node:child_process";
import { readFileSync } from "node:fs";
import LanguageSwitcher from "./LanguageSwitcher.astro";
import { getLocalizedProfile, getLocalizedSite, getPageCopy, localizePath, type SiteLocale } from "../../lib/i18n";

interface Props {
  locale: SiteLocale;
  pathname: string;
}

type FooterMeta = {
  packageVersion: string | null;
  commitDate: string | null;
};

const { locale, pathname } = Astro.props;
const profile = getLocalizedProfile(locale);
const localizedSite = getLocalizedSite(locale);
const copy = getPageCopy(locale);
const year = new Date().getFullYear();

function readCommand(command: string) {
  try {
    return execSync(command, { cwd: process.cwd(), stdio: ["ignore", "pipe", "ignore"] }).toString().trim();
  } catch {
    return null;
  }
}

function readPackageVersion() {
  try {
    const packageUrl = new URL("../../../package.json", import.meta.url);
    const packageJson = JSON.parse(readFileSync(packageUrl, "utf8")) as { version?: string };
    return packageJson.version ?? null;
  } catch {
    return null;
  }
}

const footerMetaCache = globalThis as typeof globalThis & { __footerMeta?: FooterMeta };
const footerMeta =
  footerMetaCache.__footerMeta ??
  (footerMetaCache.__footerMeta = {
    packageVersion: readPackageVersion(),
    commitDate: readCommand("git log -1 --format=%cs")
  });

const localeCode = locale === "zh-tw" ? "zh-TW" : locale === "ja" ? "ja-JP" : "en-US";
const lastUpdated = footerMeta.commitDate
  ? new Intl.DateTimeFormat(localeCode, {
      year: "numeric",
      month: "short",
      day: "numeric",
      timeZone: "UTC"
    }).format(new Date(`${footerMeta.commitDate}T00:00:00Z`))
  : null;

const primaryLinks = localizedSite.nav.filter((item) => item.href !== "/resume/");
const utilityLinks = [
  {
    href: localizePath("/resume/", locale),
    label: copy.common.resume
  },
  {
    href: localizePath("/links/", locale),
    label: copy.common.links
  }
];
const connectItems = [
  {
    href: `mailto:${profile.email}`,
    label: copy.common.email,
    value: profile.email,
    external: false
  },
  {
    href: profile.github,
    label: "GitHub",
    value: profile.handle,
    external: true
  },
  {
    href: profile.linkedin,
    label: "LinkedIn",
    value: profile.shortName,
    external: true
  }
];

function displayLabel(href: string, fallback: string) {
  if (href === "/projects/") {
    return locale === "en" ? "Work" : locale === "zh-tw" ? "作品" : "実績";
  }

  return fallback;
}
---

<footer class="site-footer border-t border-[rgba(31,27,23,0.08)] py-10">
  <div class="shell">
    <div class="section-card">
      <div class="grid gap-10 lg:grid-cols-[minmax(0,1.35fr)_minmax(0,0.8fr)_minmax(0,0.9fr)]">
        <section class="space-y-5">
          <span class="eyebrow">{profile.name}</span>
          <p class="max-w-xl text-base leading-8">{copy.footer.description}</p>
          <div class="page-actions">
            <a href={localizePath("/contact/", locale)} class="button-primary">
              {copy.footer.contactCta}
            </a>
            <a href={localizePath("/about/", locale)} class="button-secondary">
              {copy.footer.aboutCta}
            </a>
          </div>
        </section>

        <section class="space-y-4">
          <p class="muted-label">{copy.common.explore}</p>
          <nav class="grid gap-3" aria-label="Footer" data-analytics-location="footer_explore">
            {primaryLinks.map((item) => (
              <a href={localizePath(item.href, locale)} class="quiet-link">
                {displayLabel(item.href, item.label)}
              </a>
            ))}
          </nav>
        </section>

        <section class="space-y-4">
          <p class="muted-label">{copy.common.connect}</p>
          <div class="grid gap-4" data-analytics-location="footer_connect">
            {connectItems.map((item) => (
              <a
                href={item.href}
                target={item.external ? "_blank" : undefined}
                rel={item.external ? "noreferrer" : undefined}
                class="surface-link"
              >
                <p class="muted-label">{item.label}</p>
                <p class="mt-2 text-sm font-medium leading-7 text-[var(--color-charcoal)]">{item.value}</p>
              </a>
            ))}
          </div>
        </section>
      </div>

      <div class="mt-10 grid gap-8 border-t border-[rgba(31,27,23,0.08)] pt-6 lg:grid-cols-[minmax(0,1fr)_auto]">
        <div class="space-y-6">
          <LanguageSwitcher locale={locale} pathname={pathname} alwaysVisible={true} />

          <div class="flex flex-wrap gap-3">
            {utilityLinks.map((item) => (
              <a href={item.href} class="button-quiet">
                {item.label}
              </a>
            ))}
          </div>

          <p class="text-sm leading-7">
            © {year} {profile.name}. {copy.footer.rightsReserved}
          </p>
        </div>

        <div class="grid gap-4 sm:grid-cols-2">
          <div>
            <p class="muted-label">{copy.footer.versionLabel}</p>
            <p class="mt-2 text-sm">{footerMeta.packageVersion ? `v${footerMeta.packageVersion}` : "N/A"}</p>
          </div>
          <div>
            <p class="muted-label">{copy.common.lastUpdated}</p>
            <p class="mt-2 text-sm">{lastUpdated ?? "N/A"}</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</footer>
