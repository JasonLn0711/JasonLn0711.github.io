---
import { execSync } from "node:child_process";
import {
  getLocalizedProfile,
  getLocalizedSite,
  getPageCopy,
  localizePath,
  type SiteLocale
} from "../../lib/i18n";

interface Props {
  locale: SiteLocale;
  pathname: string;
}

type VersionMeta = {
  repoUrl: string | null;
  repoName: string | null;
  branchName: string | null;
  commitHash: string | null;
  commitDate: string | null;
  packageVersion: string | null;
  branchUrl: string | null;
  commitUrl: string | null;
};

const { locale } = Astro.props;
const profile = getLocalizedProfile(locale);
const localizedSite = getLocalizedSite(locale);
const copy = getPageCopy(locale);
const year = new Date().getFullYear();

function readCommand(command: string) {
  try {
    return execSync(command, { cwd: process.cwd(), stdio: ["ignore", "pipe", "ignore"] }).toString().trim();
  } catch {
    return null;
  }
}

function normalizeRepoUrl(remote: string | null) {
  if (!remote) {
    return null;
  }

  if (remote.startsWith("git@github.com:")) {
    return `https://github.com/${remote.slice("git@github.com:".length).replace(/\.git$/, "")}`;
  }

  return remote.replace(/\.git$/, "");
}

const footerVersionCache = globalThis as typeof globalThis & { __footerVersionMeta?: VersionMeta };
const versionMeta =
  footerVersionCache.__footerVersionMeta ??
  (() => {
    const repoUrl = normalizeRepoUrl(readCommand("git config --get remote.origin.url"));
    const branchName = readCommand("git rev-parse --abbrev-ref HEAD");
    const commitHash = readCommand("git rev-parse --short HEAD");

    return (footerVersionCache.__footerVersionMeta = {
      repoUrl,
      repoName: repoUrl ? repoUrl.split("/").at(-1) ?? null : null,
      branchName,
      commitHash,
      commitDate: readCommand("git log -1 --format=%cs"),
      packageVersion: process.env.npm_package_version ?? null,
      branchUrl: repoUrl && branchName ? `${repoUrl}/tree/${branchName}` : repoUrl,
      commitUrl: repoUrl && commitHash ? `${repoUrl}/commit/${commitHash}` : repoUrl
    });
  })();

const localeCode = locale === "zh-tw" ? "zh-TW" : locale === "ja" ? "ja-JP" : "en-US";
const lastUpdated = versionMeta.commitDate
  ? new Intl.DateTimeFormat(localeCode, {
      year: "numeric",
      month: "short",
      day: "numeric",
      timeZone: "UTC"
    }).format(new Date(`${versionMeta.commitDate}T00:00:00Z`))
  : null;
const connectItems = [
  {
    href: `mailto:${profile.email}`,
    label: copy.common.email,
    value: profile.email,
    external: false
  },
  {
    href: profile.lab.url,
    label: copy.footer.researchLab,
    value: profile.lab.name,
    external: true
  },
  {
    href: profile.github,
    label: "GitHub",
    value: copy.footer.githubDescription,
    external: true
  },
  {
    href: profile.linkedin,
    label: "LinkedIn",
    value: copy.footer.linkedInDescription,
    external: true
  }
];
const versionItems = [
  {
    href: versionMeta.repoUrl ?? profile.github,
    label: copy.footer.repositoryLabel,
    value: versionMeta.repoName ?? "N/A"
  },
  {
    href: null,
    label: copy.footer.versionLabel,
    value: versionMeta.packageVersion ? `v${versionMeta.packageVersion}` : versionMeta.commitHash ?? "N/A"
  },
  {
    href: versionMeta.branchUrl ?? versionMeta.repoUrl ?? profile.github,
    label: copy.footer.branchLabel,
    value: versionMeta.branchName ?? "N/A"
  },
  {
    href: versionMeta.commitUrl ?? versionMeta.repoUrl ?? profile.github,
    label: copy.footer.commitLabel,
    value: versionMeta.commitHash ?? "N/A"
  },
  {
    href: null,
    label: copy.common.lastUpdated,
    value: lastUpdated ?? "N/A"
  }
];
---

<footer class="border-t border-white/[0.08] py-10">
  <div class="shell space-y-6">
    <div class="panel overflow-hidden">
      <div class="grid gap-10 p-6 lg:grid-cols-[minmax(0,1.05fr)_minmax(0,0.95fr)] lg:p-8">
        <section class="space-y-6">
          <div class="space-y-4">
            <p class="eyebrow mb-0">{profile.name}</p>
            <p class="max-w-2xl text-sm leading-7 text-slate-300">
              {copy.footer.description}
            </p>
          </div>

          <div class="flex flex-wrap gap-3">
            <a href={localizePath("/contact/", locale)} class="button-primary">{copy.footer.contactCta}</a>
            <a href={localizePath("/about/", locale)} class="button-secondary">{copy.footer.aboutCta}</a>
          </div>

          <div class="flex flex-wrap gap-4 pl-1 text-xs uppercase tracking-[0.18em] text-slate-500">
            <a href={localizePath("/links/", locale)} class="transition hover:text-white">
              {copy.common.links}
            </a>
            <a href="/rss.xml" class="transition hover:text-white">
              RSS
            </a>
          </div>
        </section>

        <div class="grid gap-8 xl:grid-cols-[minmax(0,0.88fr)_minmax(0,1.12fr)]">
          <section>
            <h2 class="text-sm font-semibold uppercase tracking-[0.2em] text-slate-200">{copy.common.explore}</h2>
            <nav class="mt-4 grid gap-2 sm:grid-cols-2 xl:grid-cols-1" aria-label="Footer">
              {localizedSite.nav.map((item) => (
                <a
                  href={localizePath(item.href, locale)}
                  class="group flex min-h-12 items-center justify-between rounded-2xl border border-white/[0.08] bg-white/[0.03] px-4 py-3 text-sm font-semibold text-white transition hover:border-white/20 hover:bg-white/[0.05]"
                >
                  <span>{item.label}</span>
                  <span class="text-slate-500 transition group-hover:translate-x-0.5 group-hover:text-slate-300" aria-hidden="true">&gt;</span>
                </a>
              ))}
            </nav>
          </section>

          <section>
            <h2 class="text-sm font-semibold uppercase tracking-[0.2em] text-slate-200">{copy.common.connect}</h2>
            <div class="mt-4 grid gap-3 sm:grid-cols-2">
              {connectItems.map((item) => (
                <a
                  href={item.href}
                  target={item.external ? "_blank" : undefined}
                  rel={item.external ? "noreferrer" : undefined}
                  class="rounded-2xl border border-white/[0.08] bg-white/[0.03] px-4 py-4 transition hover:border-white/20 hover:bg-white/[0.05] hover:text-white"
                >
                  <span class="block text-xs font-semibold uppercase tracking-[0.18em] text-slate-500">{item.label}</span>
                  <span class="mt-2 block text-sm leading-6 text-slate-200">{item.value}</span>
                </a>
              ))}
            </div>
          </section>
        </div>
      </div>
    </div>

    <section class="rounded-3xl border border-white/[0.08] bg-white/[0.03] px-5 py-4">
      <div class="flex flex-col gap-4 lg:flex-row lg:items-center lg:justify-between">
        <div class="space-y-1">
          <p class="text-xs font-semibold uppercase tracking-[0.2em] text-slate-300">{copy.footer.versionControl}</p>
          <p class="text-xs text-slate-500">© {year} {profile.name}</p>
        </div>

        <div class="flex flex-wrap gap-2">
          {versionItems.map((item) =>
            item.href ? (
              <a
                href={item.href}
                target="_blank"
                rel="noreferrer"
                class="inline-flex min-h-10 items-center rounded-full border border-white/[0.08] bg-white/[0.04] px-4 py-2 text-xs font-medium text-slate-300 transition hover:border-white/20 hover:bg-white/[0.06] hover:text-white"
              >
                <span class="text-slate-500">{item.label}:</span>
                <span class="ml-2 text-slate-100">{item.value}</span>
              </a>
            ) : (
              <div class="inline-flex min-h-10 items-center rounded-full border border-white/[0.08] bg-white/[0.04] px-4 py-2 text-xs font-medium text-slate-300">
                <span class="text-slate-500">{item.label}:</span>
                <span class="ml-2 text-slate-100">{item.value}</span>
              </div>
            )
          )}
        </div>
      </div>
    </section>
  </div>
</footer>
