---
import { profile } from "../../data/profile";
import { site } from "../../lib/site";

const year = new Date().getFullYear();
---

<footer class="border-t border-white/[0.08] py-10">
  <div class="shell flex flex-col gap-8 md:flex-row md:items-end md:justify-between">
    <div class="max-w-xl space-y-3">
      <p class="text-sm font-semibold uppercase tracking-[0.2em] text-slate-200">{profile.name}</p>
      <p class="max-w-lg text-sm leading-6 text-slate-400">
        Doctoral research platform focused on trustworthy AI systems, speech intelligence, cybersecurity, and real-world high-stakes deployment.
      </p>
      <p class="text-xs text-slate-500">© {year} {profile.name}</p>
    </div>

    <div class="flex flex-col gap-4 text-sm text-slate-400 md:items-end">
      <nav class="flex flex-wrap gap-4" aria-label="Footer">
        {site.nav.map((item) => (
          <a href={item.href} class="transition hover:text-white">
            {item.label}
          </a>
        ))}
        <a href="/links/" class="transition hover:text-white">
          Links
        </a>
        <a href="/rss.xml" class="transition hover:text-white">
          RSS
        </a>
      </nav>
      <div class="flex flex-wrap gap-4">
        <a href={`mailto:${profile.email}`} class="transition hover:text-white">
          Email
        </a>
        <a href={profile.github} target="_blank" rel="noreferrer" class="transition hover:text-white">
          GitHub
        </a>
        <a href={profile.linkedin} target="_blank" rel="noreferrer" class="transition hover:text-white">
          LinkedIn
        </a>
      </div>
    </div>
  </div>
</footer>
