---
import { contactLinks } from "../../data/contact";
import { profile } from "../../data/profile";
import { site } from "../../lib/site";

const year = new Date().getFullYear();
---

<footer class="border-t border-[var(--color-line)] py-10">
  <div class="shell flex flex-col gap-8 md:flex-row md:items-end md:justify-between">
    <div class="max-w-xl space-y-3">
      <p class="text-sm font-semibold uppercase tracking-[0.2em] text-[var(--color-ink)]">{profile.name}</p>
      <p class="max-w-lg text-sm leading-6 text-[var(--color-muted)]">
        {profile.positioning}
      </p>
      <p class="text-xs text-[var(--color-soft)]">© {year} {profile.name}</p>
    </div>

    <div class="flex flex-col gap-4 text-sm text-[var(--color-muted)] md:items-end">
      <nav class="flex flex-wrap gap-4" aria-label="Footer">
        {site.nav.map((item) => (
          <a href={item.href} class="transition hover:text-[var(--color-ink)]">
            {item.label}
          </a>
        ))}
        <a href="/rss.xml" class="transition hover:text-[var(--color-ink)]">
          RSS
        </a>
      </nav>
      <div class="flex flex-wrap gap-4">
        {contactLinks.map((link) => (
          <a href={link.href} target={link.href.startsWith("http") ? "_blank" : undefined} rel={link.href.startsWith("http") ? "noreferrer" : undefined} class="transition hover:text-[var(--color-ink)]">
            {link.label}
          </a>
        ))}
      </div>
    </div>
  </div>
</footer>
