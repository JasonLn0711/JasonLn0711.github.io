---
import { getPageCopy, type SiteLocale } from "../../lib/i18n";

interface Props {
  locale: SiteLocale;
  kind: "blog" | "project" | "research" | "talk";
}

const { locale, kind } = Astro.props;
const copy = getPageCopy(locale);

const message =
  kind === "blog"
    ? copy.common.untranslatedBlog
    : kind === "project"
      ? copy.common.untranslatedProject
      : kind === "research"
        ? copy.common.untranslatedResearch
      : copy.common.untranslatedTalk;
---

<div class="surface-card">
  <p class="muted-label">{copy.common.untranslatedLabel}</p>
  <h2 class="mt-3 text-lg font-semibold">{copy.common.untranslatedTitle}</h2>
  <p class="mt-2 text-sm leading-7">{message}</p>
</div>
