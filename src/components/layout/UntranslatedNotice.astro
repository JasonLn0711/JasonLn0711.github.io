---
import { getPageCopy, type SiteLocale } from "../../lib/i18n";

interface Props {
  locale: SiteLocale;
  kind: "blog" | "project" | "talk";
}

const { locale, kind } = Astro.props;
const copy = getPageCopy(locale);

const message =
  kind === "blog"
    ? copy.common.untranslatedBlog
    : kind === "project"
      ? copy.common.untranslatedProject
      : copy.common.untranslatedTalk;
---

<div class="rounded-3xl border border-white/[0.08] bg-white/[0.03] p-5">
  <p class="text-xs uppercase tracking-[0.18em] text-slate-500">{copy.common.untranslatedLabel}</p>
  <h2 class="mt-3 text-lg font-semibold text-white">{copy.common.untranslatedTitle}</h2>
  <p class="mt-2 text-sm leading-7 text-slate-300">{message}</p>
</div>
