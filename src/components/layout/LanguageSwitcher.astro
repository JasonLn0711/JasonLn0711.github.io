---
import {
  getLanguageOptions,
  getPageCopy,
  type SiteLocale
} from "../../lib/i18n";
import { normalizePathname as normalizePathnameFromSite } from "../../lib/site";

interface Props {
  locale: SiteLocale;
  pathname: string;
  mobile?: boolean;
}

const { locale, pathname, mobile = false } = Astro.props;
const copy = getPageCopy(locale);
const options = getLanguageOptions(pathname);
const currentPath = normalizePathnameFromSite(pathname);
---

<div class:list={[mobile ? "space-y-3" : "items-center gap-3", mobile ? "" : "hidden lg:flex"]}>
  <p class="text-xs uppercase tracking-[0.18em] text-slate-500">{copy.common.language}</p>
  <div class="flex flex-wrap gap-2" aria-label={copy.common.languageSwitcherAria}>
    {options.map((option) => {
      const isCurrent = normalizePathnameFromSite(option.href) === currentPath;

      return (
        <a
          href={option.href}
          class:list={[
            "inline-flex min-h-10 items-center rounded-full border px-3 text-sm transition",
            isCurrent
              ? "border-white/20 bg-white/[0.08] font-semibold text-white"
              : "border-white/[0.12] bg-white/[0.04] text-slate-300 hover:border-white/20 hover:text-white"
          ]}
          hreflang={option.locale === "en" ? "en" : option.locale === "zh-tw" ? "zh-TW" : "ja"}
          lang={option.locale === "en" ? "en" : option.locale === "zh-tw" ? "zh-Hant-TW" : "ja"}
          aria-current={isCurrent ? "page" : undefined}
        >
          {option.label}
        </a>
      );
    })}
  </div>
</div>
