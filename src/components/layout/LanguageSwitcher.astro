---
import {
  getLanguageOptions,
  getPageCopy,
  type SiteLocale
} from "../../lib/i18n";
import { normalizePathname as normalizePathnameFromSite } from "../../lib/site";

interface Props {
  locale: SiteLocale;
  pathname: string;
  mobile?: boolean;
  compact?: boolean;
  alwaysVisible?: boolean;
}

const { locale, pathname, mobile = false, compact = false, alwaysVisible = false } = Astro.props;
const copy = getPageCopy(locale);
const options = getLanguageOptions(pathname);
const currentPath = normalizePathnameFromSite(pathname);
const showLabel = mobile ? !compact : alwaysVisible;
const analyticsLocation = mobile ? "mobile_language_switch" : alwaysVisible ? "footer_language_switch" : "language_switch";
---

<div
  class:list={[showLabel ? "space-y-3" : "", mobile || alwaysVisible ? "" : "hidden lg:flex"]}
  data-analytics-location={analyticsLocation}
>
  {showLabel ? (
    <p class="muted-label">{copy.common.language}</p>
  ) : (
    <span class="sr-only">{copy.common.language}</span>
  )}
  <div
    class:list={[
      "inline-flex items-center rounded-full border p-1",
      mobile || alwaysVisible ? (compact ? "flex-nowrap gap-1" : "flex-wrap gap-1.5") : "flex-nowrap gap-1"
    ]}
    style="border-color: rgba(31, 27, 23, 0.12); background: rgba(255, 252, 247, 0.7);"
    aria-label={copy.common.languageSwitcherAria}
    role="group"
  >
    {options.map((option) => {
      const isCurrent = normalizePathnameFromSite(option.href) === currentPath;

      return (
        <a
          href={option.href}
          class:list={[
            "inline-flex min-h-9 items-center justify-center rounded-full border px-3.5 text-sm font-medium whitespace-nowrap transition",
            mobile || alwaysVisible ? (compact ? "min-h-8 min-w-0 px-2.5 text-xs" : "min-w-[4.5rem]") : "min-w-[3.75rem]",
            isCurrent
              ? "text-[var(--color-ink)]"
              : "text-[rgba(31,27,23,0.54)] hover:text-[var(--color-ink)]"
          ]}
          style={isCurrent ? "border-color: rgba(31, 27, 23, 0.16); background: rgba(31, 27, 23, 0.04);" : "border-color: transparent;"}
          hreflang={option.locale === "en" ? "en" : option.locale === "zh-tw" ? "zh-TW" : "ja"}
          lang={option.locale === "en" ? "en" : option.locale === "zh-tw" ? "zh-Hant-TW" : "ja"}
          aria-current={isCurrent ? "page" : undefined}
          aria-label={option.label}
          title={option.label}
          data-plausible-event={isCurrent ? undefined : "language_switch"}
          data-analytics-from-locale={isCurrent ? undefined : locale}
          data-analytics-to-locale={isCurrent ? undefined : option.locale}
          data-analytics-path={isCurrent ? undefined : currentPath}
        >
          {option.shortLabel}
        </a>
      );
    })}
  </div>
</div>
