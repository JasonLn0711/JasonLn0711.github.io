---
import {
  getLanguageOptions,
  getPageCopy,
  type SiteLocale
} from "../../lib/i18n";
import { normalizePathname as normalizePathnameFromSite } from "../../lib/site";

interface Props {
  locale: SiteLocale;
  pathname: string;
  mobile?: boolean;
}

const { locale, pathname, mobile = false } = Astro.props;
const copy = getPageCopy(locale);
const options = getLanguageOptions(pathname);
const currentPath = normalizePathnameFromSite(pathname);
---

<div class:list={[mobile ? "space-y-3" : "", mobile ? "" : "hidden lg:flex"]}>
  {mobile ? (
    <p class="text-xs uppercase tracking-[0.18em] text-slate-500">{copy.common.language}</p>
  ) : (
    <span class="sr-only">{copy.common.language}</span>
  )}
  <div
    class:list={[
      "inline-flex items-center rounded-full border border-white/[0.1] bg-white/[0.03] p-1",
      mobile ? "flex-wrap gap-1.5" : "flex-nowrap gap-1"
    ]}
    aria-label={copy.common.languageSwitcherAria}
    role="group"
  >
    {options.map((option) => {
      const isCurrent = normalizePathnameFromSite(option.href) === currentPath;

      return (
        <a
          href={option.href}
          class:list={[
            "inline-flex min-h-9 items-center justify-center rounded-full border px-3.5 text-sm font-medium whitespace-nowrap transition",
            mobile ? "min-w-[4.5rem]" : "min-w-[3.75rem]",
            isCurrent
              ? "border-white/[0.14] bg-white/[0.1] text-white"
              : "border-transparent text-slate-400 hover:bg-white/[0.05] hover:text-white"
          ]}
          hreflang={option.locale === "en" ? "en" : option.locale === "zh-tw" ? "zh-TW" : "ja"}
          lang={option.locale === "en" ? "en" : option.locale === "zh-tw" ? "zh-Hant-TW" : "ja"}
          aria-current={isCurrent ? "page" : undefined}
          aria-label={option.label}
          title={option.label}
        >
          {option.shortLabel}
        </a>
      );
    })}
  </div>
</div>
