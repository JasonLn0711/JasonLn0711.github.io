---
import { profile } from "../../data/profile";
import { site } from "../../lib/site";
---

<header class="sticky top-0 z-50 border-b border-white/[0.08] bg-slate-950/[0.72] backdrop-blur">
  <div class="shell flex min-h-[72px] items-center justify-between gap-6 py-4">
    <a href="/" class="min-w-0 text-sm font-semibold tracking-[0.22em] text-slate-100 uppercase">
      {profile.name}
    </a>

    <nav class="hidden items-center gap-5 md:flex" aria-label="Primary">
      {site.nav.map((item) => (
        <a href={item.href} class="text-sm text-slate-300 transition hover:text-white">
          {item.label}
        </a>
      ))}
    </nav>

    <div class="hidden items-center gap-3 lg:flex">
      <a href={profile.github} class="pill transition hover:border-white/20 hover:text-white" target="_blank" rel="noreferrer">
        GitHub
      </a>
      <a href={profile.linkedin} class="pill transition hover:border-white/20 hover:text-white" target="_blank" rel="noreferrer">
        LinkedIn
      </a>
      <a href={`mailto:${profile.email}`} class="pill transition hover:border-white/20 hover:text-white">
        Email
      </a>
    </div>

    <details class="group relative md:hidden">
      <summary class="button-secondary list-none cursor-pointer px-4 py-2">
        Menu
      </summary>
      <div class="panel absolute right-0 mt-3 min-w-56 p-4">
        <nav class="flex flex-col gap-3" aria-label="Mobile">
          {site.nav.map((item) => (
            <a href={item.href} class="text-sm text-slate-200 transition hover:text-white">
              {item.label}
            </a>
          ))}
          <div class="my-1 h-px bg-white/[0.08]"></div>
          <a href={profile.github} class="text-sm text-slate-300 transition hover:text-white" target="_blank" rel="noreferrer">
            GitHub
          </a>
          <a href={profile.linkedin} class="text-sm text-slate-300 transition hover:text-white" target="_blank" rel="noreferrer">
            LinkedIn
          </a>
          <a href={`mailto:${profile.email}`} class="text-sm text-slate-300 transition hover:text-white">
            Email
          </a>
        </nav>
      </div>
    </details>
  </div>
</header>
