---
import { normalizePathname } from "../../lib/site";
import LanguageSwitcher from "./LanguageSwitcher.astro";
import {
  getLocalizedProfile,
  getLocalizedSite,
  getPageCopy,
  localizePath,
  type SiteLocale
} from "../../lib/i18n";

interface Props {
  locale: SiteLocale;
  pathname: string;
}

const { locale, pathname } = Astro.props;
const currentPath = normalizePathname(pathname);
const localizedSite = getLocalizedSite(locale);
const localizedProfile = getLocalizedProfile(locale);
const copy = getPageCopy(locale);
const homePath = localizePath("/", locale);
const isHomePage = currentPath === homePath;
const primaryNav = localizedSite.nav.filter((item) => item.href !== "/contact/");
const mobileNavItems = localizedSite.nav;

function isActive(href: string) {
  const localizedHref = localizePath(href, locale);
  return currentPath === localizedHref || (localizedHref !== "/" && currentPath.startsWith(localizedHref));
}
---

<header class="sticky top-0 z-50 border-b border-white/[0.08] bg-slate-950/[0.8] backdrop-blur">
  <div class="shell py-4">
    <div class="flex min-h-[64px] items-center justify-between gap-4">
      <div class="min-w-0">
        <a
          href={localizePath("/", locale)}
          class="inline-flex min-h-11 items-center text-sm font-semibold tracking-[0.22em] text-slate-100 uppercase"
          aria-label={localizedProfile.name}
        >
          <span class="sm:hidden">{localizedProfile.shortName}</span>
          <span class="hidden sm:inline">{localizedProfile.name}</span>
        </a>
      </div>

      <nav class={isHomePage ? "hidden" : "hidden items-center gap-1 md:flex"} aria-label="Primary">
        {primaryNav.map((item) => (
          <a
            href={localizePath(item.href, locale)}
            class:list={[
              "inline-flex min-h-11 items-center rounded-full px-4 text-sm transition",
              isActive(item.href)
                ? "bg-white/[0.08] font-semibold text-white"
                : "text-slate-300 hover:bg-white/[0.04] hover:text-white"
            ]}
            aria-current={isActive(item.href) ? "page" : undefined}
          >
            {item.label}
          </a>
        ))}
      </nav>

      <div class="hidden items-center gap-3 xl:flex">
        <LanguageSwitcher locale={locale} pathname={pathname} />
      </div>

      <div class={isHomePage ? "hidden" : "hidden items-center gap-3 xl:flex"}>
        <a href={localizedProfile.github} class="pill transition hover:border-white/20 hover:text-white" target="_blank" rel="noreferrer">
          GitHub
        </a>
        <a href={localizedProfile.linkedin} class="pill transition hover:border-white/20 hover:text-white" target="_blank" rel="noreferrer">
          LinkedIn
        </a>
      </div>

      <div class={isHomePage ? "hidden" : "hidden items-center gap-3 md:flex"}>
        <a
          href={localizePath("/contact/", locale)}
          class:list={[isActive("/contact/") ? "button-primary" : "button-secondary"]}
          data-plausible-event="nav_contact_click"
          aria-current={isActive("/contact/") ? "page" : undefined}
        >
          {copy.common.contact}
        </a>
      </div>

      <div class="md:hidden">
        <LanguageSwitcher locale={locale} pathname={pathname} mobile={true} compact={true} />
      </div>
    </div>

    <div class="mt-4 border-t border-white/[0.08] pt-4 md:hidden">
      <nav class="mobile-direct-nav" aria-label="Primary">
        {mobileNavItems.map((item) => (
          <a
            href={localizePath(item.href, locale)}
            class:list={[
              "inline-flex min-h-10 shrink-0 items-center rounded-full border px-4 text-sm font-medium transition",
              item.href === "/contact/"
                ? isActive(item.href)
                  ? "border-[var(--color-accent)] bg-[var(--color-accent)] text-slate-950"
                  : "border-[var(--color-accent)]/35 bg-[color:rgba(99,164,255,0.12)] text-white hover:bg-[color:rgba(99,164,255,0.18)]"
                : isActive(item.href)
                  ? "border-white/[0.16] bg-white/[0.08] text-white"
                  : "border-white/[0.08] bg-white/[0.03] text-slate-300 hover:border-white/20 hover:bg-white/[0.05] hover:text-white"
            ]}
            aria-current={isActive(item.href) ? "page" : undefined}
            data-plausible-event={item.href === "/contact/" ? "nav_contact_click" : undefined}
          >
            {item.label}
          </a>
        ))}
      </nav>
    </div>
  </div>
</header>

<style>
  .mobile-direct-nav {
    display: flex;
    gap: 0.6rem;
    overflow-x: auto;
    padding-bottom: 0.25rem;
    scrollbar-width: none;
    -ms-overflow-style: none;
  }

  .mobile-direct-nav::-webkit-scrollbar {
    display: none;
  }
</style>
