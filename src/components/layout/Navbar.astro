---
import LanguageSwitcher from "./LanguageSwitcher.astro";
import { normalizePathname } from "../../lib/site";
import {
  getPageCopy,
  getLocalizedProfile,
  getLocalizedSite,
  localizePath,
  type SiteLocale
} from "../../lib/i18n";

interface Props {
  locale: SiteLocale;
  pathname: string;
}

const { locale, pathname } = Astro.props;
const currentPath = normalizePathname(pathname);
const localizedSite = getLocalizedSite(locale);
const localizedProfile = getLocalizedProfile(locale);
const copy = getPageCopy(locale);
const primaryNav = localizedSite.nav.filter((item) => item.href !== "/resume/");
const utilityLinks = [
  {
    href: localizePath("/resume/", locale),
    label: locale === "en" ? "Resume" : locale === "zh-tw" ? "履歷" : "経歴"
  },
  {
    href: localizePath("/links/", locale),
    label: locale === "en" ? "Links" : locale === "zh-tw" ? "連結" : "リンク"
  }
];

function isActive(href: string) {
  const localizedHref = localizePath(href, locale);
  return currentPath === localizedHref || (localizedHref !== "/" && currentPath.startsWith(localizedHref));
}

function displayLabel(href: string, fallback: string) {
  if (href === "/projects/") {
    return locale === "en" ? "Work" : locale === "zh-tw" ? "作品" : "実績";
  }

  return fallback;
}
---

<header class="site-header sticky top-0 z-50 border-b border-[rgba(31,27,23,0.08)] bg-[rgba(243,239,231,0.8)] backdrop-blur">
  <div class="shell">
    <div class="flex min-h-[5.35rem] items-center justify-between gap-6">
      <a
        href={localizePath("/", locale)}
        class="min-w-0 max-w-[24rem]"
        aria-label={localizedProfile.name}
        data-analytics-location="navbar_brand"
      >
        <span class="block text-[0.8rem] font-semibold uppercase tracking-[0.24em] text-[rgba(31,27,23,0.46)]">
          {localizedProfile.shortName}
        </span>
        <span class="mt-2 block font-[var(--font-display)] text-[1.35rem] leading-none tracking-[-0.03em] text-[var(--color-ink)]">
          {localizedProfile.name}
        </span>
        <span class="mt-1 hidden text-sm leading-6 text-[rgba(31,27,23,0.62)] xl:block">
          {copy.navbar.desktopTagline}
        </span>
      </a>

      <nav class="hidden items-center gap-6 lg:flex" aria-label="Primary" data-analytics-location="navbar_primary">
        {primaryNav.map((item) => (
          <a
            href={localizePath(item.href, locale)}
            class:list={[
              "relative inline-flex min-h-11 items-center py-2 text-[0.95rem] font-medium transition",
              isActive(item.href)
                ? "text-[var(--color-ink)]"
                : "text-[rgba(31,27,23,0.58)] hover:text-[var(--color-ink)]"
            ]}
            aria-current={isActive(item.href) ? "page" : undefined}
          >
            <span>{displayLabel(item.href, item.label)}</span>
            <span
              class:list={[
                "absolute inset-x-0 -bottom-[0.05rem] h-px origin-left bg-[rgba(31,27,23,0.45)] transition-transform duration-300",
                isActive(item.href) ? "scale-x-100" : "scale-x-0"
              ]}
            ></span>
          </a>
        ))}
      </nav>

      <div class="hidden items-center gap-4 lg:flex">
        <LanguageSwitcher locale={locale} pathname={pathname} />
      </div>

      <button
        type="button"
        class="button-secondary lg:hidden"
        data-mobile-menu-open
        aria-haspopup="dialog"
        aria-controls="mobile-site-menu"
      >
        Menu
      </button>
    </div>
  </div>

  <dialog id="mobile-site-menu" class="mobile-menu lg:hidden">
    <div class="mobile-menu__panel">
      <div class="flex items-start justify-between gap-4">
        <div class="max-w-[18rem]">
          <p class="muted-label">{localizedProfile.shortName}</p>
          <p class="mt-3 font-[var(--font-display)] text-[2rem] leading-[0.95] tracking-[-0.03em] text-[var(--color-ink)]">
            {localizedProfile.name}
          </p>
        </div>

        <button type="button" class="button-quiet" data-mobile-menu-close>
          Close
        </button>
      </div>

      <nav class="mt-8 editorial-list" aria-label="Mobile" data-analytics-location="navbar_mobile">
        {primaryNav.map((item) => (
          <a href={localizePath(item.href, locale)} class="block py-1" data-mobile-menu-link>
            <span class="block font-[var(--font-display)] text-[2rem] leading-none tracking-[-0.03em] text-[var(--color-ink)]">
              {displayLabel(item.href, item.label)}
            </span>
            <span class="mt-2 block max-w-[28rem] text-sm leading-7 text-[var(--color-muted)]">
              {item.description}
            </span>
          </a>
        ))}
      </nav>

      <div class="mt-8 grid gap-6 sm:grid-cols-2">
        <div class="space-y-4">
          <p class="muted-label">Utility</p>
          <div class="flex flex-wrap gap-3">
            {utilityLinks.map((item) => (
              <a href={item.href} class="button-secondary" data-mobile-menu-link>
                {item.label}
              </a>
            ))}
          </div>
        </div>

        <div class="space-y-4">
          <LanguageSwitcher locale={locale} pathname={pathname} mobile={true} alwaysVisible={true} />
        </div>
      </div>
    </div>
  </dialog>
</header>

<script is:inline>
  const mobileMenu = document.querySelector("#mobile-site-menu");
  const openMenuButton = document.querySelector("[data-mobile-menu-open]");
  const closeMenuButtons = document.querySelectorAll("[data-mobile-menu-close], [data-mobile-menu-link]");

  if (mobileMenu instanceof HTMLDialogElement && openMenuButton instanceof HTMLElement) {
    openMenuButton.addEventListener("click", () => {
      mobileMenu.showModal();
      document.body.style.overflow = "hidden";
    });

    closeMenuButtons.forEach((button) => {
      button.addEventListener("click", () => {
        mobileMenu.close();
        document.body.style.overflow = "";
      });
    });

    mobileMenu.addEventListener("click", (event) => {
      const dialogDimensions = mobileMenu.getBoundingClientRect();
      const clickedBackdrop =
        event.clientX < dialogDimensions.left ||
        event.clientX > dialogDimensions.right ||
        event.clientY < dialogDimensions.top ||
        event.clientY > dialogDimensions.bottom;

      if (clickedBackdrop) {
        mobileMenu.close();
        document.body.style.overflow = "";
      }
    });

    mobileMenu.addEventListener("close", () => {
      document.body.style.overflow = "";
    });
  }
</script>

<style>
  .mobile-menu {
    width: min(100% - 1rem, 42rem);
    margin: auto;
    border: 0;
    padding: 0;
    background: transparent;
  }

  .mobile-menu::backdrop {
    background: rgba(31, 27, 23, 0.3);
    backdrop-filter: blur(10px);
  }

  .mobile-menu__panel {
    border-radius: 1.75rem;
    border: 1px solid rgba(31, 27, 23, 0.08);
    background:
      linear-gradient(180deg, rgba(255, 252, 247, 0.98), rgba(243, 239, 231, 0.96));
    box-shadow: 0 30px 90px rgba(31, 27, 23, 0.16);
    padding: 1.35rem;
  }
 </style>
