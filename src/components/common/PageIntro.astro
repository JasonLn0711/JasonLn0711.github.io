---
interface Props {
  eyebrow: string;
  title: string;
  description: string;
}

const { eyebrow, title, description } = Astro.props;
---

<div class="page-intro">
  <span class="eyebrow">{eyebrow}</span>
  <h1 class="page-title">{title}</h1>
  <p class="page-copy">{description}</p>
  <slot />
</div>
