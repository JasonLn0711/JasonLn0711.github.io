---
interface Props {
  eyebrow?: string;
  title: string;
  description?: string;
  center?: boolean;
}

const { eyebrow, title, description, center = false } = Astro.props;
---

<div class:list={["space-y-4", center && "mx-auto text-center"]}>
  {eyebrow && <span class="eyebrow">{eyebrow}</span>}
  <h2 class="section-title">{title}</h2>
  {description && <p class="section-copy">{description}</p>}
</div>
