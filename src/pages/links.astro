---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import CTASection from "../components/ui/CTASection.astro";
import PageHero from "../components/ui/PageHero.astro";
import SectionIntro from "../components/ui/SectionIntro.astro";
import { formatDate, formatLabel, getBlogPath, getLocalizedBlogEntries, sortProjects } from "../lib/content";
import {
  formatMessage,
  getLocaleFromPathname,
  getLocalizedLinksPage,
  getLocalizedPageTitle,
  getLocalizedProfile,
  getLocalizedSpeaking,
  getPageCopy,
  localizePath
} from "../lib/i18n";

const locale = getLocaleFromPathname(Astro.url.pathname);
const linksPage = getLocalizedLinksPage(locale);
const profile = getLocalizedProfile(locale);
const speaking = getLocalizedSpeaking(locale);
const copy = getPageCopy(locale);
const projects = sortProjects(await getCollection("projects")).filter((entry) => entry.data.featured).slice(0, 3);
const posts = getLocalizedBlogEntries(await getCollection("blog"), locale);
const featuredPost = posts.find((post) => post.data.featured) ?? posts[0];
const lastUpdated = formatDate(new Date(), locale);

const selectedWork = [
  ...projects.map((project) => ({
    href: localizePath(`/projects/${project.slug}/`, locale),
    label: project.data.title,
    description: project.data.summary,
    kind: copy.common.projects
  })),
  ...(featuredPost
    ? [
        {
          href: getBlogPath(featuredPost, locale),
          label: featuredPost.data.title,
          description: featuredPost.data.description,
          kind: formatLabel(featuredPost.data.category, locale)
        }
      ]
    : []),
  {
    href: localizePath(speaking.featuredEngagement.storyHref, locale),
    label: speaking.featuredEngagement.storyLabel,
    description: speaking.featuredEngagement.summary,
    kind: copy.talksPage.narrativeVersion
  }
];
---

<BaseLayout
  title={getLocalizedPageTitle(locale, copy.common.links)}
  description={linksPage.page.description}
  image={profile.avatar}
  pathname={Astro.url.pathname}
>
  <section class="page-frame">
    <div class="page-stack">
      <PageHero
        eyebrow={linksPage.page.eyebrow}
        title={linksPage.page.title}
        summary={profile.shortBio}
        titleClass="display-title-sm"
        actions={[
          { href: `mailto:${profile.email}`, label: copy.common.emailJason },
          { href: localizePath("/contact/", locale), label: copy.linksPage.openContactPage, variant: "secondary" }
        ]}
        stats={[
          { label: copy.common.institution, value: profile.institutionShort },
          { label: copy.linksPage.basedIn.replace("{location}", "").trim(), value: profile.location },
          { label: copy.common.research, value: profile.credibility[0] }
        ]}
      />

      <section class="space-y-5" aria-labelledby="links-primary-actions" data-analytics-location="links_primary_actions">
        <SectionIntro title={copy.linksPage.primaryPaths} />
        <div class="grid grid-cols-2 gap-3 lg:grid-cols-3">
          {linksPage.primaryActions.map((item) => (
            <a href={localizePath(item.href, locale)} class="surface-link flex h-full flex-col gap-3 p-4">
              <h3 class="text-base font-semibold sm:text-lg">{item.label}</h3>
              <p class="text-sm leading-6">{item.description}</p>
              <span class="action-link mt-auto">{item.label} →</span>
            </a>
          ))}
        </div>
      </section>

      <section class="section-card" aria-labelledby="links-selected-work" data-analytics-location="links_selected_work">
        <SectionIntro title={copy.linksPage.selectedWorkTitle} copy={copy.linksPage.selectedWorkDescription} />

        <div class="mt-8 grid gap-4">
          {selectedWork.map((item) => (
            <a href={item.href} class="surface-link p-5">
              <p class="muted-label">{item.kind}</p>
              <h3 class="mt-3 text-lg font-semibold">{item.label}</h3>
              <p class="mt-3 text-sm leading-7">{item.description}</p>
            </a>
          ))}
        </div>
      </section>

      <div class="grid gap-6 lg:grid-cols-[1.05fr_0.95fr]">
        <article class="section-card" aria-labelledby="links-profiles" data-analytics-location="links_profiles">
          <SectionIntro title={copy.linksPage.profilesTitle} copy={copy.linksPage.profilesDescription} />

          <div class="mt-8 grid gap-4">
            {linksPage.profileLinks.map((item) => (
              <a href={item.href} target="_blank" rel="noreferrer" class="surface-link p-5">
                <h3 class="text-lg font-semibold">{item.label}</h3>
                <p class="mt-3 text-sm leading-7">{item.description}</p>
              </a>
            ))}
          </div>
        </article>

        <CTASection
          title={linksPage.contact.title}
          copy={profile.contactPrompt}
          actions={[
            { href: `mailto:${profile.email}`, label: linksPage.contact.ctaLabel },
            { href: localizePath("/contact/", locale), label: copy.linksPage.openContactPage, variant: "secondary" }
          ]}
          className="h-full"
        />
      </div>

      <p class="muted-label">{formatMessage(copy.linksPage.lastUpdatedLabel, { date: lastUpdated })}</p>
    </div>
  </section>
</BaseLayout>
