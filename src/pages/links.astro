---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import { linksPage } from "../data/links";
import { profile } from "../data/profile";
import { speaking } from "../data/speaking";
import { formatDate, formatLabel, sortBlogEntries, sortProjects } from "../lib/content";
import { pageTitle } from "../lib/site";

const projects = sortProjects(await getCollection("projects")).filter((entry) => entry.data.featured).slice(0, 3);
const posts = sortBlogEntries(await getCollection("blog"));
const featuredPost = posts.find((post) => post.data.featured) ?? posts[0];
const lastUpdated = formatDate(new Date());

const selectedWork = [
  ...projects.map((project) => ({
    href: `/projects/${project.slug}/`,
    label: project.data.title,
    description: project.data.summary,
    kind: "Project"
  })),
  ...(featuredPost
    ? [
        {
          href: `/blog/${featuredPost.slug}/`,
          label: featuredPost.data.title,
          description: featuredPost.data.description,
          kind: formatLabel(featuredPost.data.category)
        }
      ]
    : []),
  {
    href: speaking.featuredEngagement.storyHref,
    label: speaking.featuredEngagement.storyLabel,
    description: speaking.featuredEngagement.summary,
    kind: "Talk Narrative"
  }
];
---

<BaseLayout
  title={pageTitle("Links")}
  description={linksPage.page.description}
  image={profile.avatar}
  pathname="/links/"
>
  <section class="section pt-12 sm:pt-16">
    <div class="shell space-y-12">
      <div class="max-w-4xl space-y-5">
        <span class="eyebrow">{linksPage.page.eyebrow}</span>
        <div class="space-y-3">
          <h1 class="text-4xl font-semibold tracking-tight text-white sm:text-5xl">{linksPage.page.title}</h1>
          <p class="text-lg leading-8 text-slate-200">{profile.title}</p>
          <p class="max-w-3xl text-base leading-8 text-slate-300">{profile.shortBio}</p>
        </div>
        <div class="flex flex-wrap gap-3">
          <span class="pill">{profile.institutionShort}</span>
          <span class="pill">Based in {profile.location}</span>
          <span class="pill">{profile.credibility[0]}</span>
        </div>
      </div>

      <section class="space-y-5" aria-labelledby="links-primary-actions">
        <h2 id="links-primary-actions" class="text-sm font-semibold uppercase tracking-[0.2em] text-slate-400">
          Primary paths
        </h2>
        <div class="grid grid-cols-2 gap-3 lg:grid-cols-3">
          {linksPage.primaryActions.map((item) => (
            <a
              href={item.href}
              class="panel flex h-full flex-col gap-3 p-4 transition hover:border-white/20 hover:bg-white/[0.06] focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-[var(--color-accent)]"
            >
              <h3 class="text-base font-semibold text-white sm:text-lg">{item.label}</h3>
              <p class="text-sm leading-6 text-slate-300">{item.description}</p>
              <span class="mt-auto text-sm font-semibold text-[var(--color-accent)]">{item.label} →</span>
            </a>
          ))}
        </div>
      </section>

      <section class="panel p-7 sm:p-8" aria-labelledby="links-audience-paths">
        <div class="max-w-3xl space-y-3">
          <h2 id="links-audience-paths" class="text-2xl font-semibold text-white">Quick paths by audience</h2>
          <p class="text-base leading-8 text-slate-300">
            This page is meant to shorten the first routing decision. If you already know why you are here, these are the
            fastest paths into the right part of the site.
          </p>
        </div>

        <div class="mt-8 grid gap-4 md:grid-cols-2">
          {linksPage.audiencePaths.map((item) => (
            <a
              href={item.href}
              class="rounded-3xl border border-white/[0.08] bg-white/[0.03] p-5 transition hover:border-white/20 hover:bg-white/[0.05] focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-[var(--color-accent)]"
            >
              <h3 class="text-lg font-semibold text-white">{item.label}</h3>
              <p class="mt-3 text-sm leading-7 text-slate-300">{item.description}</p>
            </a>
          ))}
        </div>
      </section>

      <section class="panel p-7 sm:p-8" aria-labelledby="links-selected-work">
        <div class="max-w-3xl space-y-3">
          <h2 id="links-selected-work" class="text-2xl font-semibold text-white">Selected work</h2>
          <p class="text-base leading-8 text-slate-300">
            A small set of representative entry points across projects, writing, and talks.
          </p>
        </div>

        <div class="mt-8 grid gap-4">
          {selectedWork.map((item) => (
            <a
              href={item.href}
              class="rounded-3xl border border-white/[0.08] bg-white/[0.03] p-5 transition hover:border-white/20 hover:bg-white/[0.05] focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-[var(--color-accent)]"
              data-plausible-event={item.href === speaking.featuredEngagement.storyHref ? "talk_story_click" : undefined}
            >
              <p class="text-xs uppercase tracking-[0.2em] text-slate-500">{item.kind}</p>
              <h3 class="mt-3 text-lg font-semibold text-white">{item.label}</h3>
              <p class="mt-3 text-sm leading-7 text-slate-300">{item.description}</p>
            </a>
          ))}
        </div>
      </section>

      <section class="grid gap-6 lg:grid-cols-[1.05fr_0.95fr]">
        <article class="panel p-7 sm:p-8" aria-labelledby="links-profiles">
          <div class="max-w-3xl space-y-3">
            <h2 id="links-profiles" class="text-2xl font-semibold text-white">Profiles and credentials</h2>
            <p class="text-base leading-8 text-slate-300">
              External destinations that add institutional context, code visibility, or speaker credentials.
            </p>
          </div>

          <div class="mt-8 grid gap-4">
            {linksPage.profileLinks.map((item) => (
              <a
                href={item.href}
                target="_blank"
                rel="noreferrer"
                class="rounded-3xl border border-white/[0.08] bg-white/[0.03] p-5 transition hover:border-white/20 hover:bg-white/[0.05] focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-[var(--color-accent)]"
                data-plausible-event={"eventName" in item ? item.eventName : undefined}
              >
                <h3 class="text-lg font-semibold text-white">{item.label}</h3>
                <p class="mt-3 text-sm leading-7 text-slate-300">{item.description}</p>
              </a>
            ))}
          </div>
        </article>

        <article class="panel flex flex-col gap-6 p-7 sm:p-8" aria-labelledby="links-contact">
          <div class="space-y-3">
            <h2 id="links-contact" class="text-2xl font-semibold text-white">{linksPage.contact.title}</h2>
            <p class="text-base leading-8 text-slate-300">{profile.contactPrompt}</p>
            <p class="text-sm leading-7 text-slate-400">{linksPage.contact.description}</p>
          </div>

          <div class="rounded-3xl border border-white/[0.08] bg-white/[0.03] p-5">
            <p class="text-xs uppercase tracking-[0.2em] text-slate-500">Email</p>
            <a
              href={`mailto:${profile.email}`}
              class="mt-3 inline-flex text-lg font-semibold text-white transition hover:text-[var(--color-accent-strong)]"
            >
              {profile.email}
            </a>
          </div>

          <div class="flex flex-wrap gap-3">
            <a href={`mailto:${profile.email}`} class="button-primary">{linksPage.contact.ctaLabel}</a>
            <a href="/contact/" class="button-secondary">Open contact page</a>
          </div>

          <p class="mt-auto text-xs uppercase tracking-[0.18em] text-slate-500">Last updated {lastUpdated}</p>
        </article>
      </section>
    </div>
  </section>
</BaseLayout>
