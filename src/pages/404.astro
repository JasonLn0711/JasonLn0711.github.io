---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getLocalizedPageTitle, getLocalizedSite, getPageCopy, localizePath } from "../lib/i18n";

const locale = "en";
const site = getLocalizedSite(locale);
const copy = getPageCopy(locale);
---

<BaseLayout
  title={getLocalizedPageTitle(locale, copy.notFoundPage.title)}
  description={copy.notFoundPage.description}
  pathname="/404.html"
  noindex={true}
>
  <section class="page-frame pt-16">
    <div class="shell">
      <div class="panel max-w-4xl space-y-8 p-8 sm:p-10">
        <span class="eyebrow">404</span>
        <h1 class="text-4xl font-semibold tracking-tight text-white">{copy.notFoundPage.title}</h1>
        <p class="text-base leading-8 text-slate-300">
          {copy.notFoundPage.body}
        </p>
        <div class="page-actions">
          <a href={localizePath("/", locale)} class="button-primary" data-plausible-event="404_recovery_click">{copy.notFoundPage.backHome}</a>
          <a href={localizePath("/projects/", locale)} class="button-secondary" data-plausible-event="404_recovery_click">{copy.notFoundPage.viewProjects}</a>
        </div>

        <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
          {site.nav.map((item) => (
            <a
              href={localizePath(item.href, locale)}
              class="surface-link py-5"
              data-plausible-event="404_recovery_click"
            >
              <span class="block text-sm font-semibold text-white">{item.label}</span>
              <span class="mt-2 block text-sm leading-6 text-slate-400">{item.description}</span>
            </a>
          ))}
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
