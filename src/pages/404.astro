---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHero from "../components/ui/PageHero.astro";
import { getLocalizedPageTitle, getLocalizedSite, getPageCopy, localizePath } from "../lib/i18n";

const locale = "en";
const site = getLocalizedSite(locale);
const copy = getPageCopy(locale);
---

<BaseLayout
  title={getLocalizedPageTitle(locale, copy.notFoundPage.title)}
  description={copy.notFoundPage.description}
  pathname="/404.html"
  noindex={true}
>
  <section class="page-frame pt-16">
    <div class="page-stack">
      <PageHero
        eyebrow="404"
        title={copy.notFoundPage.title}
        summary={copy.notFoundPage.body}
        titleClass="display-title-sm"
        actions={[
          { href: localizePath("/", locale), label: copy.notFoundPage.backHome },
          { href: localizePath("/projects/", locale), label: copy.notFoundPage.viewProjects, variant: "secondary" }
        ]}
      />

      <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3" data-analytics-location="404_recovery_grid">
        {site.nav.map((item) => (
          <a href={localizePath(item.href, locale)} class="surface-link py-5" data-plausible-event="404_recovery" data-analytics-destination={item.href}>
            <span class="block text-sm font-semibold">{item.label}</span>
            <span class="mt-2 block text-sm leading-6">{item.description}</span>
          </a>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
