---
import PageIntro from "../../components/common/PageIntro.astro";
import SectionHeader from "../../components/common/SectionHeader.astro";
import { profile } from "../../data/profile";
import {
  currentResearchThemes,
  ongoingResearchDirections,
  researchApproach,
  selectedQuestions
} from "../../data/research";
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Research"
  description="Research overview for Jason Chia-Sheng Lin, focused on trustworthy AI systems, speech and language pipelines, AI security, and deployment in high-stakes environments."
  pathname="/research/"
>
  <section class="section pt-12 sm:pt-16">
    <div class="shell space-y-12">
      <PageIntro
        eyebrow="Research"
        title="AI systems research centered on trust, deployment, and operational reality."
        description="I care about building AI systems that can actually be trusted in complex environments. That means paying attention not just to capability, but to evidence traceability, workflow fit, security posture, and the realities of how people use systems under pressure."
      />

      <dl class="grid gap-4 md:grid-cols-3">
        {profile.quickFacts.map((fact) => (
          <div class="surface-note">
            <dt class="text-xs uppercase tracking-[0.2em] text-[var(--color-soft)]">{fact.label}</dt>
            <dd class="mt-3 text-base leading-7 text-[var(--color-ink)]">{fact.value}</dd>
          </div>
        ))}
      </dl>

      <section class="space-y-6">
        <SectionHeader
          eyebrow="Current Themes"
          title="The main research areas shaping my doctoral work."
          description="Each theme reflects the same core concern: how to build AI systems that remain useful when trust, governance, and operational reliability matter."
        />
        <div class="grid gap-6 md:grid-cols-2">
          {currentResearchThemes.map((theme) => (
            <article class="panel p-7">
              <h3 class="text-2xl font-semibold text-[var(--color-ink)]">{theme.title}</h3>
              <p class="mt-4 text-sm leading-7 text-[var(--color-muted)]">{theme.body}</p>
            </article>
          ))}
        </div>
      </section>

      <section class="grid gap-8 xl:grid-cols-[0.95fr_1.05fr]">
        <article class="panel p-7 sm:p-8">
          <span class="eyebrow">Selected Questions</span>
          <h2 class="mt-5 text-3xl font-semibold text-[var(--color-ink)]">Questions I care about</h2>
          <ol class="mt-6 space-y-4">
            {selectedQuestions.map((question, index) => (
              <li class="flex gap-4">
                <span class="pill h-fit">{index + 1}</span>
                <p class="text-sm leading-7 text-[var(--color-muted)]">{question}</p>
              </li>
            ))}
          </ol>
        </article>

        <article class="panel p-7 sm:p-8">
          <span class="eyebrow">Ongoing Work</span>
          <h2 class="mt-5 text-3xl font-semibold text-[var(--color-ink)]">Current directions and active lines of inquiry</h2>
          <div class="mt-6 space-y-5">
            {ongoingResearchDirections.map((item) => (
              <div class="border-l border-[var(--color-line)] pl-5">
                <h3 class="text-lg font-semibold text-[var(--color-ink)]">{item.title}</h3>
                <p class="mt-2 text-sm leading-7 text-[var(--color-muted)]">{item.description}</p>
              </div>
            ))}
          </div>
        </article>
      </section>

      <section class="space-y-6">
        <SectionHeader
          eyebrow="Approach"
          title="Research philosophy"
          description="I prefer systems work that stays close to the conditions of real deployment instead of assuming away the hardest parts."
        />
        <div class="grid gap-4 md:grid-cols-3">
          {researchApproach.map((item) => (
            <article class="surface-note">
              <p class="text-sm leading-7 text-[var(--color-muted)]">{item}</p>
            </article>
          ))}
        </div>
      </section>

      <section class="panel-strong flex flex-col gap-5 p-7 sm:p-8 lg:flex-row lg:items-center lg:justify-between">
        <div class="space-y-3">
          <h2 class="text-2xl font-semibold text-[var(--color-ink)]">Interested in the applied side of the work?</h2>
          <p class="max-w-2xl text-base leading-8 text-[var(--color-muted)]">
            The projects page shows how these research questions turn into systems, prototypes, and implementation decisions.
          </p>
        </div>
        <div class="flex flex-wrap gap-3">
          <a href="/projects/" class="button-primary">View projects</a>
          <a href="/contact/" class="button-secondary">Start a conversation</a>
        </div>
      </section>
    </div>
  </section>
</BaseLayout>
