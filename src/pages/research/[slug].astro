---
import UntranslatedNotice from "../../components/layout/UntranslatedNotice.astro";
import CTASection from "../../components/ui/CTASection.astro";
import DetailTOC from "../../components/ui/DetailTOC.astro";
import PageHero from "../../components/ui/PageHero.astro";
import SectionIntro from "../../components/ui/SectionIntro.astro";
import { research } from "../../data/research";
import BaseLayout from "../../layouts/BaseLayout.astro";
import {
  defaultLocale,
  getLocaleFromPathname,
  getLocalizedPageTitle,
  getLocalizedResearch,
  getPageCopy,
  localizePath
} from "../../lib/i18n";
import { breadcrumbSchema } from "../../lib/schema";

export async function getStaticPaths() {
  return research.pillars.map((pillar) => ({
    params: { slug: pillar.slug }
  }));
}

const slug = Astro.params.slug ?? "";
const locale = getLocaleFromPathname(Astro.url.pathname);
const localizedResearch = getLocalizedResearch(locale);
const copy = getPageCopy(locale);
const directionIndex = localizedResearch.pillars.findIndex((pillar) => pillar.slug === slug);

if (directionIndex === -1) {
  throw new Error(`Unknown research direction: ${slug}`);
}

const direction = localizedResearch.pillars[directionIndex];
const previousDirection = localizedResearch.pillars[directionIndex - 1];
const nextDirection = localizedResearch.pillars[directionIndex + 1];
const pageDescription = locale === defaultLocale ? direction.seoDescription : direction.description;
const onThisPageLinks = [
  { href: "#why-now", label: copy.researchDirectionPage.whyNowTitle },
  { href: "#priorities", label: copy.researchDirectionPage.prioritiesTitle },
  { href: "#principles", label: copy.researchDirectionPage.principlesTitle },
  { href: "#human-factors", label: copy.researchDirectionPage.humanFactorsSectionTitle },
  { href: "#evaluation", label: copy.researchDirectionPage.evaluationTitle },
  { href: "#questions", label: copy.researchDirectionPage.questionsTitle },
  { href: "#signals", label: copy.researchDirectionPage.signalsTitle }
];
---

<BaseLayout
  title={getLocalizedPageTitle(locale, direction.title, copy.common.research)}
  description={pageDescription}
  pathname={Astro.url.pathname}
  schema={[
    breadcrumbSchema([
      { name: copy.common.research, pathname: localizePath("/research/", locale) },
      { name: direction.title, pathname: Astro.url.pathname }
    ])
  ]}
>
  <section class="page-frame">
    <div class="page-stack">
      <a href={localizePath("/research/", locale)} class="quiet-link">
        <span aria-hidden="true">←</span>
        {copy.researchDirectionPage.backToResearch}
      </a>

      <PageHero
        eyebrow={copy.researchDirectionPage.directionEyebrow}
        title={direction.title}
        summary={direction.description}
        titleClass="display-title-sm"
        actions={[
          { href: localizePath("/contact/", locale), label: copy.researchDirectionPage.discussDirection },
          { href: localizePath("/projects/", locale), label: copy.researchDirectionPage.browseProjects, variant: "secondary" }
        ]}
        stats={[
          { label: copy.researchDirectionPage.currentThesisTitle, value: direction.thesis },
          { label: copy.researchDirectionPage.yearViewTitle, value: direction.yearPerspective },
          { label: copy.researchDirectionPage.humanFactorsTitle, value: direction.humanFactorsSummary }
        ]}
      />

      <div class="detail-shell">
        <aside class="detail-aside lg:sticky lg:top-28 lg:h-fit">
          <DetailTOC title={copy.common.onThisPage} items={onThisPageLinks} />

          <div class="toc-card">
            <p class="muted-label">{copy.researchDirectionPage.focusTagsTitle}</p>
            <div class="mt-4 flex flex-wrap gap-2">
              {direction.tags.map((tag) => <span class="pill">{tag}</span>)}
            </div>
          </div>

          <div class="toc-card">
            <p class="muted-label">{copy.common.bestNextSteps}</p>
            <p class="mt-3 text-sm leading-7">{localizedResearch.collaboration.description}</p>
            <div class="mt-4 page-actions" data-analytics-location="research_direction_sidebar">
              <a href={localizePath("/contact/", locale)} class="button-primary">{copy.researchDirectionPage.discussDirection}</a>
              <a href={localizePath("/research/", locale)} class="button-secondary">{copy.researchDirectionPage.allDirections}</a>
            </div>
          </div>
        </aside>

        <article class="space-y-6 min-w-0">
          {locale !== "en" && <UntranslatedNotice locale={locale} kind="research" />}

          <section id="why-now" class="section-card scroll-mt-28">
            <SectionIntro title={copy.researchDirectionPage.whyNowTitle} />
            <p class="mt-5 text-base leading-8">{direction.whyNow}</p>
          </section>

          <section id="priorities" class="section-card scroll-mt-28">
            <SectionIntro title={copy.researchDirectionPage.prioritiesTitle} />
            <ul class="mt-6 compact-list">
              {direction.currentPriorities.map((item) => <li class="text-base leading-7">{item}</li>)}
            </ul>
          </section>

          <section id="principles" class="section-card scroll-mt-28">
            <SectionIntro title={copy.researchDirectionPage.principlesTitle} />
            <div class="mt-6 grid gap-4 sm:grid-cols-2">
              {direction.systemPrinciples.map((item) => (
                <article class="surface-card">
                  <h3 class="text-lg font-semibold">{item.title}</h3>
                  <p class="mt-3 text-sm leading-7">{item.description}</p>
                </article>
              ))}
            </div>
          </section>

          <section id="human-factors" class="section-card scroll-mt-28">
            <SectionIntro title={copy.researchDirectionPage.humanFactorsSectionTitle} />
            <ul class="mt-6 compact-list">
              {direction.humanFactors.map((item) => <li class="text-base leading-7">{item}</li>)}
            </ul>
          </section>

          <section id="evaluation" class="section-card scroll-mt-28">
            <SectionIntro title={copy.researchDirectionPage.evaluationTitle} />
            <div class="mt-6 grid gap-4 sm:grid-cols-2">
              {direction.evaluationAgenda.map((item) => (
                <article class="surface-card">
                  <h3 class="text-lg font-semibold">{item.title}</h3>
                  <p class="mt-3 text-sm leading-7">{item.description}</p>
                </article>
              ))}
            </div>
          </section>

          <section id="questions" class="section-card scroll-mt-28">
            <SectionIntro title={copy.researchDirectionPage.questionsTitle} />
            <ul class="mt-6 compact-list">
              {direction.questions.map((item) => <li class="text-base leading-7">{item}</li>)}
            </ul>
          </section>

          <section id="signals" class="section-card scroll-mt-28">
            <SectionIntro title={copy.researchDirectionPage.signalsTitle} />
            <div class="mt-6 grid gap-4 xl:grid-cols-2">
              {direction.signals.map((signal) => (
                <a href={signal.url} target="_blank" rel="noreferrer" class="surface-link block">
                  <h3 class="text-lg font-semibold">{signal.label}</h3>
                  <p class="mt-3 text-sm leading-7">{signal.note}</p>
                </a>
              ))}
            </div>
          </section>

          <CTASection
            title={localizedResearch.collaboration.title}
            copy={localizedResearch.collaboration.description}
            actions={[
              { href: localizePath("/projects/", locale), label: copy.researchDirectionPage.browseProjects, variant: "secondary" },
              { href: localizePath("/contact/", locale), label: copy.researchDirectionPage.discussDirection }
            ]}
          />
        </article>
      </div>

      <div class="grid gap-4 sm:grid-cols-2" data-analytics-location="research_direction_pagination">
        {previousDirection ? (
          <a href={localizePath(`/research/${previousDirection.slug}/`, locale)} class="surface-link block p-6">
            <p class="muted-label">{copy.researchDirectionPage.previousDirection}</p>
            <p class="mt-3 text-lg font-semibold">{previousDirection.title}</p>
          </a>
        ) : (
          <a href={localizePath("/research/", locale)} class="surface-link block p-6">
            <p class="muted-label">{copy.common.browse}</p>
            <p class="mt-3 text-lg font-semibold">{copy.researchDirectionPage.allDirections}</p>
          </a>
        )}

        {nextDirection ? (
          <a href={localizePath(`/research/${nextDirection.slug}/`, locale)} class="surface-link block p-6 text-left sm:text-right">
            <p class="muted-label">{copy.researchDirectionPage.nextDirection}</p>
            <p class="mt-3 text-lg font-semibold">{nextDirection.title}</p>
          </a>
        ) : (
          <a href={localizePath("/projects/", locale)} class="surface-link block p-6 text-left sm:text-right">
            <p class="muted-label">{copy.common.projects}</p>
            <p class="mt-3 text-lg font-semibold">{copy.researchDirectionPage.browseProjects}</p>
          </a>
        )}
      </div>
    </div>
  </section>
</BaseLayout>
