---
import { getCollection } from "astro:content";
import { profile } from "../data/profile";
import { speaking } from "../data/speaking";
import BaseLayout from "../layouts/BaseLayout.astro";
import { sortBlogEntries, sortProjects } from "../lib/content";
import { pageTitle } from "../lib/site";

const projects = sortProjects(await getCollection("projects")).filter((entry) => entry.data.featured).slice(0, 3);
const posts = sortBlogEntries(await getCollection("blog")).slice(0, 2);

const professionalStrengths = [
  {
    title: "Research-grounded systems thinking",
    description:
      "Works across models, pipelines, runtime assumptions, and operational constraints rather than treating AI work as an isolated modeling problem."
  },
  {
    title: "Security-aware technical judgment",
    description:
      "Brings threat modeling, privacy, leakage risk, and deployment realism into system design for environments where failure has real cost."
  },
  {
    title: "Clear communication for mixed audiences",
    description:
      "Turns technical work into talks, case studies, and structured writing that hiring managers, researchers, and technical collaborators can inspect quickly."
  }
];

const teamSignals = [
  "Interdisciplinary profile spanning doctoral research, systems building, and investigation-informed reasoning.",
  "Comfortable in research, engineering-adjacent, and technically cross-functional conversations.",
  "Public work includes an official CYBERSEC 2026 session and two English CISC 2025 conference papers."
];

const resumeMetrics = [
  {
    label: "Current role",
    value: "Doctoral researcher at NYCU"
  },
  {
    label: "Base",
    value: profile.lab.name
  },
  {
    label: "Primary focus",
    value: "Trustworthy AI, speech intelligence, and cybersecurity"
  },
  {
    label: "Recent public signals",
    value: `1 official session + ${speaking.additionalEngagements.length} English conference papers`
  }
];
---

<BaseLayout
  title={pageTitle("Resume")}
  description="A professional resume page summarizing Jason Chia-Sheng Lin's current role, strengths, experience, selected work, and public research signals for hiring and collaboration review."
  image={profile.avatar}
  pathname="/resume/"
>
  <section class="section pt-12 sm:pt-16">
    <div class="shell space-y-12">
      <div class="grid gap-8 xl:grid-cols-[minmax(0,1fr)_340px] xl:items-start">
        <div class="max-w-4xl space-y-6">
          <span class="eyebrow">Resume</span>
          <div class="space-y-5">
            <h1 class="text-4xl font-semibold tracking-tight text-white sm:text-5xl">
              Professional profile for research, AI systems, and security-aware technical work.
            </h1>
            <p class="text-lg leading-8 text-slate-300">
              {profile.name} is a doctoral researcher at {profile.institution} whose work connects trustworthy AI, speech
              intelligence, cybersecurity, and deployment-ready system design. This page is designed for hiring managers,
              technical leaders, collaborators, and organizers who want a concise, professional overview.
            </p>
          </div>

          <div class="flex flex-wrap gap-3">
            <a href={`mailto:${profile.email}`} class="button-primary">Email Jason</a>
            <a href={profile.linkedin} target="_blank" rel="noreferrer" class="button-secondary">
              LinkedIn
            </a>
            <a href="/projects/" class="button-secondary">Selected projects</a>
            <a href="/about/" class="button-secondary">About</a>
          </div>
        </div>

        <aside class="panel overflow-hidden p-6 sm:p-7">
          <div class="space-y-6">
            <div class="overflow-hidden rounded-3xl border border-white/[0.08]">
              <img
                src={profile.avatar}
                alt={`Portrait of ${profile.name}`}
                width="1693"
                height="2540"
                class="aspect-[4/5] w-full object-cover object-[center_32%]"
              />
            </div>

            <div class="space-y-3">
              <div>
                <p class="text-xs uppercase tracking-[0.18em] text-slate-500">Name</p>
                <p class="mt-2 text-xl font-semibold text-white">{profile.name}</p>
              </div>
              <div>
                <p class="text-xs uppercase tracking-[0.18em] text-slate-500">Current position</p>
                <p class="mt-2 text-sm leading-7 text-slate-300">{profile.title}</p>
              </div>
              <div>
                <p class="text-xs uppercase tracking-[0.18em] text-slate-500">Institution</p>
                <p class="mt-2 text-sm leading-7 text-slate-300">{profile.institution}</p>
              </div>
              <div>
                <p class="text-xs uppercase tracking-[0.18em] text-slate-500">Location</p>
                <p class="mt-2 text-sm leading-7 text-slate-300">{profile.location}</p>
              </div>
            </div>
          </div>
        </aside>
      </div>

      <dl class="grid gap-4 sm:grid-cols-2 xl:grid-cols-4">
        {resumeMetrics.map((item) => (
          <div class="panel p-6">
            <dt class="text-xs uppercase tracking-[0.2em] text-slate-500">{item.label}</dt>
            <dd class="mt-3 text-base leading-7 text-slate-200">{item.value}</dd>
          </div>
        ))}
      </dl>

      <div class="grid gap-8 xl:grid-cols-[1.1fr_0.9fr]">
        <section class="panel p-7 sm:p-8">
          <h2 class="text-2xl font-semibold text-white">Professional Summary</h2>
          <div class="mt-6 space-y-5">
            <p class="text-base leading-8 text-slate-300">
              {profile.shortBio}
            </p>
            <p class="text-base leading-8 text-slate-300">
              Before doctoral research, Jason worked in cybercrime investigation. That background continues to shape a
              practical approach to evidence, adversarial behavior, traceability, and the gap between a model that looks
              good in isolation and a system that remains trustworthy in real-world use.
            </p>
            <p class="text-base leading-8 text-slate-300">
              Current work spans speech and language pipelines, trustworthy AI evaluation, medical AI cybersecurity, and
              deployment-minded AI system design in environments where reviewability and operational constraints matter.
            </p>
          </div>
        </section>

        <section class="panel p-7 sm:p-8">
          <h2 class="text-2xl font-semibold text-white">What Jason Brings to a Team</h2>
          <div class="mt-6 grid gap-4">
            {professionalStrengths.map((item) => (
              <div class="rounded-3xl border border-white/[0.08] bg-white/[0.03] p-5">
                <h3 class="text-lg font-semibold text-white">{item.title}</h3>
                <p class="mt-2 text-sm leading-7 text-slate-300">{item.description}</p>
              </div>
            ))}
          </div>
        </section>
      </div>

      <div class="grid gap-8 xl:grid-cols-[0.95fr_1.05fr]">
        <section class="panel p-7 sm:p-8">
          <h2 class="text-2xl font-semibold text-white">Professional Experience</h2>
          <div class="mt-6 space-y-6">
            {profile.experience.map((item) => (
              <div class="border-l border-white/10 pl-5">
                <p class="text-xs uppercase tracking-[0.2em] text-slate-500">{item.period}</p>
                <h3 class="mt-2 text-lg font-semibold text-white">{item.title}</h3>
                <p class="mt-2 text-sm leading-7 text-slate-300">{item.detail}</p>
              </div>
            ))}
          </div>
        </section>

        <section class="panel p-7 sm:p-8">
          <h2 class="text-2xl font-semibold text-white">Current Areas of Work</h2>
          <div class="mt-6 grid gap-4">
            {profile.interests.map((item) => (
              <div class="rounded-3xl border border-white/[0.08] bg-white/[0.03] p-5">
                <p class="text-base leading-7 text-slate-300">{item}</p>
              </div>
            ))}
          </div>
        </section>
      </div>

      <section class="space-y-6">
        <div class="flex flex-col gap-4 md:flex-row md:items-end md:justify-between">
          <div class="max-w-3xl">
            <span class="eyebrow">Selected Work</span>
            <h2 class="section-title">Representative projects that show applied systems thinking.</h2>
            <p class="section-copy">
              These case studies show how Jason frames problems, builds systems, and explains technical choices in ways
              that are inspectable by both technical and cross-functional readers.
            </p>
          </div>
          <a href="/projects/" class="button-secondary">Browse all projects</a>
        </div>

        <div class="grid gap-6 xl:grid-cols-3">
          {projects.map((project) => (
            <article class="panel flex h-full flex-col p-6 sm:p-7">
              <div class="flex flex-wrap items-center gap-3 text-xs uppercase tracking-[0.2em] text-slate-400">
                <span>{project.data.category}</span>
                <span class="h-1 w-1 rounded-full bg-white/20"></span>
                <span>{project.data.year}</span>
                <span class="h-1 w-1 rounded-full bg-white/20"></span>
                <span>{project.data.status}</span>
              </div>
              <h3 class="mt-4 text-2xl font-semibold tracking-tight text-white">{project.data.title}</h3>
              <p class="mt-3 text-sm leading-7 text-slate-300">{project.data.summary}</p>
              <div class="mt-5 flex flex-wrap gap-2">
                {project.data.stack.slice(0, 5).map((item) => <span class="pill">{item}</span>)}
              </div>
              <div class="mt-auto pt-6">
                <a href={`/projects/${project.slug}/`} class="action-link">
                  Open case study
                  <span aria-hidden="true">→</span>
                </a>
              </div>
            </article>
          ))}
        </div>
      </section>

      <div class="grid gap-8 xl:grid-cols-2">
        <section class="panel p-7 sm:p-8">
          <h2 class="text-2xl font-semibold text-white">Speaking and Publication Signals</h2>
          <div class="mt-6 space-y-5">
            <div class="rounded-3xl border border-[var(--color-accent)]/20 bg-[color:rgba(99,164,255,0.1)] p-5">
              <p class="text-xs uppercase tracking-[0.2em] text-slate-500">{speaking.featuredEngagement.event}</p>
              <h3 class="mt-2 text-lg font-semibold text-white">{speaking.featuredEngagement.title}</h3>
              <p class="mt-2 text-sm leading-7 text-slate-300">{speaking.featuredEngagement.summary}</p>
              <div class="mt-4 flex flex-wrap gap-3">
                <a href="/talks/" class="button-secondary">Talks page</a>
                <a href={profile.externalProfiles.cybersecSpeaker.url} target="_blank" rel="noreferrer" class="button-secondary">
                  Speaker profile
                </a>
              </div>
            </div>

            {speaking.additionalEngagements.map((engagement) => (
              <div class="rounded-3xl border border-white/[0.08] bg-white/[0.03] p-5">
                <p class="text-xs uppercase tracking-[0.2em] text-slate-500">
                  {engagement.event} · {engagement.format}
                </p>
                <h3 class="mt-2 text-lg font-semibold text-white">{engagement.title}</h3>
                <p class="mt-2 text-sm leading-7 text-slate-300">{engagement.summary}</p>
              </div>
            ))}
          </div>
        </section>

        <section class="panel p-7 sm:p-8">
          <h2 class="text-2xl font-semibold text-white">Writing and Technical Communication</h2>
          <div class="mt-6 space-y-5">
            {posts.map((post) => (
              <article class="rounded-3xl border border-white/[0.08] bg-white/[0.03] p-5">
                <p class="text-xs uppercase tracking-[0.2em] text-slate-500">{post.data.category}</p>
                <h3 class="mt-2 text-lg font-semibold text-white">{post.data.title}</h3>
                <p class="mt-2 text-sm leading-7 text-slate-300">{post.data.description}</p>
                <div class="mt-4">
                  <a href={`/blog/${post.slug}/`} class="action-link">
                    Read article
                    <span aria-hidden="true">→</span>
                  </a>
                </div>
              </article>
            ))}

            <div class="rounded-3xl border border-white/[0.08] bg-white/[0.03] p-5">
              <p class="text-xs uppercase tracking-[0.2em] text-slate-500">Professional signals</p>
              <ul class="mt-4 space-y-4">
                {teamSignals.map((item) => <li class="text-sm leading-7 text-slate-300">{item}</li>)}
              </ul>
            </div>
          </div>
        </section>
      </div>

      <div class="grid gap-8 xl:grid-cols-[0.92fr_1.08fr]">
        <section class="panel p-7 sm:p-8">
          <h2 class="text-2xl font-semibold text-white">Methods and Technical Toolkit</h2>
          <div class="mt-6 grid gap-5">
            {profile.toolkit.map((group) => (
              <div class="rounded-3xl border border-white/[0.08] bg-white/[0.03] p-5">
                <h3 class="text-lg font-semibold text-white">{group.title}</h3>
                <div class="mt-4 flex flex-wrap gap-2">
                  {group.items.map((item) => <span class="pill">{item}</span>)}
                </div>
              </div>
            ))}
          </div>
        </section>

        <section class="panel flex flex-col gap-6 p-7 sm:p-8">
          <div class="space-y-3">
            <h2 class="text-2xl font-semibold text-white">Open to the Following Conversations</h2>
            <p class="max-w-2xl text-base leading-8 text-slate-300">
              The strongest fit is with teams, labs, or organizers working near trustworthy AI, speech and language
              systems, deployment-sensitive workflows, or cybersecurity-minded system design.
            </p>
          </div>

          <div class="grid gap-3 sm:grid-cols-3">
            {profile.contactTopics.map((topic) => (
              <div class="rounded-3xl border border-white/[0.08] bg-white/[0.03] p-4">
                <p class="text-sm leading-7 text-slate-300">{topic}</p>
              </div>
            ))}
          </div>

          <div class="rounded-3xl border border-white/[0.08] bg-white/[0.03] p-5">
            <p class="text-xs uppercase tracking-[0.2em] text-slate-500">Contact</p>
            <p class="mt-3 text-base leading-8 text-slate-300">
              Email is the best route for hiring conversations, research collaboration, speaking invitations, and
              technically specific discussion.
            </p>
          </div>

          <div class="mt-auto flex flex-wrap gap-3">
            <a href={`mailto:${profile.email}`} class="button-primary">Email Jason</a>
            <a href="/contact/" class="button-secondary">Contact page</a>
            <a href={profile.github} target="_blank" rel="noreferrer" class="button-secondary">
              GitHub
            </a>
          </div>
        </section>
      </div>
    </div>
  </section>
</BaseLayout>
