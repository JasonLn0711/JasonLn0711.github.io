---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import ProjectCard from "../components/project/ProjectCard.astro";
import CTASection from "../components/ui/CTASection.astro";
import MediaFrame from "../components/ui/MediaFrame.astro";
import PageHero from "../components/ui/PageHero.astro";
import SectionIntro from "../components/ui/SectionIntro.astro";
import { getBlogPath, getLocalizedBlogEntries, sortProjects } from "../lib/content";
import {
  formatMessage,
  getLocaleFromPathname,
  getLocalizedPageTitle,
  getLocalizedProfile,
  getLocalizedSpeaking,
  getPageCopy,
  localizePath
} from "../lib/i18n";

const locale = getLocaleFromPathname(Astro.url.pathname);
const profile = getLocalizedProfile(locale);
const speaking = getLocalizedSpeaking(locale);
const copy = getPageCopy(locale);
const projects = sortProjects(await getCollection("projects")).filter((entry) => entry.data.featured).slice(0, 3);
const posts = getLocalizedBlogEntries(await getCollection("blog"), locale).slice(0, 2);
const professionalStrengths = copy.resumePage.professionalStrengths;
const teamSignals = copy.resumePage.teamSignals;
const resumeMetrics = copy.resumePage.metrics.map((item) => ({
  label: item.label,
  value: formatMessage(item.value, {
    lab: profile.lab.name,
    count: speaking.additionalEngagements.length
  })
}));
---

<BaseLayout
  title={getLocalizedPageTitle(locale, copy.common.resume)}
  description={copy.resumePage.description}
  image={profile.avatar}
  pathname={Astro.url.pathname}
>
  <section class="page-frame">
    <div class="page-stack">
      <PageHero
        eyebrow={copy.common.resume}
        title={copy.resumePage.title}
        summary={formatMessage(copy.resumePage.intro, {
          name: profile.name,
          institution: profile.institution
        })}
        split={true}
        titleClass="display-title-sm"
        actions={[
          { href: `mailto:${profile.email}`, label: copy.common.emailJason },
          { href: profile.linkedin, label: "LinkedIn", variant: "secondary", external: true },
          { href: localizePath("/projects/", locale), label: copy.resumePage.selectedProjects, variant: "secondary" }
        ]}
      >
        <MediaFrame
          slot="media"
          src={profile.avatar}
          alt={`Portrait of ${profile.name}`}
          width="1693"
          height="2540"
          imageClass="aspect-[4/5] w-full object-cover object-[center_24%]"
        />
      </PageHero>

      <div class="grid gap-4 sm:grid-cols-2 xl:grid-cols-4">
        {resumeMetrics.map((item) => (
          <div class="surface-card">
            <p class="muted-label">{item.label}</p>
            <p class="mt-3 text-base leading-7 text-[var(--color-charcoal)]">{item.value}</p>
          </div>
        ))}
      </div>

      <div class="grid gap-8 xl:grid-cols-[1.05fr_0.95fr]">
        <section class="section-card">
          <SectionIntro title={copy.resumePage.professionalSummary} />
          <div class="mt-6 space-y-5">
            <p class="text-base leading-8">{profile.shortBio}</p>
            <p class="text-base leading-8">{copy.resumePage.summaryParagraphTwo}</p>
            <p class="text-base leading-8">{copy.resumePage.summaryParagraphThree}</p>
          </div>
        </section>

        <section class="section-card">
          <SectionIntro title={copy.resumePage.whatBrings} />
          <div class="mt-6 grid gap-4">
            {professionalStrengths.map((item) => (
              <div class="surface-card">
                <h3 class="text-lg font-semibold">{item.title}</h3>
                <p class="mt-2 text-sm leading-7">{item.description}</p>
              </div>
            ))}
          </div>
        </section>
      </div>

      <div class="grid gap-8 xl:grid-cols-[0.95fr_1.05fr]">
        <section class="section-card">
          <SectionIntro title={copy.resumePage.experience} />
          <div class="mt-6 space-y-6">
            {profile.experience.map((item) => (
              <div class="border-l border-[rgba(31,27,23,0.12)] pl-5">
                <p class="muted-label">{item.period}</p>
                <h3 class="mt-2 text-lg font-semibold">{item.title}</h3>
                <p class="mt-2 text-sm leading-7">{item.detail}</p>
              </div>
            ))}
          </div>
        </section>

        <section class="section-card">
          <SectionIntro title={copy.resumePage.currentWork} />
          <div class="mt-6 grid gap-4">
            {profile.interests.map((item) => (
              <div class="surface-card">
                <p class="text-base leading-7">{item}</p>
              </div>
            ))}
          </div>
        </section>
      </div>

      <section class="space-y-6">
        <SectionIntro
          eyebrow={copy.resumePage.selectedWorkEyebrow}
          title={copy.resumePage.selectedWorkTitle}
          copy={copy.resumePage.selectedWorkDescription}
        >
          <Fragment slot="actions">
            <a href={localizePath("/projects/", locale)} class="button-secondary">{copy.resumePage.browseAllProjects}</a>
          </Fragment>
        </SectionIntro>

        <div class="grid gap-6 xl:grid-cols-3">
          {projects.map((project) => <ProjectCard project={project} analyticsLocation="resume_selected_projects" locale={locale} />)}
        </div>
      </section>

      <div class="grid gap-8 xl:grid-cols-2">
        <section class="section-card">
          <SectionIntro title={copy.resumePage.speakingSignals} />
          <div class="mt-6 space-y-5">
            <div class="surface-card">
              <p class="muted-label">{speaking.featuredEngagement.event}</p>
              <h3 class="mt-2 text-lg font-semibold">{speaking.featuredEngagement.title}</h3>
              <p class="mt-2 text-sm leading-7">{speaking.featuredEngagement.summary}</p>
              <div class="page-actions mt-4">
                <a href={localizePath("/talks/", locale)} class="button-secondary">{copy.resumePage.talksPage}</a>
                <a href={profile.externalProfiles.cybersecSpeaker.url} target="_blank" rel="noreferrer" class="button-secondary">
                  {copy.resumePage.speakerProfile}
                </a>
              </div>
            </div>

            {speaking.additionalEngagements.map((engagement) => (
              <div class="surface-card">
                <p class="muted-label">{engagement.event}</p>
                <h3 class="mt-2 text-lg font-semibold">{engagement.title}</h3>
                <p class="mt-2 text-sm leading-7">{engagement.summary}</p>
              </div>
            ))}
          </div>
        </section>

        <section class="section-card">
          <SectionIntro title={copy.resumePage.writingCommunication} />
          <div class="mt-6 space-y-5">
            {posts.map((post) => (
              <article class="surface-card">
                <p class="muted-label">{post.data.category}</p>
                <h3 class="mt-2 text-lg font-semibold">{post.data.title}</h3>
                <p class="mt-2 text-sm leading-7">{post.data.description}</p>
                <div class="mt-4">
                  <a href={getBlogPath(post, locale)} class="action-link">
                    {copy.common.readArticle}
                    <span aria-hidden="true">→</span>
                  </a>
                </div>
              </article>
            ))}

            <div class="surface-card">
              <p class="muted-label">{copy.resumePage.professionalSignals}</p>
              <ul class="mt-4 compact-list">
                {teamSignals.map((item) => <li class="text-sm leading-7">{item}</li>)}
              </ul>
            </div>
          </div>
        </section>
      </div>

      <section class="grid gap-8 xl:grid-cols-[0.92fr_1.08fr]">
        <div class="section-card">
          <SectionIntro title={copy.resumePage.methodsAndToolkit} />
          <div class="mt-6 grid gap-5">
            {profile.toolkit.map((group) => (
              <div class="surface-card">
                <h3 class="text-lg font-semibold">{group.title}</h3>
                <div class="mt-4 flex flex-wrap gap-2">
                  {group.items.map((item) => <span class="pill">{item}</span>)}
                </div>
              </div>
            ))}
          </div>
        </div>

        <CTASection
          title={copy.resumePage.openToConversations}
          copy={copy.resumePage.openToConversationsDescription}
          actions={[
            { href: `mailto:${profile.email}`, label: copy.common.emailJason },
            { href: localizePath("/contact/", locale), label: copy.resumePage.contactPage, variant: "secondary" },
            { href: profile.github, label: "GitHub", variant: "secondary", external: true }
          ]}
        />
      </section>
    </div>
  </section>
</BaseLayout>
