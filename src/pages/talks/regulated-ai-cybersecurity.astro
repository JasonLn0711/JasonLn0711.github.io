            {talkStory.trustChain.map((item, index) => (
              <Fragment>
                {index > 0 && <div class="hidden justify-center text-2xl text-[var(--color-accent)] lg:flex" aria-hidden="true">→</div>}
                <div class="rounded-3xl border border-white/[0.08] bg-white/[0.03] p-5 text-left">
                  <p class="text-xs uppercase tracking-[0.18em] text-slate-500">Trust chain</p>
                  <p class="mt-3 text-lg font-semibold text-white">{item}</p>
                </div>
              </Fragment>
            ))}
          </div>
        </TalkStorySection>

        <TalkStorySection
          id={storySections[12].id}
          chapter={storySections[12].chapter}
          navLabel={storySections[12].navLabel}
          title="LeakPro: test the model before you share it"
          intro="Leakage testing should happen before a model crosses organizational boundaries."
        >
          <Fragment slot="visual">
            <div class="rounded-[1.75rem] border border-white/[0.08] bg-gradient-to-br from-white/[0.06] via-white/[0.03] to-transparent p-5">
              <div class="grid gap-4 lg:grid-cols-[1fr_auto_1fr] lg:items-center">
                <div class="rounded-3xl border border-white/[0.08] bg-white/[0.03] p-6">
                  <p class="text-xs uppercase tracking-[0.18em] text-slate-500">Before sharing</p>
                  <p class="mt-3 text-lg font-semibold text-white">Model ready for release?</p>
                </div>

                <div class="hidden justify-center text-2xl text-[var(--color-accent)] lg:flex" aria-hidden="true">→</div>

                <div class="rounded-3xl border border-[var(--color-accent)]/20 bg-[color:rgba(102,117,101,0.1)] p-6">
                  <p class="text-xs uppercase tracking-[0.18em] text-slate-500">Validation gate</p>
                  <p class="mt-3 text-lg font-semibold text-white">Ask whether it leaks, not only whether it is accurate.</p>
                </div>
              </div>

              <div class="mt-4 flex flex-wrap gap-2">
                {talkStory.leakProLabels.map((label) => <span class="pill">{label}</span>)}
              </div>
            </div>
          </Fragment>

          <p class="text-base leading-8 text-slate-300">
            Pre-release leakage assessment provides evidence for governance, model sharing, and internal review. It turns privacy risk into something testable instead of assumed.
          </p>
        </TalkStorySection>

        <TalkStorySection
          id={storySections[13].id}
          chapter={storySections[13].chapter}
          navLabel={storySections[13].navLabel}
          title="The Future Question for Medical AI"
          intro="Medical AI is governed across time, not just at launch."
        >
          <Fragment slot="visual">
            <div class="rounded-[1.75rem] border border-white/[0.08] bg-gradient-to-br from-[color:rgba(102,117,101,0.12)] via-white/[0.04] to-transparent p-5">
              <div class="grid gap-3 md:grid-cols-3">
                {talkStory.lifecycleLabels.map((label, index) => (
                  <div class="rounded-3xl border border-white/[0.08] bg-white/[0.03] p-4">
                    <p class="text-xs uppercase tracking-[0.18em] text-slate-500">Stage {index + 1}</p>
                    <p class="mt-3 text-base font-semibold text-white">{label}</p>
                  </div>
                ))}
              </div>
            </div>
          </Fragment>

          <div class="rounded-3xl border border-white/[0.08] bg-white/[0.03] p-6">
            <p class="text-2xl font-semibold tracking-tight text-white">
              How do we govern systems that keep changing?
            </p>
          </div>
        </TalkStorySection>

        <TalkStorySection
          id={storySections[14].id}
          chapter={storySections[14].chapter}
          navLabel={storySections[14].navLabel}
          title="Embedding security into the SaMD DNA"
          intro="Threat modeling connects abstract architecture to concrete design and review decisions."
        >
          <Fragment slot="visual">
            <div class="rounded-[1.75rem] border border-white/[0.08] bg-gradient-to-br from-white/[0.06] via-white/[0.03] to-transparent p-5">
              <div class="rounded-[1.5rem] border border-dashed border-white/[0.18] p-4">
                <div class="rounded-3xl border border-white/[0.08] bg-white/[0.03] p-5">
                  <p class="text-xs uppercase tracking-[0.18em] text-slate-500">Threat model frame</p>
                  <p class="mt-3 text-lg font-semibold text-white">Architecture becomes control points.</p>
                </div>

                <div class="mt-4 grid gap-3 sm:grid-cols-2">
                  {talkStory.threatModelLabels.map((label) => (
                    <div class="rounded-3xl border border-white/[0.08] bg-white/[0.03] p-4">
                      <p class="text-sm font-semibold text-white">{label}</p>
                    </div>
                  ))}
                </div>
              </div>
            </div>
          </Fragment>
        </TalkStorySection>

        <TalkStorySection
          id={storySections[15].id}
          chapter={storySections[15].chapter}
          navLabel={storySections[15].navLabel}
          title="The 'Default-Deny' clinical environment"
          intro="A clinical environment benefits from explicit trust boundaries and permitted paths only."
        >
          <Fragment slot="visual">
            <div class="rounded-[1.75rem] border border-white/[0.08] bg-gradient-to-br from-[color:rgba(102,117,101,0.12)] via-white/[0.04] to-transparent p-5">
              <div class="grid gap-3 md:grid-cols-2 lg:grid-cols-[1fr_auto_1fr_auto_1fr_auto_1fr] lg:items-center xl:grid-cols-2 xl:items-stretch">
                {talkStory.clinicalZones.map((zone, index) => (
                  <Fragment>
                    {index > 0 && <div class="hidden justify-center text-2xl text-[var(--color-accent)] lg:flex xl:hidden" aria-hidden="true">→</div>}
                    <div class="min-w-0 rounded-3xl border border-white/[0.08] bg-white/[0.03] p-4">
                      <p class="text-xs uppercase tracking-[0.18em] text-slate-500">Zone</p>
                      <p class="mt-3 text-base font-semibold text-white">{zone}</p>
                    </div>
                  </Fragment>
                ))}
              </div>

              <div class="mt-4 rounded-3xl border border-[var(--color-accent)]/20 bg-[color:rgba(102,117,101,0.1)] p-5">
                <p class="text-xs uppercase tracking-[0.18em] text-slate-500">Policy</p>
                <p class="mt-3 text-lg font-semibold text-white">{talkStory.clinicalPolicy}</p>
              </div>
            </div>
          </Fragment>

          <p class="text-base leading-8 text-slate-300">
            Inside the hospital is not the same as trusted. A clinical architecture should restrict movement by default, make exceptions explicit, and treat vendor or integration access as bounded paths rather than ambient trust.
          </p>
        </TalkStorySection>

        <TalkStorySection
          id={storySections[16].id}
          chapter={storySections[16].chapter}
          navLabel={storySections[16].navLabel}
          title="Balancing clinical stability with cybersecurity responsiveness"
          intro="Security response has to respect both exploit urgency and validation reality."
        >
          <Fragment slot="visual">
            <div class="rounded-[1.75rem] border border-white/[0.08] bg-gradient-to-br from-white/[0.06] via-white/[0.03] to-transparent p-5">
              <div class="grid gap-4 lg:grid-cols-[1fr_1fr] xl:grid-cols-1">
                <div class="grid gap-3 sm:grid-cols-2">
                  {talkStory.patchInputs.map((item) => (
                    <div class="min-w-0 rounded-3xl border border-white/[0.08] bg-white/[0.03] p-4">
                      <p class="text-sm font-semibold text-white">{item}</p>
                    </div>
                  ))}
                </div>

                <div class="rounded-3xl border border-[var(--color-accent)]/20 bg-[color:rgba(102,117,101,0.1)] p-6">
                  <p class="text-xs uppercase tracking-[0.18em] text-slate-500">Decision principle</p>
                  <p class="mt-3 text-2xl font-semibold tracking-tight text-white">
                    The right patch decision is not the fastest one. It is the most controllable one.
                  </p>
                </div>
              </div>
            </div>
          </Fragment>
        </TalkStorySection>

        <TalkStorySection
          id={storySections[17].id}
          chapter={storySections[17].chapter}
          navLabel={storySections[17].navLabel}
          title="Patient safety supersedes cybersecurity speed."
          intro="Clinical systems are allowed to move carefully when patient harm is on the line."
          variant="center"
        >
          <div class="rounded-3xl border border-white/[0.08] bg-white/[0.03] p-8">
            <p class="mx-auto max-w-2xl text-4xl font-semibold tracking-tight text-white sm:text-5xl">
              Patient safety
              <span class="block text-slate-300">supersedes</span>
              cybersecurity speed.
            </p>
            <p class="mx-auto mt-5 max-w-2xl text-base leading-8 text-slate-300">
              In clinical environments, patching must be fast enough, but also safe enough to trust.
            </p>
          </div>
        </TalkStorySection>

        <TalkStorySection
          id={storySections[18].id}
          chapter={storySections[18].chapter}
          navLabel={storySections[18].navLabel}
          title="AI security is not about protecting models. It is about protecting the entire computing stack."
          intro="The endpoint of this talk is a shift from model-centric security to system-centric trust."
          variant="center"
        >
          <div class="rounded-3xl border border-[var(--color-accent)]/20 bg-[color:rgba(102,117,101,0.1)] p-8">
            <p class="mx-auto max-w-3xl text-3xl font-semibold tracking-tight text-white sm:text-4xl">
              AI security is not about protecting models.
              <span class="mt-2 block">It is about protecting the entire computing stack.</span>
            </p>
            <p class="mt-5 text-sm uppercase tracking-[0.18em] text-slate-400">{talkStory.closingLine}</p>
          </div>

          <div class="mt-6 flex flex-wrap justify-center gap-3">
            <a href={localizePath("/talks/", locale)} class="button-secondary">{copy.common.talks}</a>
            <a href={localizePath("/contact/", locale)} class="button-primary">{copy.talksPage.inviteJason}</a>
          </div>
