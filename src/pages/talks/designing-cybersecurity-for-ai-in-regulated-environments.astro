---
import { speaking } from "../../data/speaking";
import { talkPromptDeck } from "../../data/talkPromptDeck";
import BaseLayout from "../../layouts/BaseLayout.astro";

const slideSections = talkPromptDeck.sections.filter((section) => section.label.startsWith("Slide"));
---

<BaseLayout
  title="AI Medical Device Security Prompt Deck"
  description="A one-page companion deck for Jason Lin's talk on cybersecurity design for AI in regulated medical environments, including a global prompt, slide-by-slide prompts, and a full-deck master prompt."
  pathname={talkPromptDeck.pathname}
  type="article"
>
  <section id="top" class="section pt-12 sm:pt-16">
    <div class="shell space-y-8 sm:space-y-10">
      <article class="panel overflow-hidden p-7 sm:p-8 lg:p-10">
        <div class="grid gap-8 xl:grid-cols-[1.15fr_0.85fr] xl:gap-10">
          <div class="space-y-6">
            <div class="flex flex-wrap items-center gap-3">
              <span class="eyebrow mb-0">{talkPromptDeck.hero.eyebrow}</span>
              <span class="pill">{speaking.featuredEngagement.event}</span>
              <span class="pill">One-page companion</span>
            </div>

            <div class="space-y-4">
              <h1 class="max-w-4xl text-4xl font-semibold tracking-tight text-white sm:text-5xl">
                {talkPromptDeck.hero.title}
              </h1>
              <p class="max-w-3xl text-lg leading-8 text-slate-300">{talkPromptDeck.hero.description}</p>
              <p class="max-w-3xl text-base leading-8 text-slate-400">{talkPromptDeck.hero.detail}</p>
            </div>

            <div class="flex flex-wrap gap-3">
              <a href="#global-control-prompt" class="button-primary">Jump to Global Prompt</a>
              <a href="/talks/" class="button-secondary">Back to Talks</a>
              <a
                href={speaking.featuredEngagement.url}
                target="_blank"
                rel="noreferrer"
                class="button-secondary"
              >
                Official Session Page
              </a>
            </div>
          </div>

          <div class="grid gap-4">
            <div class="summary-card">
              <p class="summary-label">Deck scope</p>
              <p class="mt-3 text-3xl font-semibold tracking-tight text-white">20 core slides + appendix</p>
              <p class="mt-3 text-sm leading-7 text-slate-300">
                Opening contrast, MacKay Memorial Hospital, FDA Section 524B, full-stack security,
                federated learning, trust, patch governance, patient safety, and closing thesis.
              </p>
            </div>

            <div class="summary-card">
              <p class="summary-label">Compatible tools</p>
              <div class="mt-4 flex flex-wrap gap-2">
                {talkPromptDeck.compatibleTools.map((tool) => <span class="pill">{tool}</span>)}
              </div>
            </div>

            <div class="summary-card">
              <p class="summary-label">Visual direction</p>
              <ul class="mt-3 space-y-3 list-disc pl-5">
                {talkPromptDeck.designDirection.map((item) => (
                  <li class="text-sm leading-7 text-slate-300">{item}</li>
                ))}
              </ul>
            </div>
          </div>
        </div>
      </article>

      <section class="grid gap-6 xl:grid-cols-[0.95fr_1.05fr]">
        <article class="panel p-7 sm:p-8">
          <p class="summary-label">How to use</p>
          <h2 class="mt-3 text-2xl font-semibold tracking-tight text-white">Use the prompts in sequence</h2>
          <ol class="mt-5 list-none space-y-4 p-0">
            {talkPromptDeck.usageSteps.map((step, index) => (
              <li class="flex gap-3 text-base leading-7 text-slate-300">
                <span class="mt-1 inline-flex h-6 w-6 shrink-0 items-center justify-center rounded-full border border-white/10 bg-white/5 text-xs font-semibold text-white">
                  {index + 1}
                </span>
                <span>{step}</span>
              </li>
            ))}
          </ol>
        </article>

        <article class="panel p-7 sm:p-8">
          <p class="summary-label">Deck flow</p>
          <h2 class="mt-3 text-2xl font-semibold tracking-tight text-white">From model security to full-stack trust</h2>
          <ul class="mt-5 list-disc space-y-4 pl-5">
            {talkPromptDeck.deckFlow.map((item) => <li class="text-base leading-7 text-slate-300">{item}</li>)}
          </ul>
        </article>
      </section>

      <article class="panel p-6 sm:p-7">
        <div class="flex flex-col gap-3 sm:flex-row sm:items-end sm:justify-between">
          <div class="space-y-2">
            <p class="summary-label">Prompt navigator</p>
            <h2 class="text-2xl font-semibold tracking-tight text-white">All prompts on one page</h2>
            <p class="max-w-3xl text-sm leading-7 text-slate-300">
              Start with the global prompt, then move slide by slide. Each section below is copy-ready.
            </p>
          </div>
          <div class="rounded-full border border-white/10 bg-white/5 px-4 py-2 text-sm text-slate-300">
            {slideSections.length} slide prompts
          </div>
        </div>

        <div class="mt-6 flex flex-wrap gap-2">
          {talkPromptDeck.sections.map((section) => (
            <a href={`#${section.id}`} class="nav-chip">
              <span>{section.label}</span>
              <span class="nav-chip-divider">/</span>
              <span>{section.title}</span>
            </a>
          ))}
        </div>
      </article>

      <div class="space-y-6">
        {talkPromptDeck.sections.map((section) => (
          <article id={section.id} class="panel scroll-mt-28 p-7 sm:p-8">
            <div class="space-y-4">
              <div class="flex flex-wrap items-center gap-3">
                <span class="pill">{section.label}</span>
                <span class="text-xs uppercase tracking-[0.18em] text-slate-500">{section.kind}</span>
              </div>

              <div class="space-y-3">
                <h2 class="text-2xl font-semibold tracking-tight text-white sm:text-3xl">{section.title}</h2>
                <p class="max-w-4xl text-base leading-8 text-slate-300">{section.summary}</p>
              </div>

              <pre class="prompt-block"><code>{section.prompt.trim()}</code></pre>

              <div class="flex justify-end">
                <a href="#top" class="text-sm font-medium text-[var(--color-accent)] transition hover:text-[var(--color-accent-strong)]">
                  Back to top
                </a>
              </div>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .summary-card {
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 1.75rem;
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.06), rgba(255, 255, 255, 0.03)),
      rgba(15, 23, 42, 0.5);
    padding: 1.25rem;
  }

  .summary-label {
    color: rgb(148 163 184);
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }

  .nav-chip {
    align-items: center;
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 9999px;
    color: rgb(226 232 240);
    display: inline-flex;
    font-size: 0.875rem;
    gap: 0.5rem;
    padding: 0.75rem 1rem;
    transition: border-color 160ms ease, background-color 160ms ease, color 160ms ease;
    background: rgba(255, 255, 255, 0.04);
  }

  .nav-chip:hover {
    background: rgba(255, 255, 255, 0.08);
    border-color: rgba(255, 255, 255, 0.16);
    color: white;
  }

  .nav-chip-divider {
    color: rgb(100 116 139);
  }

  .prompt-block {
    background: rgba(2, 6, 23, 0.78);
    border: 1px solid rgba(148, 163, 184, 0.18);
    border-radius: 1.75rem;
    color: rgb(226 232 240);
    font-size: 0.95rem;
    line-height: 1.8;
    margin: 0;
    overflow-x: auto;
    padding: 1.35rem 1.5rem;
    white-space: pre-wrap;
    word-break: break-word;
  }

  .prompt-block code {
    display: block;
    font-family: var(--font-mono);
  }
</style>
