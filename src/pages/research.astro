---
import BaseLayout from "../layouts/BaseLayout.astro";
import {
  getLocaleFromPathname,
  getLocalizedPageTitle,
  getLocalizedProfile,
  getLocalizedResearch,
  getPageCopy,
  localizePath
} from "../lib/i18n";
import { itemListSchema } from "../lib/schema";

const locale = getLocaleFromPathname(Astro.url.pathname);
const profile = getLocalizedProfile(locale);
const research = getLocalizedResearch(locale);
const copy = getPageCopy(locale);
---

<BaseLayout
  title={getLocalizedPageTitle(locale, copy.common.research)}
  description={research.page.description}
  pathname={Astro.url.pathname}
  schema={itemListSchema("Research directions", research.pillars.map((pillar) => ({
    name: pillar.title,
    pathname: localizePath(`/research/${pillar.slug}/`, locale)
  })))}
>
  <section class="page-frame">
    <div class="page-stack">
      <div class="page-intro">
        <span class="eyebrow">{research.page.eyebrow}</span>
        <h1 class="text-4xl font-semibold tracking-tight text-white sm:text-5xl">
          {research.page.title}
        </h1>
        <p class="page-summary">{research.page.description}</p>
      </div>

      <section class="section-card grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
        <a href="#active-work" class="surface-link">
          <span class="block text-sm font-semibold text-white">{copy.researchPage.activeNowTitle}</span>
          <span class="mt-2 block text-sm leading-6 text-slate-400">{copy.researchPage.activeNowDescription}</span>
        </a>
        <a href="#recent-papers" class="surface-link">
          <span class="block text-sm font-semibold text-white">{copy.researchPage.depthTitle}</span>
          <span class="mt-2 block text-sm leading-6 text-slate-400">{copy.researchPage.depthDescription}</span>
        </a>
        <a href={localizePath("/projects/", locale)} class="surface-link">
          <span class="block text-sm font-semibold text-white">{copy.researchPage.implementationTitle}</span>
          <span class="mt-2 block text-sm leading-6 text-slate-400">{copy.researchPage.implementationDescription}</span>
        </a>
        <a href={localizePath("/contact/", locale)} class="surface-link">
          <span class="block text-sm font-semibold text-white">{copy.researchPage.collaborationTitle}</span>
          <span class="mt-2 block text-sm leading-6 text-slate-400">{copy.researchPage.collaborationDescription}</span>
        </a>
      </section>

      <section id="active-work" class="section-card">
        <div class="max-w-3xl space-y-3">
          <h2 class="text-2xl font-semibold text-white">{copy.researchPage.activeWorkTitle}</h2>
          <p class="text-base leading-8 text-slate-300">
            {copy.researchPage.activeWorkDescription}
          </p>
        </div>

        <div class="mt-8 grid gap-6 xl:grid-cols-3">
          {research.ongoingWork.map((item) => (
            <article class="surface-card">
              <div class="flex items-center justify-between gap-3">
                <span class="text-xs uppercase tracking-[0.2em] text-slate-500">{item.status}</span>
              </div>
              <h3 class="mt-4 text-xl font-semibold text-white">{item.title}</h3>
              <p class="mt-4 text-sm leading-7 text-slate-300">{item.summary}</p>
              <p class="mt-4 text-sm leading-7 text-slate-300">
                <span class="text-slate-200">{copy.researchPage.currentNextStep}</span> {item.nextStep}
              </p>
              <div class="mt-5 flex flex-wrap gap-2">
                {item.tags.map((tag) => <span class="pill">{tag}</span>)}
              </div>
            </article>
          ))}
        </div>
      </section>

      <section id="recent-papers" class="section-card">
        <div class="max-w-3xl space-y-3">
          <h2 class="text-2xl font-semibold text-white">{copy.researchPage.recentPapersTitle}</h2>
          <p class="text-base leading-8 text-slate-300">
            {copy.researchPage.recentPapersDescription}
          </p>
        </div>

        <div class="mt-8 grid gap-6 xl:grid-cols-2">
          {research.currentActivities.map((activity) => (
            <article class="surface-card">
              <p class="text-xs uppercase tracking-[0.2em] text-slate-500">{activity.label}</p>
              <h3 class="mt-3 text-xl font-semibold text-white">{activity.title}</h3>
              <p class="mt-3 text-sm leading-7 text-slate-300">{activity.description}</p>
              <div class="mt-4 space-y-2">
                {activity.details.map((item) => (
                  <p class="text-sm leading-7 text-slate-300">
                    <span class="text-slate-200">{item.label}:</span> {item.value}
                  </p>
                ))}
              </div>
              <div class="mt-4 flex flex-wrap gap-2">
                {activity.tags.map((tag) => <span class="pill">{tag}</span>)}
              </div>
              <div class="page-actions mt-5">
                {activity.links.map((link) => (
                  <a
                    href={link.url}
                    target="_blank"
                    rel="noreferrer"
                    class="button-secondary"
                  >
                    {link.label}
                  </a>
                ))}
              </div>
            </article>
          ))}
        </div>
      </section>

      <section id="research-pillars" class="grid gap-6 md:grid-cols-2 xl:grid-cols-3 scroll-mt-28" data-analytics-location="research_overview_directions">
        {research.pillars.map((pillar) => (
          <a
            href={localizePath(`/research/${pillar.slug}/`, locale)}
            class="panel group flex h-full flex-col gap-5 p-6 transition hover:border-white/20 hover:bg-white/[0.06] sm:p-7"
          >
            <h2 class="text-2xl font-semibold tracking-tight text-white">{pillar.title}</h2>
            <p class="text-sm leading-7 text-slate-300">{pillar.description}</p>
            <div class="mt-auto space-y-4">
              <div class="flex flex-wrap gap-2">
                {pillar.tags.map((tag) => <span class="pill">{tag}</span>)}
              </div>
              <span class="inline-flex items-center gap-2 text-sm font-semibold text-[var(--color-accent)] transition group-hover:text-[var(--color-accent-strong)]">
                {copy.researchDirectionPage.openDirection}
                <span aria-hidden="true">→</span>
              </span>
            </div>
          </a>
        ))}
      </section>

      <section class="grid gap-8 xl:grid-cols-[1.05fr_0.95fr]">
        <article class="section-card">
          <h2 class="text-2xl font-semibold text-white">{copy.researchPage.questionsTitle}</h2>
          <ul class="mt-6 space-y-4">
            {research.questions.map((question) => <li class="text-base leading-7 text-slate-300">{question}</li>)}
          </ul>
        </article>

        <article class="section-card">
          <h2 class="text-2xl font-semibold text-white">{copy.researchPage.workingStyleTitle}</h2>
          <p class="mt-6 text-base leading-8 text-slate-300">
            {copy.researchPage.workingStyleParagraphOne}
          </p>
          <p class="mt-4 text-base leading-8 text-slate-300">
            {copy.researchPage.workingStyleParagraphTwo}
          </p>
          <div class="mt-6 flex flex-wrap gap-2">
            {profile.credibility.map((item) => <span class="pill">{item}</span>)}
          </div>
          <div class="mt-6">
            <a href={profile.lab.url} target="_blank" rel="noreferrer" class="button-secondary">
              {copy.researchPage.labWebsite}
            </a>
          </div>
        </article>
      </section>

      <section id="collaboration" class="grid gap-8 xl:grid-cols-[0.95fr_1.05fr] scroll-mt-28">
        <article class="section-card">
          <h2 class="text-2xl font-semibold text-white">{copy.researchPage.futureDirectionsTitle}</h2>
          <ul class="mt-6 space-y-4">
            {research.futureDirections.map((item) => <li class="text-base leading-7 text-slate-300">{item}</li>)}
          </ul>
        </article>

        <article class="section-card flex flex-col gap-5">
          <div class="space-y-3">
            <h2 class="text-2xl font-semibold text-white">{research.collaboration.title}</h2>
            <p class="text-base leading-8 text-slate-300">{research.collaboration.description}</p>
          </div>
          <div class="surface-card">
            <p class="text-sm leading-7 text-slate-300">
              {copy.researchPage.collaborationBox}
            </p>
          </div>
          <div class="page-actions">
            <a href={localizePath("/projects/", locale)} class="button-secondary">{copy.researchPage.selectedProjects}</a>
            <a href={localizePath("/contact/", locale)} class="button-primary">{copy.researchPage.collaborate}</a>
          </div>
        </article>
      </section>
    </div>
  </section>
</BaseLayout>
