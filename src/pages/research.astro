---
import BaseLayout from "../layouts/BaseLayout.astro";
import CTASection from "../components/ui/CTASection.astro";
import PageHero from "../components/ui/PageHero.astro";
import SectionIntro from "../components/ui/SectionIntro.astro";
import {
  getLocaleFromPathname,
  getLocalizedPageTitle,
  getLocalizedProfile,
  getLocalizedResearch,
  getPageCopy,
  localizePath
} from "../lib/i18n";
import { itemListSchema } from "../lib/schema";

const locale = getLocaleFromPathname(Astro.url.pathname);
const profile = getLocalizedProfile(locale);
const research = getLocalizedResearch(locale);
const copy = getPageCopy(locale);
---

<BaseLayout
  title={getLocalizedPageTitle(locale, copy.common.research)}
  description={research.page.description}
  pathname={Astro.url.pathname}
  schema={itemListSchema("Research directions", research.pillars.map((pillar) => ({
    name: pillar.title,
    pathname: localizePath(`/research/${pillar.slug}/`, locale)
  })))}
>
  <section class="page-frame">
    <div class="page-stack">
      <PageHero
        eyebrow={research.page.eyebrow}
        title={research.page.title}
        summary={research.page.description}
        titleClass="display-title-sm"
        actions={[
          { href: localizePath("/projects/", locale), label: copy.researchPage.selectedProjects, variant: "secondary" },
          { href: localizePath("/contact/", locale), label: copy.researchPage.collaborate }
        ]}
      />

      <section class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
        <a href="#active-work" class="surface-link">
          <span class="block text-sm font-semibold">{copy.researchPage.activeNowTitle}</span>
          <span class="mt-2 block text-sm leading-6">{copy.researchPage.activeNowDescription}</span>
        </a>
        <a href="#recent-papers" class="surface-link">
          <span class="block text-sm font-semibold">{copy.researchPage.depthTitle}</span>
          <span class="mt-2 block text-sm leading-6">{copy.researchPage.depthDescription}</span>
        </a>
        <a href={localizePath("/projects/", locale)} class="surface-link">
          <span class="block text-sm font-semibold">{copy.researchPage.implementationTitle}</span>
          <span class="mt-2 block text-sm leading-6">{copy.researchPage.implementationDescription}</span>
        </a>
        <a href={localizePath("/contact/", locale)} class="surface-link">
          <span class="block text-sm font-semibold">{copy.researchPage.collaborationTitle}</span>
          <span class="mt-2 block text-sm leading-6">{copy.researchPage.collaborationDescription}</span>
        </a>
      </section>

      <section id="active-work" class="section-card">
        <SectionIntro title={copy.researchPage.activeWorkTitle} copy={copy.researchPage.activeWorkDescription} />

        <div class="mt-8 grid gap-6 xl:grid-cols-3">
          {research.ongoingWork.map((item) => (
            <article class="surface-card">
              <div class="flex items-center justify-between gap-3">
                <span class="muted-label">{item.status}</span>
              </div>
              <h3 class="mt-4 text-xl font-semibold">{item.title}</h3>
              <p class="mt-4 text-sm leading-7">{item.summary}</p>
              <p class="mt-4 text-sm leading-7">
                <span class="font-semibold text-[var(--color-charcoal)]">{copy.researchPage.currentNextStep}</span> {item.nextStep}
              </p>
              <div class="mt-5 flex flex-wrap gap-2">
                {item.tags.map((tag) => <span class="pill">{tag}</span>)}
              </div>
            </article>
          ))}
        </div>
      </section>

      <section id="recent-papers" class="section-card">
        <SectionIntro title={copy.researchPage.recentPapersTitle} copy={copy.researchPage.recentPapersDescription} />

        <div class="mt-8 grid gap-6 xl:grid-cols-2">
          {research.currentActivities.map((activity) => (
            <article class="surface-card">
              <p class="muted-label">{activity.label}</p>
              <h3 class="mt-3 text-xl font-semibold">{activity.title}</h3>
              <p class="mt-3 text-sm leading-7">{activity.description}</p>
              <div class="mt-4 space-y-2">
                {activity.details.map((item) => (
                  <p class="text-sm leading-7">
                    <span class="font-semibold text-[var(--color-charcoal)]">{item.label}:</span> {item.value}
                  </p>
                ))}
              </div>
              <div class="mt-4 flex flex-wrap gap-2">
                {activity.tags.map((tag) => <span class="pill">{tag}</span>)}
              </div>
              <div class="page-actions mt-5">
                {activity.links.map((link) => (
                  <a href={link.url} target="_blank" rel="noreferrer" class="button-secondary">
                    {link.label}
                  </a>
                ))}
              </div>
            </article>
          ))}
        </div>
      </section>

      <section id="research-pillars" class="grid gap-6 md:grid-cols-2 xl:grid-cols-3 scroll-mt-28" data-analytics-location="research_overview_directions">
        {research.pillars.map((pillar) => (
          <a href={localizePath(`/research/${pillar.slug}/`, locale)} class="surface-link group flex h-full flex-col gap-5 p-6 sm:p-7">
            <h2 class="font-[var(--font-display)] text-[2rem] leading-[0.98] tracking-[-0.03em]">{pillar.title}</h2>
            <p class="text-sm leading-7">{pillar.description}</p>
            <div class="mt-auto space-y-4">
              <div class="flex flex-wrap gap-2">
                {pillar.tags.map((tag) => <span class="pill">{tag}</span>)}
              </div>
              <span class="action-link">
                {copy.researchDirectionPage.openDirection}
                <span aria-hidden="true">→</span>
              </span>
            </div>
          </a>
        ))}
      </section>

      <section class="grid gap-8 xl:grid-cols-[1.05fr_0.95fr]">
        <article class="section-card">
          <SectionIntro title={copy.researchPage.questionsTitle} />
          <ul class="mt-6 compact-list">
            {research.questions.map((question) => <li class="text-base leading-7">{question}</li>)}
          </ul>
        </article>

        <article class="section-card">
          <SectionIntro title={copy.researchPage.workingStyleTitle} />
          <p class="mt-6 text-base leading-8">{copy.researchPage.workingStyleParagraphOne}</p>
          <p class="mt-4 text-base leading-8">{copy.researchPage.workingStyleParagraphTwo}</p>
          <div class="mt-6 flex flex-wrap gap-2">
            {profile.credibility.map((item) => <span class="pill">{item}</span>)}
          </div>
          <div class="mt-6">
            <a href={profile.lab.url} target="_blank" rel="noreferrer" class="button-secondary">
              {copy.researchPage.labWebsite}
            </a>
          </div>
        </article>
      </section>

      <section id="collaboration" class="grid gap-8 xl:grid-cols-[0.95fr_1.05fr] scroll-mt-28">
        <article class="section-card">
          <SectionIntro title={copy.researchPage.futureDirectionsTitle} />
          <ul class="mt-6 compact-list">
            {research.futureDirections.map((item) => <li class="text-base leading-7">{item}</li>)}
          </ul>
        </article>

        <CTASection
          title={research.collaboration.title}
          copy={research.collaboration.description}
          actions={[
            { href: localizePath("/projects/", locale), label: copy.researchPage.selectedProjects, variant: "secondary" },
            { href: localizePath("/contact/", locale), label: copy.researchPage.collaborate }
          ]}
        />
      </section>
    </div>
  </section>
</BaseLayout>
