---
import { getCollection } from "astro:content";
import AboutPreview from "../components/home/AboutPreview.astro";
import ContactCTA from "../components/home/ContactCTA.astro";
import CredibilityStrip from "../components/home/CredibilityStrip.astro";
import FeaturedProjects from "../components/home/FeaturedProjects.astro";
import Hero from "../components/home/Hero.astro";
import ResearchThemes from "../components/home/ResearchThemes.astro";
import SpeakingPreview from "../components/home/SpeakingPreview.astro";
import WritingPreview from "../components/home/WritingPreview.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { sortBlogEntries, sortProjects } from "../lib/content";
import { getLocaleFromPathname, getLocalizedSite } from "../lib/i18n";

const projects = sortProjects(await getCollection("projects")).filter((entry) => entry.data.featured).slice(0, 3);
const posts = sortBlogEntries(await getCollection("blog")).slice(0, 3);
const locale = getLocaleFromPathname(Astro.url.pathname);
const localizedSite = getLocalizedSite(locale);
---

<BaseLayout title={localizedSite.defaultTitle} description={localizedSite.description} pathname={Astro.url.pathname}>
  <Hero locale={locale} />
  <CredibilityStrip locale={locale} />
  <ResearchThemes locale={locale} />
  <FeaturedProjects projects={projects} locale={locale} />
  <WritingPreview posts={posts} locale={locale} />
  <SpeakingPreview locale={locale} />
  <AboutPreview locale={locale} />
  <ContactCTA locale={locale} />
</BaseLayout>
