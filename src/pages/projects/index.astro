---
import { getCollection } from "astro:content";
import ProjectCard from "../../components/project/ProjectCard.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { projectFilters, sortProjects } from "../../lib/content";
import { getLocaleFromPathname, getLocalizedPageTitle, getPageCopy, localizePath } from "../../lib/i18n";

const projects = sortProjects(await getCollection("projects"));
const locale = getLocaleFromPathname(Astro.url.pathname);
const copy = getPageCopy(locale);
const filters = [
  { id: "All", label: copy.projectsPage.filters[0] },
  { id: "Speech", label: copy.projectsPage.filters[1] },
  { id: "AI Systems", label: copy.projectsPage.filters[2] },
  { id: "Fraud Analysis", label: copy.projectsPage.filters[3] },
  { id: "Security", label: copy.projectsPage.filters[4] }
];
---

<BaseLayout
  title={getLocalizedPageTitle(locale, copy.common.projects)}
  description={copy.projectsPage.description}
  pathname={Astro.url.pathname}
>
  <section class="page-frame">
    <div class="page-stack">
      <div class="page-intro">
        <span class="eyebrow">{copy.common.projects}</span>
        <h1 class="text-4xl font-semibold tracking-tight text-white sm:text-5xl">
          {copy.projectsPage.title}
        </h1>
        <p class="page-summary">
          {copy.projectsPage.description}
        </p>
      </div>

      <section class="section-card flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
        <div class="max-w-2xl space-y-2">
          <h2 class="text-lg font-semibold text-white">{copy.projectsPage.filterTitle}</h2>
          <p class="text-sm leading-7 text-slate-300">
            {copy.projectsPage.filterDescription}
          </p>
        </div>
        <p class="text-sm text-slate-400" aria-live="polite" data-project-results-summary>
          {copy.projectsPage.showingSummary.replace("{count}", String(projects.length)).replace("{total}", String(projects.length))}
        </p>
      </section>

      <div class="flex flex-wrap gap-3" aria-label="Project filters" role="toolbar" data-analytics-location="projects_filters">
        {filters.map((filter, index) => (
          <button
            type="button"
            class:list={[
              "button-secondary px-4 py-2",
              index === 0 && "border-white/20 bg-white/[0.08] text-white"
            ]}
            data-filter={filter.id}
            data-filter-label={filter.label}
            aria-controls="project-grid"
            aria-pressed={index === 0 ? "true" : "false"}
            data-plausible-event="content_filter_use"
            data-analytics-page-type="projects_index"
            data-analytics-filter={filter.id}
            data-analytics-label={filter.label}
          >
            {filter.label}
          </button>
        ))}
      </div>

      <div id="project-grid" class="grid gap-6 xl:grid-cols-3" data-analytics-location="projects_index_grid">
        {projects.map((project) => <ProjectCard project={project} filters={projectFilters(project)} analyticsLocation="projects_index_grid" locale={locale} />)}
      </div>

      <section class="section-card flex flex-col gap-5 lg:flex-row lg:items-center lg:justify-between" data-analytics-location="projects_broader_context">
        <div class="space-y-2">
          <h2 class="text-2xl font-semibold text-white">{copy.projectsPage.broaderContextTitle}</h2>
          <p class="max-w-2xl text-base leading-8 text-slate-300">
            {copy.projectsPage.broaderContextDescription}
          </p>
        </div>
        <div class="page-actions">
          <a href={localizePath("/research/", locale)} class="button-secondary">{copy.common.research}</a>
          <a href={localizePath("/blog/", locale)} class="button-secondary">{copy.common.writing}</a>
          <a href={localizePath("/contact/", locale)} class="button-primary">{copy.common.contact}</a>
        </div>
      </section>
    </div>
  </section>

  <script
    is:inline
    define:vars={{
      projectsSummary: copy.projectsPage.showingSummary,
      projectsSummaryWithFilter: copy.projectsPage.showingSummaryWithFilter
    }}
  >
    const buttons = Array.from(document.querySelectorAll("[data-filter]"));
    const cards = Array.from(document.querySelectorAll("[data-project-card]"));
    const summary = document.querySelector("[data-project-results-summary]");
    const total = cards.length;

    const updateSummary = (count, filter, filterLabel) => {
      if (!(summary instanceof HTMLElement)) {
        return;
      }

      if (filter && filter !== "All") {
        summary.textContent = projectsSummaryWithFilter
          .replace("{count}", String(count))
          .replace("{total}", String(total))
          .replace("{filter}", String(filterLabel));
        return;
      }

      summary.textContent = projectsSummary.replace("{count}", String(count)).replace("{total}", String(total));
    };

    buttons.forEach((button) => {
      button.addEventListener("click", () => {
        const filter = button.dataset.filter;
        const filterLabel = button.dataset.filterLabel;
        let visibleCount = 0;

        buttons.forEach((item) => {
          item.setAttribute("aria-pressed", String(item === button));
          item.classList.toggle("text-white", item === button);
          item.classList.toggle("border-white/20", item === button);
          item.classList.toggle("bg-white/[0.08]", item === button);
        });

        cards.forEach((card) => {
          const categories = (card.dataset.category || "").split(",");
          const visible = filter === "All" || categories.includes(filter);
          card.toggleAttribute("hidden", !visible);
          if (visible) {
            visibleCount += 1;
          }
        });

        updateSummary(visibleCount, filter, filterLabel);
      });
    });
  </script>
</BaseLayout>
