---
import { getCollection } from "astro:content";
import ProjectCard from "../../components/project/ProjectCard.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { projectFilters, sortProjects } from "../../lib/content";
import { pageTitle } from "../../lib/site";

const projects = sortProjects(await getCollection("projects"));
const filters = ["All", "Speech", "AI Systems", "Fraud Analysis", "Security"];
---

<BaseLayout
  title={pageTitle("Projects")}
  description="This page focuses on intentional case studies rather than a repository dump. Each project is framed through the problem, the system design, the technical decisions that mattered, and the reason the work is relevant in practice."
  pathname="/projects/"
>
  <section class="section pt-12 sm:pt-16">
    <div class="shell space-y-10">
      <div class="max-w-3xl space-y-5">
        <span class="eyebrow">Projects</span>
        <h1 class="text-4xl font-semibold tracking-tight text-white sm:text-5xl">
          Research-led case studies in trustworthy AI, speech intelligence, and security-aware systems.
        </h1>
        <p class="text-lg leading-8 text-slate-300">
          This page focuses on intentional case studies rather than a repository dump. Each project is framed through the problem, the system design, the technical decisions that mattered, and the reason the work is relevant in practice.
        </p>
      </div>

      <section class="panel flex flex-col gap-4 p-6 sm:flex-row sm:items-center sm:justify-between">
        <div class="max-w-2xl space-y-2">
          <h2 class="text-lg font-semibold text-white">Filter by theme</h2>
          <p class="text-sm leading-7 text-slate-300">
            Use these filters to jump directly to speech, AI systems, fraud analysis, or security-related case studies.
          </p>
        </div>
        <p class="text-sm text-slate-400" aria-live="polite" data-project-results-summary>
          Showing {projects.length} of {projects.length} projects
        </p>
      </section>

      <div class="flex flex-wrap gap-3" aria-label="Project filters" role="toolbar">
        {filters.map((filter, index) => (
          <button
            type="button"
            class:list={[
              "button-secondary px-4 py-2",
              index === 0 && "border-white/20 bg-white/[0.08] text-white"
            ]}
            data-filter={filter}
            aria-controls="project-grid"
            aria-pressed={index === 0 ? "true" : "false"}
          >
            {filter}
          </button>
        ))}
      </div>

      <div id="project-grid" class="grid gap-6 xl:grid-cols-3">
        {projects.map((project) => <ProjectCard project={project} filters={projectFilters(project)} />)}
      </div>

      <section class="panel flex flex-col gap-5 p-7 sm:p-8 lg:flex-row lg:items-center lg:justify-between">
        <div class="space-y-2">
          <h2 class="text-2xl font-semibold text-white">Need the broader context?</h2>
          <p class="max-w-2xl text-base leading-8 text-slate-300">
            If a case study is relevant, the next useful comparison is usually the research agenda, a writing sample, or a direct conversation.
          </p>
        </div>
        <div class="flex flex-wrap gap-3">
          <a href="/research/" class="button-secondary">Research</a>
          <a href="/blog/" class="button-secondary">Writing</a>
          <a href="/contact/" class="button-primary">Contact</a>
        </div>
      </section>
    </div>
  </section>

  <script is:inline>
    const buttons = Array.from(document.querySelectorAll("[data-filter]"));
    const cards = Array.from(document.querySelectorAll("[data-project-card]"));
    const summary = document.querySelector("[data-project-results-summary]");
    const total = cards.length;

    const updateSummary = (count, filter) => {
      if (!(summary instanceof HTMLElement)) {
        return;
      }

      summary.textContent = `Showing ${count} of ${total} projects${filter && filter !== "All" ? ` for ${filter}` : ""}`;
    };

    buttons.forEach((button) => {
      button.addEventListener("click", () => {
        const filter = button.dataset.filter;
        let visibleCount = 0;

        buttons.forEach((item) => {
          item.setAttribute("aria-pressed", String(item === button));
          item.classList.toggle("text-white", item === button);
          item.classList.toggle("border-white/20", item === button);
          item.classList.toggle("bg-white/[0.08]", item === button);
        });

        cards.forEach((card) => {
          const categories = (card.dataset.category || "").split(",");
          const visible = filter === "All" || categories.includes(filter);
          card.toggleAttribute("hidden", !visible);
          if (visible) {
            visibleCount += 1;
          }
        });

        updateSummary(visibleCount, filter);
      });
    });
  </script>
</BaseLayout>
