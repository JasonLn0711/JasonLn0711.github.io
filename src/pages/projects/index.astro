---
import { getCollection } from "astro:content";
import PageIntro from "../../components/common/PageIntro.astro";
import SectionHeader from "../../components/common/SectionHeader.astro";
import ProjectCard from "../../components/project/ProjectCard.astro";
import { projectSections } from "../../data/projects";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { groupProjectsByKind, sortProjects } from "../../lib/content";

const projects = sortProjects(await getCollection("projects"));
const grouped = groupProjectsByKind(projects);
---

<BaseLayout
  title="Projects"
  description="Selected systems, research prototypes, and engineering experiments spanning trustworthy AI, speech pipelines, cybersecurity, and deployable intelligence systems."
  pathname="/projects/"
>
  <section class="section pt-12 sm:pt-16">
    <div class="shell space-y-12">
      <PageIntro
        eyebrow="Projects"
        title="A curated project archive, not a random repo list."
        description="This page is organized as a set of technical case studies. Some entries point to public repositories, while others document research systems and architecture directions that matter to my current doctoral work."
      />

      {projectSections.map((section) =>
        grouped[section.kind].length > 0 && (
          <section class="space-y-6">
            <SectionHeader
              eyebrow={section.eyebrow}
              title={section.title}
              description={section.description}
            />
            <div class="grid gap-6 lg:grid-cols-2">
              {grouped[section.kind].map((project) => <ProjectCard project={project} />)}
            </div>
          </section>
        )
      )}
    </div>
  </section>
</BaseLayout>
