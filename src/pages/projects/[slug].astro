---
import { getCollection, type CollectionEntry } from "astro:content";
import ProjectLayout from "../../components/project/ProjectLayout.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { sortProjects } from "../../lib/content";
import { getLocaleFromPathname, getLocalizedPageTitle, getPageCopy } from "../../lib/i18n";
import { projectSchema } from "../../lib/schema";

export async function getStaticPaths() {
  const projects = sortProjects(await getCollection("projects"));

  return projects.map((project, index) => ({
    params: { slug: project.slug },
    props: {
      project,
      previousProject: projects[index + 1] ?? null,
      nextProject: projects[index - 1] ?? null
    }
  }));
}

interface Props {
  project: CollectionEntry<"projects">;
  previousProject?: CollectionEntry<"projects"> | null;
  nextProject?: CollectionEntry<"projects"> | null;
}

const { project, previousProject, nextProject } = Astro.props;
const { Content } = await project.render();
const locale = getLocaleFromPathname(Astro.url.pathname);
const copy = getPageCopy(locale);
---

<BaseLayout
  title={getLocalizedPageTitle(locale, project.data.title, copy.common.projects)}
  description={project.data.summary}
  image={project.data.cover}
  pathname={Astro.url.pathname}
  schema={projectSchema(project)}
>
  <ProjectLayout project={project} previousProject={previousProject ?? undefined} nextProject={nextProject ?? undefined} locale={locale}>
    <Content />
  </ProjectLayout>
</BaseLayout>
