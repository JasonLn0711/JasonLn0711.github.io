---
import { profile } from "../data/profile";
import { research } from "../data/research";
import { speaking } from "../data/speaking";
import BaseLayout from "../layouts/BaseLayout.astro";

const currentWorkTitles = research.ongoingWork.map((item) => item.title);
---

<BaseLayout
  title="Contact"
  description="Contact Jason Chia-Sheng Lin for research collaboration, speaking, or technical discussions related to trustworthy AI, AI systems, speech intelligence, and real-world deployment."
  pathname="/contact/"
>
  <section class="section pt-12 sm:pt-16">
    <div class="shell space-y-12">
      <div class="max-w-3xl space-y-5">
        <span class="eyebrow">Contact</span>
        <h1 class="text-4xl font-semibold tracking-tight text-white sm:text-5xl">
          Start a serious conversation.
        </h1>
        <p class="text-lg leading-8 text-slate-300">{profile.contactPrompt}</p>
      </div>

      <div class="grid gap-6 lg:grid-cols-3">
        <article class="panel flex flex-col gap-5 p-7">
          <span class="pill w-fit">Who I am</span>
          <h2 class="text-2xl font-semibold text-white">Doctoral researcher at NYCU</h2>
          <p class="text-sm leading-7 text-slate-300">{profile.shortBio}</p>
        </article>

        <article class="panel flex flex-col gap-5 p-7">
          <span class="pill w-fit">What I'm building</span>
          <h2 class="text-2xl font-semibold text-white">Current research focus</h2>
          <p class="text-sm leading-7 text-slate-300">{currentWorkTitles.join(" · ")}</p>
          <p class="text-sm leading-7 text-slate-300">
            Current work moves from evidence-aware speech systems to grounded analysis workflows and security-minded AI deployment.
          </p>
        </article>

        <article class="panel flex flex-col gap-5 p-7">
          <span class="pill w-fit">Why trust me</span>
          <h2 class="text-2xl font-semibold text-white">Research and delivery signals</h2>
          <p class="text-sm leading-7 text-slate-300">
            Doctoral research at {profile.institutionShort}, an official {speaking.featuredEngagement.event} session, and {speaking.additionalEngagements.length} English CISC 2025 conference papers.
          </p>
        </article>
      </div>

      <section class="grid gap-8 lg:grid-cols-[320px_minmax(0,1fr)]">
        <div class="panel overflow-hidden">
          <img src={profile.avatar} alt={profile.name} class="aspect-[4/5] w-full object-cover" />
        </div>

        <div class="panel flex flex-col justify-center gap-5 p-7 sm:p-8">
          <span class="eyebrow">Profile</span>
          <h2 class="text-2xl font-semibold text-white">{profile.name}</h2>
          <p class="max-w-2xl text-base leading-8 text-slate-300">
            Doctoral researcher at {profile.institution} in the {profile.lab.name}, working across trustworthy AI, medical cybersecurity, speech intelligence, and real-world deployment, with recent English CISC 2025 papers on ransomware defense and threat pulse modeling for zero-trust maturity assessment.
          </p>
          <div class="flex flex-wrap gap-3">
            <a href={profile.lab.url} target="_blank" rel="noreferrer" class="button-secondary">
              Lab Website
            </a>
            <a
              href={profile.externalProfiles.cybersecSpeaker.url}
              target="_blank"
              rel="noreferrer"
              class="button-secondary"
            >
              CYBERSEC Speaker Profile
            </a>
          </div>
        </div>
      </section>

      <div class="grid gap-6 lg:grid-cols-3">
        <article class="panel flex flex-col gap-5 p-7">
          <span class="pill w-fit">Email</span>
          <h2 class="text-2xl font-semibold text-white">Research and collaboration</h2>
          <p class="text-sm leading-7 text-slate-300">
            The best route for collaboration, speaking invitations, research discussions, and technically specific inquiries.
          </p>
          <a href={`mailto:${profile.email}`} class="button-primary mt-auto">Send an email</a>
        </article>

        <article class="panel flex flex-col gap-5 p-7">
          <span class="pill w-fit">GitHub</span>
          <h2 class="text-2xl font-semibold text-white">Code and technical work</h2>
          <p class="text-sm leading-7 text-slate-300">
            Browse repositories, prototypes, and the implementation side of ongoing research and engineering work.
          </p>
          <a href={profile.github} target="_blank" rel="noreferrer" class="button-secondary mt-auto">
            Visit GitHub
          </a>
        </article>

        <article class="panel flex flex-col gap-5 p-7">
          <span class="pill w-fit">LinkedIn</span>
          <h2 class="text-2xl font-semibold text-white">Professional connection</h2>
          <p class="text-sm leading-7 text-slate-300">
            Connect for longer-term opportunities, introductions, and interdisciplinary or international conversations.
          </p>
          <a href={profile.linkedin} target="_blank" rel="noreferrer" class="button-secondary mt-auto">
            View LinkedIn
          </a>
        </article>
      </div>
    </div>
  </section>
</BaseLayout>
