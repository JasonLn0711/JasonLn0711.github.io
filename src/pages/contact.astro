---
import BaseLayout from "../layouts/BaseLayout.astro";
import {
  formatMessage,
  getLocaleFromPathname,
  getLocalizedPageTitle,
  getLocalizedProfile,
  getLocalizedResearch,
  getLocalizedSpeaking,
  getPageCopy,
  localizePath
} from "../lib/i18n";

const locale = getLocaleFromPathname(Astro.url.pathname);
const profile = getLocalizedProfile(locale);
const research = getLocalizedResearch(locale);
const speaking = getLocalizedSpeaking(locale);
const copy = getPageCopy(locale);
const currentWorkTitles = research.ongoingWork.map((item) => item.title);
---

<BaseLayout
  title={getLocalizedPageTitle(locale, copy.common.contact)}
  description={profile.contactPrompt}
  image={profile.avatar}
  pathname={Astro.url.pathname}
>
  <section class="section pt-12 sm:pt-16">
    <div class="shell space-y-12">
      <div class="max-w-3xl space-y-5">
        <span class="eyebrow">{copy.common.contact}</span>
        <h1 class="text-4xl font-semibold tracking-tight text-white sm:text-5xl">
          {copy.contactPage.title}
        </h1>
        <p class="text-lg leading-8 text-slate-300">{profile.contactPrompt}</p>
      </div>

      <section class="panel grid gap-6 p-7 sm:p-8 lg:grid-cols-[1.1fr_0.9fr]">
        <div class="space-y-5">
          <div class="space-y-2">
            <h2 class="text-2xl font-semibold text-white">{copy.contactPage.directRouteTitle}</h2>
            <p class="text-base leading-8 text-slate-300">
              {copy.contactPage.directRouteDescription}
            </p>
          </div>

          <div class="grid gap-3 sm:grid-cols-3">
            {profile.contactTopics.map((topic) => (
              <div class="rounded-3xl border border-white/[0.08] bg-white/[0.03] p-4">
                <p class="text-sm leading-7 text-slate-300">{topic}</p>
              </div>
            ))}
          </div>

          <div class="flex flex-wrap gap-3">
            <a href={`mailto:${profile.email}`} class="button-primary">{copy.common.emailJason}</a>
            <a href={profile.linkedin} target="_blank" rel="noreferrer" class="button-secondary">
              LinkedIn
            </a>
            <a href={profile.github} target="_blank" rel="noreferrer" class="button-secondary">
              GitHub
            </a>
          </div>
        </div>

        <div class="rounded-3xl border border-white/[0.08] bg-white/[0.03] p-6">
          <p class="text-xs uppercase tracking-[0.18em] text-slate-500">{copy.contactPage.helpfulContext}</p>
          <ul class="mt-4 space-y-4">
            {profile.contactChecklist.map((item) => <li class="text-sm leading-7 text-slate-300">{item}</li>)}
          </ul>
        </div>
      </section>

      <section class="grid gap-8 lg:grid-cols-[320px_minmax(0,1fr)]">
        <div class="panel overflow-hidden">
          <img
            src={profile.avatar}
            alt={`Portrait of ${profile.name}`}
            width="1693"
            height="2540"
            class="aspect-[4/5] w-full object-cover"
          />
        </div>

        <div class="panel flex flex-col justify-center gap-5 p-7 sm:p-8">
          <span class="eyebrow">{copy.contactPage.profileEyebrow}</span>
          <h2 class="text-2xl font-semibold text-white">{profile.name}</h2>
          <p class="max-w-2xl text-base leading-8 text-slate-300">
            {formatMessage(copy.contactPage.profileSummary, {
              institution: profile.institution,
              lab: profile.lab.name
            })}
          </p>
          <div class="flex flex-wrap gap-3">
            <a href={profile.lab.url} target="_blank" rel="noreferrer" class="button-secondary">
              {copy.common.labWebsite}
            </a>
            <a
              href={profile.externalProfiles.cybersecSpeaker.url}
              target="_blank"
              rel="noreferrer"
              class="button-secondary"
            >
              CYBERSEC Speaker Profile
            </a>
          </div>
        </div>
      </section>

      <div class="grid gap-6 lg:grid-cols-3">
        <article class="panel flex flex-col gap-5 p-7">
          <span class="pill w-fit">{copy.common.research}</span>
          <h2 class="text-2xl font-semibold text-white">{copy.contactPage.collaborationCardTitle}</h2>
          <p class="text-sm leading-7 text-slate-300">
            {copy.contactPage.collaborationCardDescription}
          </p>
          <a href={`mailto:${profile.email}`} class="button-primary mt-auto">{copy.contactPage.sendEmail}</a>
        </article>

        <article class="panel flex flex-col gap-5 p-7">
          <span class="pill w-fit">{copy.contactPage.currentWorkCardLabel}</span>
          <h2 class="text-2xl font-semibold text-white">{copy.contactPage.currentWorkCardTitle}</h2>
          <p class="text-sm leading-7 text-slate-300">{currentWorkTitles.join(" · ")}</p>
          <a href={localizePath("/research/", locale)} class="button-secondary mt-auto">
            {copy.contactPage.viewResearch}
          </a>
        </article>

        <article class="panel flex flex-col gap-5 p-7">
          <span class="pill w-fit">{copy.contactPage.signalsLabel}</span>
          <h2 class="text-2xl font-semibold text-white">{copy.contactPage.signalsTitle}</h2>
          <p class="text-sm leading-7 text-slate-300">
            {formatMessage(copy.contactPage.signalsDescription, {
              institutionShort: profile.institutionShort,
              event: speaking.featuredEngagement.event,
              count: speaking.additionalEngagements.length
            })}
          </p>
          <a href={localizePath("/talks/", locale)} class="button-secondary mt-auto">
            {copy.contactPage.reviewTalks}
          </a>
        </article>
      </div>
    </div>
  </section>
</BaseLayout>
