---
import { profile } from "../data/profile";
import { research } from "../data/research";
import { speaking } from "../data/speaking";
import BaseLayout from "../layouts/BaseLayout.astro";
import { pageTitle } from "../lib/site";

const currentWorkTitles = research.ongoingWork.map((item) => item.title);
---

<BaseLayout
  title={pageTitle("Contact")}
  description={profile.contactPrompt}
  image={profile.avatar}
  pathname="/contact/"
>
  <section class="section pt-12 sm:pt-16">
    <div class="shell space-y-12">
      <div class="max-w-3xl space-y-5">
        <span class="eyebrow">Contact</span>
        <h1 class="text-4xl font-semibold tracking-tight text-white sm:text-5xl">
          Start a serious conversation.
        </h1>
        <p class="text-lg leading-8 text-slate-300">{profile.contactPrompt}</p>
      </div>

      <section class="panel grid gap-6 p-7 sm:p-8 lg:grid-cols-[1.1fr_0.9fr]">
        <div class="space-y-5">
          <div class="space-y-2">
            <h2 class="text-2xl font-semibold text-white">The direct route</h2>
            <p class="text-base leading-8 text-slate-300">
              Email is the best path for collaboration, speaking invitations, hiring conversations, and technically specific questions.
            </p>
          </div>

          <div class="grid gap-3 sm:grid-cols-3">
            {profile.contactTopics.map((topic) => (
              <div class="rounded-3xl border border-white/[0.08] bg-white/[0.03] p-4">
                <p class="text-sm leading-7 text-slate-300">{topic}</p>
              </div>
            ))}
          </div>

          <div class="flex flex-wrap gap-3">
            <a href={`mailto:${profile.email}`} class="button-primary">Email Jason</a>
            <a href={profile.linkedin} target="_blank" rel="noreferrer" class="button-secondary">
              LinkedIn
            </a>
            <a href={profile.github} target="_blank" rel="noreferrer" class="button-secondary">
              GitHub
            </a>
          </div>
        </div>

        <div class="rounded-3xl border border-white/[0.08] bg-white/[0.03] p-6">
          <p class="text-xs uppercase tracking-[0.18em] text-slate-500">Helpful context to include</p>
          <ul class="mt-4 space-y-4">
            {profile.contactChecklist.map((item) => <li class="text-sm leading-7 text-slate-300">{item}</li>)}
          </ul>
        </div>
      </section>

      <section class="grid gap-8 lg:grid-cols-[320px_minmax(0,1fr)]">
        <div class="panel overflow-hidden">
          <img
            src={profile.avatar}
            alt={`Portrait of ${profile.name}`}
            width="1693"
            height="2540"
            class="aspect-[4/5] w-full object-cover"
          />
        </div>

        <div class="panel flex flex-col justify-center gap-5 p-7 sm:p-8">
          <span class="eyebrow">Profile</span>
          <h2 class="text-2xl font-semibold text-white">{profile.name}</h2>
          <p class="max-w-2xl text-base leading-8 text-slate-300">
            Doctoral researcher at {profile.institution} in the {profile.lab.name}, working across trustworthy AI, medical cybersecurity, speech intelligence, and real-world deployment, with recent English CISC 2025 papers on ransomware defense and threat pulse modeling for zero-trust maturity assessment.
          </p>
          <div class="flex flex-wrap gap-3">
            <a href={profile.lab.url} target="_blank" rel="noreferrer" class="button-secondary">
              Lab Website
            </a>
            <a
              href={profile.externalProfiles.cybersecSpeaker.url}
              target="_blank"
              rel="noreferrer"
              class="button-secondary"
            >
              CYBERSEC Speaker Profile
            </a>
          </div>
        </div>
      </section>

      <div class="grid gap-6 lg:grid-cols-3">
        <article class="panel flex flex-col gap-5 p-7">
          <span class="pill w-fit">Research</span>
          <h2 class="text-2xl font-semibold text-white">Collaboration and technical discussion</h2>
          <p class="text-sm leading-7 text-slate-300">
            The best route for collaboration, speaking invitations, research discussions, and technically specific inquiries.
          </p>
          <a href={`mailto:${profile.email}`} class="button-primary mt-auto">Send an email</a>
        </article>

        <article class="panel flex flex-col gap-5 p-7">
          <span class="pill w-fit">Current work</span>
          <h2 class="text-2xl font-semibold text-white">What Jason is building now</h2>
          <p class="text-sm leading-7 text-slate-300">{currentWorkTitles.join(" · ")}</p>
          <a href="/research/" class="button-secondary mt-auto">
            View research
          </a>
        </article>

        <article class="panel flex flex-col gap-5 p-7">
          <span class="pill w-fit">Signals</span>
          <h2 class="text-2xl font-semibold text-white">Credibility and external references</h2>
          <p class="text-sm leading-7 text-slate-300">
            Doctoral research at {profile.institutionShort}, an official {speaking.featuredEngagement.event} session, and {speaking.additionalEngagements.length} English CISC 2025 conference papers.
          </p>
          <a href="/talks/" class="button-secondary mt-auto">
            Review talks
          </a>
        </article>
      </div>
    </div>
  </section>
</BaseLayout>
