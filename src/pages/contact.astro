---
import BaseLayout from "../layouts/BaseLayout.astro";
import CTASection from "../components/ui/CTASection.astro";
import MediaFrame from "../components/ui/MediaFrame.astro";
import PageHero from "../components/ui/PageHero.astro";
import SectionIntro from "../components/ui/SectionIntro.astro";
import {
  formatMessage,
  getLocaleFromPathname,
  getLocalizedPageTitle,
  getLocalizedProfile,
  getLocalizedResearch,
  getLocalizedSpeaking,
  getPageCopy,
  localizePath
} from "../lib/i18n";

const locale = getLocaleFromPathname(Astro.url.pathname);
const profile = getLocalizedProfile(locale);
const research = getLocalizedResearch(locale);
const speaking = getLocalizedSpeaking(locale);
const copy = getPageCopy(locale);
const currentWorkTitles = research.ongoingWork.map((item) => item.title);
---

<BaseLayout
  title={getLocalizedPageTitle(locale, copy.common.contact)}
  description={profile.contactPrompt}
  image={profile.avatar}
  pathname={Astro.url.pathname}
>
  <section class="page-frame">
    <div class="page-stack">
      <PageHero
        eyebrow={copy.common.contact}
        title={copy.contactPage.title}
        summary={profile.contactPrompt}
        split={true}
        titleClass="display-title-sm"
        actions={[
          { href: `mailto:${profile.email}`, label: copy.common.emailJason },
          { href: profile.linkedin, label: "LinkedIn", variant: "secondary", external: true },
          { href: profile.github, label: "GitHub", variant: "secondary", external: true }
        ]}
      >
        <div slot="media" class="space-y-5">
          <MediaFrame
            src={profile.avatar}
            alt={`Portrait of ${profile.name}`}
            width="1693"
            height="2540"
            imageClass="aspect-[4/5] w-full object-cover object-[center_24%]"
          />
          <div class="surface-card">
            <p class="muted-label">{copy.contactPage.helpfulContext}</p>
            <ul class="mt-4 compact-list">
              {profile.contactChecklist.map((item) => <li class="text-sm leading-7">{item}</li>)}
            </ul>
          </div>
        </div>
      </PageHero>

      <section class="grid gap-8 xl:grid-cols-[1.05fr_0.95fr]">
        <article class="section-card">
          <SectionIntro title={copy.contactPage.directRouteTitle} copy={copy.contactPage.directRouteDescription} />
          <div class="mt-6 grid gap-3 sm:grid-cols-2">
            {profile.contactTopics.map((topic) => (
              <div class="surface-card">
                <p class="text-sm leading-7">{topic}</p>
              </div>
            ))}
          </div>
        </article>

        <article class="section-card">
          <SectionIntro
            eyebrow={copy.contactPage.profileEyebrow}
            title={profile.name}
            copy={formatMessage(copy.contactPage.profileSummary, {
              institution: profile.institution,
              lab: profile.lab.name
            })}
          />
          <div class="mt-6 page-actions" data-analytics-location="contact_profile_links">
            <a href={profile.lab.url} target="_blank" rel="noreferrer" class="button-secondary">
              {copy.common.labWebsite}
            </a>
            <a
              href={profile.externalProfiles.cybersecSpeaker.url}
              target="_blank"
              rel="noreferrer"
              class="button-secondary"
            >
              CYBERSEC Speaker Profile
            </a>
          </div>
        </article>
      </section>

      <div class="grid gap-6 lg:grid-cols-3" data-analytics-location="contact_cards">
        <article class="surface-card flex flex-col gap-5">
          <span class="pill w-fit">{copy.common.research}</span>
          <h2 class="text-2xl font-semibold">{copy.contactPage.collaborationCardTitle}</h2>
          <p class="text-sm leading-7">{copy.contactPage.collaborationCardDescription}</p>
          <a href={`mailto:${profile.email}`} class="button-primary mt-auto">{copy.contactPage.sendEmail}</a>
        </article>

        <article class="surface-card flex flex-col gap-5">
          <span class="pill w-fit">{copy.contactPage.currentWorkCardLabel}</span>
          <h2 class="text-2xl font-semibold">{copy.contactPage.currentWorkCardTitle}</h2>
          <p class="text-sm leading-7">{currentWorkTitles.join(" · ")}</p>
          <a href={localizePath("/research/", locale)} class="button-secondary mt-auto">
            {copy.contactPage.viewResearch}
          </a>
        </article>

        <article class="surface-card flex flex-col gap-5">
          <span class="pill w-fit">{copy.contactPage.signalsLabel}</span>
          <h2 class="text-2xl font-semibold">{copy.contactPage.signalsTitle}</h2>
          <p class="text-sm leading-7">
            {formatMessage(copy.contactPage.signalsDescription, {
              institutionShort: profile.institutionShort,
              event: speaking.featuredEngagement.event,
              count: speaking.additionalEngagements.length
            })}
          </p>
          <a href={localizePath("/talks/", locale)} class="button-secondary mt-auto">
            {copy.contactPage.reviewTalks}
          </a>
        </article>
      </div>

      <CTASection
        title={copy.common.workTogether}
        copy={profile.contactPrompt}
        actions={[
          { href: `mailto:${profile.email}`, label: copy.common.emailJason },
          { href: localizePath("/research/", locale), label: copy.common.research, variant: "secondary" }
        ]}
      />
    </div>
  </section>
</BaseLayout>
