---
import PageIntro from "../components/common/PageIntro.astro";
import { collaborationAreas, contactLinks } from "../data/contact";
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Contact"
  description="Contact Jason Chia-Sheng Lin for research collaboration, speaking invitations, or technical conversations around AI systems, trustworthy AI, and AI security."
  pathname="/contact/"
>
  <section class="section pt-12 sm:pt-16">
    <div class="shell space-y-12">
      <PageIntro
        eyebrow="Contact"
        title="Open to thoughtful collaboration, speaking, and technically serious conversations."
        description="The most relevant discussions are usually around trustworthy AI, speech and language systems, AI security, and real-world deployment in environments where reliability matters."
      />

      <div class="grid gap-6 xl:grid-cols-[0.95fr_1.05fr]">
        <article class="panel p-7 sm:p-8">
          <span class="eyebrow">Best Fit</span>
          <h2 class="mt-5 text-2xl font-semibold text-[var(--color-ink)]">Reach out for work that benefits from technical depth and cross-domain judgment.</h2>
          <ul class="mt-6 space-y-4">
            {collaborationAreas.map((item) => (
              <li class="flex gap-4">
                <span class="pill h-fit">+</span>
                <p class="text-sm leading-7 text-[var(--color-muted)]">{item}</p>
              </li>
            ))}
          </ul>
          <p class="mt-6 text-sm leading-7 text-[var(--color-muted)]">
            Email is the best path for substantive conversations. LinkedIn and GitHub are useful for profile context, public work, and longer-term connection.
          </p>
        </article>

        <div class="grid gap-4 sm:grid-cols-2">
          {contactLinks.map((link) => (
            <article class="panel flex flex-col gap-5 p-7">
              <span class="pill w-fit">{link.label}</span>
              <h2 class="text-2xl font-semibold text-[var(--color-ink)]">{link.label}</h2>
              <p class="text-sm leading-7 text-[var(--color-muted)]">{link.note}</p>
              <a
                href={link.href}
                target={link.href.startsWith("http") ? "_blank" : undefined}
                rel={link.href.startsWith("http") ? "noreferrer" : undefined}
                class="button-secondary mt-auto"
              >
                Open {link.label}
              </a>
            </article>
          ))}
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
