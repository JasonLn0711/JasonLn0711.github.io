---
import BaseLayout from "../layouts/BaseLayout.astro";
import {
  getLocaleFromPathname,
  getLocalizedPageTitle,
  getLocalizedProfile,
  getLocalizedSpeaking,
  getPageCopy,
  localizePath
} from "../lib/i18n";

const locale = getLocaleFromPathname(Astro.url.pathname);
const profile = getLocalizedProfile(locale);
const speaking = getLocalizedSpeaking(locale);
const copy = getPageCopy(locale);
---

<BaseLayout
  title={getLocalizedPageTitle(locale, copy.common.talks)}
  description={speaking.page.description}
  image={profile.avatar}
  pathname={Astro.url.pathname}
>
  <section class="page-frame">
    <div class="page-stack">
      <div class="page-intro">
        <span class="eyebrow">{speaking.page.eyebrow}</span>
        <h1 class="text-4xl font-semibold tracking-tight text-white sm:text-5xl">{speaking.page.title}</h1>
        <p class="page-summary">{speaking.page.description}</p>
      </div>

      <section class="section-card grid gap-4 sm:grid-cols-3">
        <a href="#featured-talk" class="surface-link">
          <span class="block text-sm font-semibold text-white">{copy.talksPage.reviewTitle}</span>
          <span class="mt-2 block text-sm leading-6 text-slate-400">{copy.talksPage.reviewDescription}</span>
        </a>
        <a href="#topics" class="surface-link">
          <span class="block text-sm font-semibold text-white">{copy.talksPage.browseTitle}</span>
          <span class="mt-2 block text-sm leading-6 text-slate-400">{copy.talksPage.browseDescription}</span>
        </a>
        <a href={localizePath("/contact/", locale)} class="surface-link">
          <span class="block text-sm font-semibold text-white">{copy.talksPage.readyTitle}</span>
          <span class="mt-2 block text-sm leading-6 text-slate-400">{copy.talksPage.readyDescription}</span>
        </a>
      </section>

      <article id="featured-talk" class="section-card grid gap-8 overflow-hidden lg:grid-cols-[280px_minmax(0,1fr)]">
        <div class="overflow-hidden rounded-3xl border border-white/[0.08]">
          <img
            src={profile.avatar}
            alt={`Portrait of ${profile.name}`}
            width="1693"
            height="2540"
            class="aspect-[4/5] w-full object-cover"
          />
        </div>
        <div class="flex flex-col justify-center gap-5">
          <div class="flex flex-wrap items-center gap-3">
            <span class="pill w-fit">{speaking.featuredEngagement.label}</span>
            <span class="text-xs uppercase tracking-[0.18em] text-slate-500">{speaking.featuredEngagement.event}</span>
          </div>

          <div class="space-y-3">
            <h2 class="text-2xl font-semibold text-white">{speaking.featuredEngagement.title}</h2>
            <p class="max-w-3xl text-base leading-8 text-slate-300">{speaking.featuredEngagement.summary}</p>
          </div>

          <div class="grid gap-3 sm:grid-cols-2">
            <div class="surface-card p-4">
              <p class="text-xs uppercase tracking-[0.18em] text-slate-500">{copy.talksPage.schedule}</p>
              <p class="mt-2 text-sm leading-7 text-slate-200">{speaking.featuredEngagement.schedule}</p>
            </div>
            <div class="surface-card p-4">
              <p class="text-xs uppercase tracking-[0.18em] text-slate-500">{copy.talksPage.track}</p>
              <p class="mt-2 text-sm leading-7 text-slate-200">{speaking.featuredEngagement.track}</p>
            </div>
            <div class="surface-card p-4">
              <p class="text-xs uppercase tracking-[0.18em] text-slate-500">{copy.talksPage.location}</p>
              <p class="mt-2 text-sm leading-7 text-slate-200">{speaking.featuredEngagement.venue}</p>
            </div>
            <div class="surface-card p-4">
              <p class="text-xs uppercase tracking-[0.18em] text-slate-500">{copy.talksPage.format}</p>
              <p class="mt-2 text-sm leading-7 text-slate-200">
                {speaking.featuredEngagement.format} · {speaking.featuredEngagement.language}
              </p>
            </div>
          </div>

          <p class="text-sm leading-7 text-slate-300">{speaking.featuredEngagement.description}</p>
          <p class="text-sm leading-7 text-slate-400">{speaking.featuredEngagement.speaker}</p>
          <p class="text-sm leading-7 text-slate-400">{speaking.featuredEngagement.coauthor}</p>

          <div class="flex flex-wrap gap-2">
            {speaking.featuredEngagement.tags.map((tag) => <span class="pill">{tag}</span>)}
          </div>

          <div class="surface-card">
            <p class="text-xs uppercase tracking-[0.18em] text-slate-500">{copy.talksPage.narrativeVersion}</p>
            <p class="mt-3 text-sm leading-7 text-slate-300">
              {copy.talksPage.narrativeVersionDescription}
            </p>
          </div>

          <div class="page-actions">
            <a href={localizePath(speaking.featuredEngagement.storyHref, locale)} class="button-primary">
              {speaking.featuredEngagement.storyLabel}
            </a>
            <a
              href={speaking.featuredEngagement.url}
              target="_blank"
              rel="noreferrer"
              class="button-secondary"
            >
              {copy.common.officialSessionPage}
            </a>
            <a
              href={profile.externalProfiles.cybersecSpeaker.url}
              target="_blank"
              rel="noreferrer"
              class="button-secondary"
            >
              {copy.common.speakerProfile}
            </a>
          </div>
        </div>
      </article>

      {speaking.additionalEngagements.length > 0 && (
        <section class="space-y-6">
          <div class="max-w-4xl space-y-3">
            <span class="eyebrow">{copy.talksPage.englishSessionsEyebrow}</span>
            <h2 class="text-3xl font-semibold tracking-tight text-white">{copy.talksPage.englishSessionsTitle}</h2>
            <p class="text-base leading-8 text-slate-300">
              {copy.talksPage.englishSessionsDescription}
            </p>
          </div>

          <div class="grid gap-6">
            {speaking.additionalEngagements.map((engagement) => (
              <article class="section-card flex flex-col gap-6">
                <div class="flex flex-wrap items-center gap-3">
                  <span class="pill">{engagement.label}</span>
                  <span class="text-xs uppercase tracking-[0.18em] text-slate-500">{engagement.event}</span>
                </div>

                <div class="space-y-3">
                  <h2 class="text-2xl font-semibold text-white">{engagement.title}</h2>
                  <p class="max-w-4xl text-base leading-8 text-slate-300">{engagement.summary}</p>
                </div>

                <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-4">
                  <div class="surface-card p-4">
                    <p class="text-xs uppercase tracking-[0.18em] text-slate-500">{copy.talksPage.schedule}</p>
                    <p class="mt-2 text-sm leading-7 text-slate-200">{engagement.schedule}</p>
                  </div>
                  <div class="surface-card p-4">
                    <p class="text-xs uppercase tracking-[0.18em] text-slate-500">{copy.talksPage.track}</p>
                    <p class="mt-2 text-sm leading-7 text-slate-200">{engagement.track}</p>
                  </div>
                  <div class="surface-card p-4">
                    <p class="text-xs uppercase tracking-[0.18em] text-slate-500">{copy.talksPage.venue}</p>
                    <p class="mt-2 text-sm leading-7 text-slate-200">{engagement.venue}</p>
                  </div>
                  <div class="surface-card p-4">
                    <p class="text-xs uppercase tracking-[0.18em] text-slate-500">{copy.talksPage.format}</p>
                    <p class="mt-2 text-sm leading-7 text-slate-200">
                      {engagement.format} · {engagement.language}
                    </p>
                  </div>
                </div>

                <p class="text-sm leading-7 text-slate-300">{engagement.description}</p>
                <p class="text-sm leading-7 text-slate-400">{engagement.speaker}</p>
                <p class="text-sm leading-7 text-slate-400">{engagement.coauthor}</p>

                <div class="flex flex-wrap gap-2">
                  {engagement.tags.map((tag) => <span class="pill">{tag}</span>)}
                </div>

                <div class="page-actions">
                  {(engagement.links ?? [{ label: engagement.ctaLabel, url: engagement.url }]).map((link) => (
                    <a
                      href={link.url}
                      target="_blank"
                      rel="noreferrer"
                      class="button-secondary"
                    >
                      {link.label}
                    </a>
                  ))}
                </div>
              </article>
            ))}
          </div>
        </section>
      )}

      <section id="topics" class="grid gap-6 xl:grid-cols-3 scroll-mt-28">
        {speaking.topics.map((topic) => (
          <article class="panel flex h-full flex-col gap-5 p-6 sm:p-7">
            <h2 class="text-2xl font-semibold tracking-tight text-white">{topic.title}</h2>
            <p class="text-sm leading-7 text-slate-300">{topic.description}</p>
            <p class="mt-auto text-xs uppercase tracking-[0.18em] text-slate-500">{topic.audience}</p>
          </article>
        ))}
      </section>

      <section class="grid gap-8 xl:grid-cols-[0.95fr_1.05fr]">
        <article class="section-card">
          <h2 class="text-2xl font-semibold text-white">{copy.talksPage.formatsTitle}</h2>
          <ul class="mt-6 space-y-4">
            {speaking.formats.map((item) => <li class="text-base leading-7 text-slate-300">{item}</li>)}
          </ul>
          <p class="mt-6 text-base leading-8 text-slate-300">
            {copy.talksPage.formatsDescription}
          </p>
        </article>

        <article class="section-card flex flex-col gap-5">
          <div class="space-y-3">
            <h2 class="text-2xl font-semibold text-white">{speaking.invitation.title}</h2>
            <p class="text-base leading-8 text-slate-300">{speaking.invitation.description}</p>
          </div>

          <div class="surface-card">
            <p class="text-sm leading-7 text-slate-300">
              {copy.talksPage.invitationBox}
            </p>
          </div>

          <div class="page-actions">
            <a href={`mailto:${profile.email}`} class="button-primary">{copy.talksPage.inviteJason}</a>
            <a href={localizePath("/contact/", locale)} class="button-secondary">{copy.common.contact}</a>
          </div>
        </article>
      </section>
    </div>
  </section>
</BaseLayout>
