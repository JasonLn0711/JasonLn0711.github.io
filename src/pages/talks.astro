---
import { profile } from "../data/profile";
import { speaking } from "../data/speaking";
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Talks"
  description="Speaking topics, official session details, and selected conference-paper activity from Jason Chia-Sheng Lin across trustworthy AI, cybersecurity, speech systems, and real-world AI deployment."
  pathname="/talks/"
>
  <section class="section pt-12 sm:pt-16">
    <div class="shell space-y-14">
      <div class="max-w-4xl space-y-5">
        <span class="eyebrow">{speaking.page.eyebrow}</span>
        <h1 class="text-4xl font-semibold tracking-tight text-white sm:text-5xl">{speaking.page.title}</h1>
        <p class="text-lg leading-8 text-slate-300">{speaking.page.description}</p>
      </div>

      {speaking.additionalEngagements.length > 0 && (
        <section class="space-y-6">
          <div class="max-w-4xl space-y-3">
            <span class="eyebrow">English Research Sessions</span>
            <h2 class="text-3xl font-semibold tracking-tight text-white">Conference paper activity</h2>
            <p class="text-base leading-8 text-slate-300">
              Two English CISC 2025 paper sessions connecting technical analysis, operational threat models, continuous assessment, and practical defense strategy.
            </p>
          </div>

          <div class="grid gap-6">
            {speaking.additionalEngagements.map((engagement) => (
              <article class="panel flex flex-col gap-6 p-7 sm:p-8">
                <div class="flex flex-wrap items-center gap-3">
                  <span class="pill">{engagement.label}</span>
                  <span class="text-xs uppercase tracking-[0.18em] text-slate-500">{engagement.event}</span>
                </div>

                <div class="space-y-3">
                  <h2 class="text-2xl font-semibold text-white">{engagement.title}</h2>
                  <p class="max-w-4xl text-base leading-8 text-slate-300">{engagement.summary}</p>
                </div>

                <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-4">
                  <div class="rounded-3xl border border-white/[0.08] bg-white/[0.03] p-4">
                    <p class="text-xs uppercase tracking-[0.18em] text-slate-500">Schedule</p>
                    <p class="mt-2 text-sm leading-7 text-slate-200">{engagement.schedule}</p>
                  </div>
                  <div class="rounded-3xl border border-white/[0.08] bg-white/[0.03] p-4">
                    <p class="text-xs uppercase tracking-[0.18em] text-slate-500">Track</p>
                    <p class="mt-2 text-sm leading-7 text-slate-200">{engagement.track}</p>
                  </div>
                  <div class="rounded-3xl border border-white/[0.08] bg-white/[0.03] p-4">
                    <p class="text-xs uppercase tracking-[0.18em] text-slate-500">Venue</p>
                    <p class="mt-2 text-sm leading-7 text-slate-200">{engagement.venue}</p>
                  </div>
                  <div class="rounded-3xl border border-white/[0.08] bg-white/[0.03] p-4">
                    <p class="text-xs uppercase tracking-[0.18em] text-slate-500">Format</p>
                    <p class="mt-2 text-sm leading-7 text-slate-200">
                      {engagement.format} · {engagement.language}
                    </p>
                  </div>
                </div>

                <p class="text-sm leading-7 text-slate-300">{engagement.description}</p>
                <p class="text-sm leading-7 text-slate-400">{engagement.speaker}</p>
                <p class="text-sm leading-7 text-slate-400">{engagement.coauthor}</p>

                <div class="flex flex-wrap gap-2">
                  {engagement.tags.map((tag) => <span class="pill">{tag}</span>)}
                </div>

                <div class="flex flex-wrap gap-3">
                  {(engagement.links ?? [{ label: engagement.ctaLabel, url: engagement.url }]).map((link) => (
                    <a
                      href={link.url}
                      target="_blank"
                      rel="noreferrer"
                      class="button-secondary"
                    >
                      {link.label}
                    </a>
                  ))}
                </div>
              </article>
            ))}
          </div>
        </section>
      )}

      <article class="panel grid gap-8 overflow-hidden p-7 sm:p-8 lg:grid-cols-[280px_minmax(0,1fr)]">
        <div class="overflow-hidden rounded-3xl border border-white/[0.08]">
          <img src={profile.avatar} alt={profile.name} class="aspect-[4/5] w-full object-cover" />
        </div>
        <div class="flex flex-col justify-center gap-5">
          <div class="flex flex-wrap items-center gap-3">
            <span class="pill w-fit">{speaking.featuredEngagement.label}</span>
            <span class="text-xs uppercase tracking-[0.18em] text-slate-500">{speaking.featuredEngagement.event}</span>
          </div>

          <div class="space-y-3">
            <h2 class="text-2xl font-semibold text-white">{speaking.featuredEngagement.title}</h2>
            <p class="max-w-3xl text-base leading-8 text-slate-300">{speaking.featuredEngagement.summary}</p>
          </div>

          <div class="grid gap-3 sm:grid-cols-2">
            <div class="rounded-3xl border border-white/[0.08] bg-white/[0.03] p-4">
              <p class="text-xs uppercase tracking-[0.18em] text-slate-500">Schedule</p>
              <p class="mt-2 text-sm leading-7 text-slate-200">{speaking.featuredEngagement.schedule}</p>
            </div>
            <div class="rounded-3xl border border-white/[0.08] bg-white/[0.03] p-4">
              <p class="text-xs uppercase tracking-[0.18em] text-slate-500">Track</p>
              <p class="mt-2 text-sm leading-7 text-slate-200">{speaking.featuredEngagement.track}</p>
            </div>
            <div class="rounded-3xl border border-white/[0.08] bg-white/[0.03] p-4">
              <p class="text-xs uppercase tracking-[0.18em] text-slate-500">Location</p>
              <p class="mt-2 text-sm leading-7 text-slate-200">{speaking.featuredEngagement.venue}</p>
            </div>
            <div class="rounded-3xl border border-white/[0.08] bg-white/[0.03] p-4">
              <p class="text-xs uppercase tracking-[0.18em] text-slate-500">Format</p>
              <p class="mt-2 text-sm leading-7 text-slate-200">
                {speaking.featuredEngagement.format} · {speaking.featuredEngagement.language}
              </p>
            </div>
          </div>

          <p class="text-sm leading-7 text-slate-300">{speaking.featuredEngagement.description}</p>
          <p class="text-sm leading-7 text-slate-400">{speaking.featuredEngagement.speaker}</p>
          <p class="text-sm leading-7 text-slate-400">{speaking.featuredEngagement.coauthor}</p>

          <div class="flex flex-wrap gap-2">
            {speaking.featuredEngagement.tags.map((tag) => <span class="pill">{tag}</span>)}
          </div>

          <div class="flex flex-wrap gap-3">
            <a
              href={speaking.featuredEngagement.url}
              target="_blank"
              rel="noreferrer"
              class="button-primary"
            >
              Official Session Page
            </a>
            <a
              href={profile.externalProfiles.cybersecSpeaker.url}
              target="_blank"
              rel="noreferrer"
              class="button-secondary"
            >
              CYBERSEC Speaker Profile
            </a>
          </div>
        </div>
      </article>

      <section class="grid gap-6 xl:grid-cols-3">
        {speaking.topics.map((topic) => (
          <article class="panel flex h-full flex-col gap-5 p-6 sm:p-7">
            <h2 class="text-2xl font-semibold tracking-tight text-white">{topic.title}</h2>
            <p class="text-sm leading-7 text-slate-300">{topic.description}</p>
            <p class="mt-auto text-xs uppercase tracking-[0.18em] text-slate-500">{topic.audience}</p>
          </article>
        ))}
      </section>

      <section class="grid gap-8 xl:grid-cols-[0.95fr_1.05fr]">
        <article class="panel p-7 sm:p-8">
          <h2 class="text-2xl font-semibold text-white">Formats and audience fit</h2>
          <ul class="mt-6 space-y-4">
            {speaking.formats.map((item) => <li class="text-base leading-7 text-slate-300">{item}</li>)}
          </ul>
          <p class="mt-6 text-base leading-8 text-slate-300">
            These talks are especially well suited to research groups, technical conferences, interdisciplinary programs, and teams working on AI in environments where reliability and governance matter.
          </p>
        </article>

        <article class="panel flex flex-col gap-5 p-7 sm:p-8">
          <div class="space-y-3">
            <h2 class="text-2xl font-semibold text-white">{speaking.invitation.title}</h2>
            <p class="text-base leading-8 text-slate-300">{speaking.invitation.description}</p>
          </div>

          <div class="rounded-3xl border border-white/[0.08] bg-white/[0.03] p-5">
            <p class="text-sm leading-7 text-slate-300">
              If you are organizing a seminar, conference session, lab talk, or interdisciplinary event related to trustworthy AI, speech intelligence, RAG systems, or high-stakes deployment, feel free to reach out with your format and audience in mind.
            </p>
          </div>

          <div class="flex flex-wrap gap-3">
            <a href={`mailto:${profile.email}`} class="button-primary">Invite Jason to Speak</a>
            <a href="/contact/" class="button-secondary">Contact</a>
          </div>
        </article>
      </section>
    </div>
  </section>
</BaseLayout>
