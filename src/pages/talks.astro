---
import BaseLayout from "../layouts/BaseLayout.astro";
import CTASection from "../components/ui/CTASection.astro";
import MediaFrame from "../components/ui/MediaFrame.astro";
import PageHero from "../components/ui/PageHero.astro";
import SectionIntro from "../components/ui/SectionIntro.astro";
import {
  getLocaleFromPathname,
  getLocalizedPageTitle,
  getLocalizedProfile,
  getLocalizedSpeaking,
  getPageCopy,
  localizePath
} from "../lib/i18n";

const locale = getLocaleFromPathname(Astro.url.pathname);
const profile = getLocalizedProfile(locale);
const speaking = getLocalizedSpeaking(locale);
const copy = getPageCopy(locale);
---

<BaseLayout
  title={getLocalizedPageTitle(locale, copy.common.talks)}
  description={speaking.page.description}
  image={profile.avatar}
  pathname={Astro.url.pathname}
>
  <section class="page-frame">
    <div class="page-stack">
      <PageHero
        eyebrow={speaking.page.eyebrow}
        title={speaking.page.title}
        summary={speaking.page.description}
        titleClass="display-title-sm"
        actions={[
          { href: localizePath(speaking.featuredEngagement.storyHref, locale), label: speaking.featuredEngagement.storyLabel },
          { href: localizePath("/contact/", locale), label: copy.common.contact, variant: "secondary" }
        ]}
      />

      <section class="grid gap-4 sm:grid-cols-3">
        <a href="#featured-talk" class="surface-link">
          <span class="block text-sm font-semibold">{copy.talksPage.reviewTitle}</span>
          <span class="mt-2 block text-sm leading-6">{copy.talksPage.reviewDescription}</span>
        </a>
        <a href="#topics" class="surface-link">
          <span class="block text-sm font-semibold">{copy.talksPage.browseTitle}</span>
          <span class="mt-2 block text-sm leading-6">{copy.talksPage.browseDescription}</span>
        </a>
        <a href={localizePath("/contact/", locale)} class="surface-link">
          <span class="block text-sm font-semibold">{copy.talksPage.readyTitle}</span>
          <span class="mt-2 block text-sm leading-6">{copy.talksPage.readyDescription}</span>
        </a>
      </section>

      <article id="featured-talk" class="section-card grid gap-8 lg:grid-cols-[320px_minmax(0,1fr)]">
        <MediaFrame
          src={profile.avatar}
          alt={`Portrait of ${profile.name}`}
          width="1693"
          height="2540"
          imageClass="aspect-[4/5] w-full object-cover object-[center_24%]"
        />

        <div class="space-y-5">
          <div class="flex flex-wrap items-center gap-3">
            <span class="pill w-fit">{speaking.featuredEngagement.label}</span>
            <span class="muted-label">{speaking.featuredEngagement.event}</span>
          </div>

          <div class="space-y-3">
            <h2 class="font-[var(--font-display)] text-[2.5rem] leading-[0.96] tracking-[-0.03em]">
              {speaking.featuredEngagement.title}
            </h2>
            <p class="max-w-3xl text-base leading-8">{speaking.featuredEngagement.summary}</p>
          </div>

          <div class="grid gap-3 sm:grid-cols-2">
            <div class="surface-card">
              <p class="muted-label">{copy.talksPage.schedule}</p>
              <p class="mt-2 text-sm leading-7 text-[var(--color-charcoal)]">{speaking.featuredEngagement.schedule}</p>
            </div>
            <div class="surface-card">
              <p class="muted-label">{copy.talksPage.track}</p>
              <p class="mt-2 text-sm leading-7 text-[var(--color-charcoal)]">{speaking.featuredEngagement.track}</p>
            </div>
            <div class="surface-card">
              <p class="muted-label">{copy.talksPage.location}</p>
              <p class="mt-2 text-sm leading-7 text-[var(--color-charcoal)]">{speaking.featuredEngagement.venue}</p>
            </div>
            <div class="surface-card">
              <p class="muted-label">{copy.talksPage.format}</p>
              <p class="mt-2 text-sm leading-7 text-[var(--color-charcoal)]">
                {speaking.featuredEngagement.format} · {speaking.featuredEngagement.language}
              </p>
            </div>
          </div>

          <p class="text-sm leading-7">{speaking.featuredEngagement.description}</p>
          <div class="flex flex-wrap gap-2">
            {speaking.featuredEngagement.tags.map((tag) => <span class="pill">{tag}</span>)}
          </div>

          <div class="page-actions">
            <a href={localizePath(speaking.featuredEngagement.storyHref, locale)} class="button-primary">
              {speaking.featuredEngagement.storyLabel}
            </a>
            <a href={speaking.featuredEngagement.url} target="_blank" rel="noreferrer" class="button-secondary">
              {copy.common.officialSessionPage}
            </a>
            <a href={profile.externalProfiles.cybersecSpeaker.url} target="_blank" rel="noreferrer" class="button-secondary">
              {copy.common.speakerProfile}
            </a>
          </div>
        </div>
      </article>

      {speaking.additionalEngagements.length > 0 && (
        <section class="space-y-6">
          <SectionIntro
            eyebrow={copy.talksPage.englishSessionsEyebrow}
            title={copy.talksPage.englishSessionsTitle}
            copy={copy.talksPage.englishSessionsDescription}
          />

          <div class="grid gap-6">
            {speaking.additionalEngagements.map((engagement) => (
              <article class="section-card flex flex-col gap-5">
                <div class="flex flex-wrap items-center gap-3">
                  <span class="pill">{engagement.label}</span>
                  <span class="muted-label">{engagement.event}</span>
                </div>

                <div class="space-y-3">
                  <h2 class="text-2xl font-semibold">{engagement.title}</h2>
                  <p class="max-w-4xl text-base leading-8">{engagement.summary}</p>
                </div>

                <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-4">
                  <div class="surface-card">
                    <p class="muted-label">{copy.talksPage.schedule}</p>
                    <p class="mt-2 text-sm leading-7 text-[var(--color-charcoal)]">{engagement.schedule}</p>
                  </div>
                  <div class="surface-card">
                    <p class="muted-label">{copy.talksPage.track}</p>
                    <p class="mt-2 text-sm leading-7 text-[var(--color-charcoal)]">{engagement.track}</p>
                  </div>
                  <div class="surface-card">
                    <p class="muted-label">{copy.talksPage.venue}</p>
                    <p class="mt-2 text-sm leading-7 text-[var(--color-charcoal)]">{engagement.venue}</p>
                  </div>
                  <div class="surface-card">
                    <p class="muted-label">{copy.talksPage.format}</p>
                    <p class="mt-2 text-sm leading-7 text-[var(--color-charcoal)]">{engagement.format} · {engagement.language}</p>
                  </div>
                </div>

                <p class="text-sm leading-7">{engagement.description}</p>
                <div class="flex flex-wrap gap-2">
                  {engagement.tags.map((tag) => <span class="pill">{tag}</span>)}
                </div>

                <div class="page-actions">
                  {(engagement.links ?? [{ label: engagement.ctaLabel, url: engagement.url }]).map((link) => (
                    <a href={link.url} target="_blank" rel="noreferrer" class="button-secondary">
                      {link.label}
                    </a>
                  ))}
                </div>
              </article>
            ))}
          </div>
        </section>
      )}

      <section id="topics" class="space-y-6 scroll-mt-28">
        <SectionIntro title="Topics and audience fit" copy={copy.talksPage.formatsDescription} />
        <div class="grid gap-6 xl:grid-cols-3">
          {speaking.topics.map((topic) => (
            <article class="surface-card flex h-full flex-col gap-5 p-6 sm:p-7">
              <h2 class="font-[var(--font-display)] text-[2rem] leading-[0.98] tracking-[-0.03em]">{topic.title}</h2>
              <p class="text-sm leading-7">{topic.description}</p>
              <p class="mt-auto muted-label">{topic.audience}</p>
            </article>
          ))}
        </div>
      </section>

      <CTASection
        title={speaking.invitation.title}
        copy={speaking.invitation.description}
        actions={[
          { href: `mailto:${profile.email}`, label: copy.talksPage.inviteJason },
          { href: localizePath("/contact/", locale), label: copy.common.contact, variant: "secondary" }
        ]}
      />
    </div>
  </section>
</BaseLayout>
