---
import { profile } from "../data/profile";
import { speaking } from "../data/speaking";
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Talks"
  description="Speaking topics and upcoming CYBERSEC 2026 activity from Jason Chia-Sheng Lin across trustworthy AI, cybersecurity governance, speech systems, and real-world AI deployment."
  pathname="/talks/"
>
  <section class="section pt-12 sm:pt-16">
    <div class="shell space-y-14">
      <div class="max-w-4xl space-y-5">
        <span class="eyebrow">{speaking.page.eyebrow}</span>
        <h1 class="text-4xl font-semibold tracking-tight text-white sm:text-5xl">{speaking.page.title}</h1>
        <p class="text-lg leading-8 text-slate-300">{speaking.page.description}</p>
      </div>

      <article class="panel p-7 sm:p-8">
        <div class="max-w-3xl space-y-3">
          <span class="pill">{speaking.featuredEngagement.label}</span>
          <h2 class="text-2xl font-semibold text-white">{speaking.featuredEngagement.title}</h2>
          <p class="text-base leading-8 text-slate-300">{speaking.featuredEngagement.description}</p>
        </div>
      </article>

      <section class="grid gap-6 xl:grid-cols-3">
        {speaking.topics.map((topic) => (
          <article class="panel flex h-full flex-col gap-5 p-6 sm:p-7">
            <h2 class="text-2xl font-semibold tracking-tight text-white">{topic.title}</h2>
            <p class="text-sm leading-7 text-slate-300">{topic.description}</p>
            <p class="mt-auto text-xs uppercase tracking-[0.18em] text-slate-500">{topic.audience}</p>
          </article>
        ))}
      </section>

      <section class="grid gap-8 xl:grid-cols-[0.95fr_1.05fr]">
        <article class="panel p-7 sm:p-8">
          <h2 class="text-2xl font-semibold text-white">Formats and audience fit</h2>
          <ul class="mt-6 space-y-4">
            {speaking.formats.map((item) => <li class="text-base leading-7 text-slate-300">{item}</li>)}
          </ul>
          <p class="mt-6 text-base leading-8 text-slate-300">
            These talks are especially well suited to research groups, technical conferences, interdisciplinary programs, and teams working on AI in environments where reliability and governance matter.
          </p>
        </article>

        <article class="panel flex flex-col gap-5 p-7 sm:p-8">
          <div class="space-y-3">
            <h2 class="text-2xl font-semibold text-white">{speaking.invitation.title}</h2>
            <p class="text-base leading-8 text-slate-300">{speaking.invitation.description}</p>
          </div>

          <div class="rounded-3xl border border-white/[0.08] bg-white/[0.03] p-5">
            <p class="text-sm leading-7 text-slate-300">
              If you are organizing a seminar, conference session, lab talk, or interdisciplinary event related to trustworthy AI, speech intelligence, RAG systems, or high-stakes deployment, feel free to reach out with your format and audience in mind.
            </p>
          </div>

          <div class="flex flex-wrap gap-3">
            <a href={`mailto:${profile.email}`} class="button-primary">Invite Jason to Speak</a>
            <a href="/contact/" class="button-secondary">Contact</a>
          </div>
        </article>
      </section>
    </div>
  </section>
</BaseLayout>
