---
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Writing"
  description="Legacy route for writing. The canonical archive now lives under /writing/."
  pathname="/writing/"
  noindex={true}
>
  <section class="section pt-12 sm:pt-16">
    <div class="shell">
      <div class="panel-strong max-w-3xl space-y-5 p-8 sm:p-10">
        <span class="eyebrow">Legacy route</span>
        <h1 class="text-4xl font-semibold tracking-tight text-[var(--color-ink)] sm:text-5xl">
          The writing archive has moved.
        </h1>
        <p class="text-lg leading-8 text-[var(--color-muted)]">
          The canonical location for essays, research notes, and technical reflections is now <a href="/writing/" class="font-semibold text-[var(--color-accent)]">/writing/</a>.
        </p>
        <div class="flex flex-wrap gap-3">
          <a href="/writing/" class="button-primary">Go to writing</a>
          <a href="/rss.xml" class="button-secondary">RSS feed</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
