---
import { getCollection } from "astro:content";
import BlogCard from "../../components/blog/BlogCard.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { sortBlogEntries } from "../../lib/content";
import { pageTitle } from "../../lib/site";

const posts = sortBlogEntries(await getCollection("blog"));
const featuredPost = posts.find((post) => post.data.featured) ?? posts[0];
const remainingPosts = posts.filter((post) => post.slug !== featuredPost?.slug);
---

<BaseLayout
  title={pageTitle("Writing")}
  description="Essays and research notes that make the reasoning behind the work visible, from evidence-aware speech pipelines to deployment risk, evaluation, and trustworthy AI in practice."
  pathname="/blog/"
>
  <section class="section pt-12 sm:pt-16">
    <div class="shell space-y-10">
      <div class="max-w-3xl space-y-5">
        <span class="eyebrow">Writing</span>
        <h1 class="text-4xl font-semibold tracking-tight text-white sm:text-5xl">
          Writing on trustworthy AI, speech intelligence, and security-minded system design.
        </h1>
        <p class="text-lg leading-8 text-slate-300">
          Essays and research notes that make the reasoning behind the work visible, from evidence-aware speech pipelines to deployment risk, evaluation, and trustworthy AI in practice.
        </p>
      </div>

      <section class="panel grid gap-4 p-6 sm:grid-cols-3">
        <a href="#featured-writing" class="rounded-3xl border border-white/[0.08] bg-white/[0.03] px-5 py-4 transition hover:border-white/20 hover:bg-white/[0.05]">
          <span class="block text-sm font-semibold text-white">Start with the featured piece</span>
          <span class="mt-2 block text-sm leading-6 text-slate-400">A fast way to understand the voice and concerns behind the work.</span>
        </a>
        <a href="#recent-writing" class="rounded-3xl border border-white/[0.08] bg-white/[0.03] px-5 py-4 transition hover:border-white/20 hover:bg-white/[0.05]">
          <span class="block text-sm font-semibold text-white">Browse recent notes</span>
          <span class="mt-2 block text-sm leading-6 text-slate-400">Scan topics quickly by category, date, and tags.</span>
        </a>
        <a href="/projects/" class="rounded-3xl border border-white/[0.08] bg-white/[0.03] px-5 py-4 transition hover:border-white/20 hover:bg-white/[0.05]">
          <span class="block text-sm font-semibold text-white">Want implementation examples?</span>
          <span class="mt-2 block text-sm leading-6 text-slate-400">Jump from reasoning to project case studies.</span>
        </a>
      </section>

      {featuredPost && (
        <section id="featured-writing" class="space-y-5 scroll-mt-28">
          <h2 class="text-sm font-semibold uppercase tracking-[0.2em] text-slate-400">Featured piece</h2>
          <BlogCard post={featuredPost} featured={true} />
        </section>
      )}

      <section id="recent-writing" class="space-y-5 scroll-mt-28">
        <h2 class="text-sm font-semibold uppercase tracking-[0.2em] text-slate-400">Recent writing</h2>
        {remainingPosts.length > 0 ? (
          <div class="grid gap-6 lg:grid-cols-2">
            {remainingPosts.map((post) => <BlogCard post={post} />)}
          </div>
        ) : (
          <div class="panel p-8">
            <p class="text-base leading-7 text-slate-300">More writing is on the way.</p>
          </div>
        )}
      </section>
    </div>
  </section>
</BaseLayout>
