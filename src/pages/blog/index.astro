---
import { getCollection } from "astro:content";
import BlogCard from "../../components/blog/BlogCard.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { sortBlogEntries } from "../../lib/content";
import { getLocaleFromPathname, getLocalizedPageTitle, getPageCopy, localizePath } from "../../lib/i18n";

const posts = sortBlogEntries(await getCollection("blog"));
const featuredPost = posts.find((post) => post.data.featured) ?? posts[0];
const remainingPosts = posts.filter((post) => post.slug !== featuredPost?.slug);
const locale = getLocaleFromPathname(Astro.url.pathname);
const copy = getPageCopy(locale);
---

<BaseLayout
  title={getLocalizedPageTitle(locale, copy.common.writing)}
  description={copy.blogIndexPage.description}
  pathname={Astro.url.pathname}
>
  <section class="page-frame">
    <div class="page-stack">
      <div class="page-intro">
        <span class="eyebrow">{copy.common.writing}</span>
        <h1 class="text-4xl font-semibold tracking-tight text-white sm:text-5xl">
          {copy.blogIndexPage.title}
        </h1>
        <p class="page-summary">
          {copy.blogIndexPage.description}
        </p>
      </div>

      <section class="section-card grid gap-4 sm:grid-cols-3">
        <a href="#featured-writing" class="surface-link">
          <span class="block text-sm font-semibold text-white">{copy.blogIndexPage.featuredTitle}</span>
          <span class="mt-2 block text-sm leading-6 text-slate-400">{copy.blogIndexPage.featuredDescription}</span>
        </a>
        <a href="#recent-writing" class="surface-link">
          <span class="block text-sm font-semibold text-white">{copy.blogIndexPage.recentTitle}</span>
          <span class="mt-2 block text-sm leading-6 text-slate-400">{copy.blogIndexPage.recentDescription}</span>
        </a>
        <a href={localizePath("/projects/", locale)} class="surface-link">
          <span class="block text-sm font-semibold text-white">{copy.blogIndexPage.implementationTitle}</span>
          <span class="mt-2 block text-sm leading-6 text-slate-400">{copy.blogIndexPage.implementationDescription}</span>
        </a>
      </section>

      {featuredPost && (
        <section id="featured-writing" class="space-y-5 scroll-mt-28">
          <h2 class="text-sm font-semibold uppercase tracking-[0.2em] text-slate-400">{copy.blogIndexPage.featuredPiece}</h2>
          <BlogCard post={featuredPost} featured={true} locale={locale} />
        </section>
      )}

      <section id="recent-writing" class="space-y-5 scroll-mt-28">
        <h2 class="text-sm font-semibold uppercase tracking-[0.2em] text-slate-400">{copy.blogIndexPage.recentWriting}</h2>
        {remainingPosts.length > 0 ? (
          <div class="grid gap-6 lg:grid-cols-2">
            {remainingPosts.map((post) => <BlogCard post={post} locale={locale} />)}
          </div>
        ) : (
          <div class="panel p-8">
            <p class="text-base leading-7 text-slate-300">{copy.blogIndexPage.emptyState}</p>
          </div>
        )}
      </section>
    </div>
  </section>
</BaseLayout>
