---
import { getCollection, type CollectionEntry } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { sortBlogEntries } from "../../lib/content";

export async function getStaticPaths() {
  const posts = sortBlogEntries(await getCollection("blog"));

  return posts.map((post) => ({
    params: { slug: post.slug },
    props: {
      post
    }
  }));
}

interface Props {
  post: CollectionEntry<"blog">;
}

const { post } = Astro.props;
---

<BaseLayout
  title={post.data.title}
  description={post.data.description}
  pathname={`/writing/${post.slug}/`}
  noindex={true}
>
  <section class="section pt-12 sm:pt-16">
    <div class="shell">
      <div class="panel-strong max-w-3xl space-y-5 p-8 sm:p-10">
        <span class="eyebrow">Legacy article route</span>
        <h1 class="text-4xl font-semibold tracking-tight text-[var(--color-ink)] sm:text-5xl">
          This article now lives in the writing archive.
        </h1>
        <p class="text-lg leading-8 text-[var(--color-muted)]">{post.data.title}</p>
        <div class="flex flex-wrap gap-3">
          <a href={`/writing/${post.slug}/`} class="button-primary">Open canonical article</a>
          <a href="/writing/" class="button-secondary">Browse writing</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
