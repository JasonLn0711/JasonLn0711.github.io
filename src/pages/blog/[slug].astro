---
import { getCollection, type CollectionEntry } from "astro:content";
import UntranslatedNotice from "../../components/layout/UntranslatedNotice.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { formatDate, formatLabel, sortBlogEntries } from "../../lib/content";
import { getLocaleFromPathname, getLocalizedPageTitle, getPageCopy, localizePath } from "../../lib/i18n";
import { blogSchema } from "../../lib/schema";

export async function getStaticPaths() {
  const posts = sortBlogEntries(await getCollection("blog"));

  return posts.map((post, index) => ({
    params: { slug: post.slug },
    props: {
      post,
      previousPost: posts[index + 1] ?? null,
      nextPost: posts[index - 1] ?? null
    }
  }));
}

interface Props {
  post: CollectionEntry<"blog">;
  previousPost?: CollectionEntry<"blog"> | null;
  nextPost?: CollectionEntry<"blog"> | null;
}

const { post, previousPost, nextPost } = Astro.props;
const { Content, headings } = await post.render();
const publishedTime = post.data.pubDate.toISOString();
const modifiedTime = (post.data.updatedDate ?? post.data.pubDate).toISOString();
const locale = getLocaleFromPathname(Astro.url.pathname);
const copy = getPageCopy(locale);
---

<BaseLayout
  title={getLocalizedPageTitle(locale, post.data.title, copy.common.writing)}
  description={post.data.description}
  image={post.data.ogImage ?? post.data.cover}
  pathname={Astro.url.pathname}
  type="article"
  schema={blogSchema(post)}
  publishedTime={publishedTime}
  modifiedTime={modifiedTime}
>
  <section class="page-frame">
    <div class="page-stack">
      <div class="page-intro">
        <a href={localizePath("/blog/", locale)} class="action-link">
          <span aria-hidden="true">←</span>
          {copy.common.backToWriting}
        </a>
        <span class="eyebrow">{formatLabel(post.data.category, locale)}</span>
        <h1 class="text-4xl font-semibold tracking-tight text-white sm:text-5xl">{post.data.title}</h1>
        <p class="page-summary">{post.data.description}</p>
        <div class="meta-row">
          <span>{formatDate(post.data.pubDate, locale)}</span>
          {post.data.tags.map((tag) => <span class="pill">{tag}</span>)}
        </div>
      </div>

      <div class="panel overflow-hidden">
        <img src={post.data.cover} alt={`${post.data.title} cover`} class="aspect-[16/8] w-full object-cover" />
      </div>

      <div class="grid gap-8 xl:grid-cols-[minmax(0,1fr)_280px]">
        <article class="space-y-6">
          {locale !== "en" && <UntranslatedNotice locale={locale} kind="blog" />}
          <div class="reading-panel">
            <div class="article-body">
              <Content />
            </div>
          </div>
        </article>

        {headings.length > 2 && (
          <aside class="panel h-fit p-6 xl:sticky xl:top-28">
            <h2 class="text-sm font-semibold uppercase tracking-[0.2em] text-slate-200">{copy.common.onThisPage}</h2>
            <nav class="mt-5">
              <ul class="space-y-3">
                {headings.filter((heading) => heading.depth <= 2).map((heading) => (
                  <li>
                    <a href={`#${heading.slug}`} class="text-sm leading-6 text-slate-300 transition hover:text-white">
                      {heading.text}
                    </a>
                  </li>
                ))}
              </ul>
            </nav>
          </aside>
        )}
      </div>

      <section class="section-card flex flex-col gap-5 lg:flex-row lg:items-center lg:justify-between">
        <div class="space-y-2">
          <h2 class="text-2xl font-semibold text-white">{copy.common.continueFromThisPiece}</h2>
          <p class="max-w-2xl text-base leading-8 text-slate-300">
            If this note was useful, the next helpful step is usually to compare it with the research agenda, a project case study, or start a conversation.
          </p>
        </div>
        <div class="page-actions">
          <a href={localizePath("/research/", locale)} class="button-secondary">{copy.common.research}</a>
          <a href={localizePath("/projects/", locale)} class="button-secondary">{copy.common.projects}</a>
          <a href={localizePath("/contact/", locale)} class="button-primary">{copy.common.contact}</a>
        </div>
      </section>

      {(previousPost || nextPost) && (
        <div class="grid gap-4 sm:grid-cols-2">
          {previousPost ? (
            <a href={localizePath(`/blog/${previousPost.slug}/`, locale)} class="panel block p-6 transition hover:border-white/20">
              <p class="text-xs uppercase tracking-[0.2em] text-slate-500">{copy.common.previousPiece}</p>
              <p class="mt-3 text-lg font-semibold text-white">{previousPost.data.title}</p>
            </a>
          ) : (
            <div></div>
          )}

          {nextPost && (
            <a href={localizePath(`/blog/${nextPost.slug}/`, locale)} class="panel block p-6 text-left transition hover:border-white/20 sm:text-right">
              <p class="text-xs uppercase tracking-[0.2em] text-slate-500">{copy.common.nextPiece}</p>
              <p class="mt-3 text-lg font-semibold text-white">{nextPost.data.title}</p>
            </a>
          )}
        </div>
      )}
    </div>
  </section>
</BaseLayout>
