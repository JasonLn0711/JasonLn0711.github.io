---
import { getCollection, type CollectionEntry } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { formatDate, sortBlogEntries } from "../../lib/content";
import { blogSchema } from "../../lib/schema";

export async function getStaticPaths() {
  const posts = sortBlogEntries(await getCollection("blog"));

  return posts.map((post, index) => ({
    params: { slug: post.slug },
    props: {
      post,
      previousPost: posts[index + 1] ?? null,
      nextPost: posts[index - 1] ?? null
    }
  }));
}

interface Props {
  post: CollectionEntry<"blog">;
  previousPost?: CollectionEntry<"blog"> | null;
  nextPost?: CollectionEntry<"blog"> | null;
}

const { post, previousPost, nextPost } = Astro.props;
const { Content, headings } = await post.render();
---

<BaseLayout
  title={post.data.title}
  description={post.data.description}
  image={post.data.ogImage ?? post.data.cover}
  pathname={`/blog/${post.slug}/`}
  type="article"
  schema={blogSchema(post)}
>
  <section class="section pt-12 sm:pt-16">
    <div class="shell space-y-10">
      <div class="max-w-4xl space-y-5">
        <a href="/blog/" class="text-sm font-semibold text-[var(--color-accent)] transition hover:text-[var(--color-accent-strong)]">
          ← Back to blog
        </a>
        <span class="eyebrow">{post.data.category.replace("-", " ")}</span>
        <h1 class="text-4xl font-semibold tracking-tight text-white sm:text-5xl">{post.data.title}</h1>
        <p class="max-w-3xl text-lg leading-8 text-slate-300">{post.data.description}</p>
        <div class="flex flex-wrap items-center gap-3 text-sm text-slate-400">
          <span>{formatDate(post.data.pubDate)}</span>
          {post.data.tags.map((tag) => <span class="pill">{tag}</span>)}
        </div>
      </div>

      <div class="panel overflow-hidden">
        <img src={post.data.cover} alt={`${post.data.title} cover`} class="aspect-[16/8] w-full object-cover" />
      </div>

      <div class="grid gap-8 xl:grid-cols-[minmax(0,1fr)_280px]">
        <article class="panel p-6 sm:p-8 lg:p-10">
          <div class="article-body">
            <Content />
          </div>
        </article>

        {headings.length > 2 && (
          <aside class="panel h-fit p-6">
            <h2 class="text-sm font-semibold uppercase tracking-[0.2em] text-slate-200">On this page</h2>
            <nav class="mt-5">
              <ul class="space-y-3">
                {headings.filter((heading) => heading.depth <= 2).map((heading) => (
                  <li>
                    <a href={`#${heading.slug}`} class="text-sm leading-6 text-slate-300 transition hover:text-white">
                      {heading.text}
                    </a>
                  </li>
                ))}
              </ul>
            </nav>
          </aside>
        )}
      </div>

      {(previousPost || nextPost) && (
        <div class="grid gap-4 sm:grid-cols-2">
          {previousPost ? (
            <a href={`/blog/${previousPost.slug}/`} class="panel block p-6 transition hover:border-white/20">
              <p class="text-xs uppercase tracking-[0.2em] text-slate-500">Previous post</p>
              <p class="mt-3 text-lg font-semibold text-white">{previousPost.data.title}</p>
            </a>
          ) : (
            <div></div>
          )}

          {nextPost && (
            <a href={`/blog/${nextPost.slug}/`} class="panel block p-6 text-left transition hover:border-white/20 sm:text-right">
              <p class="text-xs uppercase tracking-[0.2em] text-slate-500">Next post</p>
              <p class="mt-3 text-lg font-semibold text-white">{nextPost.data.title}</p>
            </a>
          )}
        </div>
      )}
    </div>
  </section>
</BaseLayout>
