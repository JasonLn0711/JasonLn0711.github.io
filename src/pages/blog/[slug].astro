---
import { getCollection, type CollectionEntry } from "astro:content";
import UntranslatedNotice from "../../components/layout/UntranslatedNotice.astro";
import CTASection from "../../components/ui/CTASection.astro";
import DetailTOC from "../../components/ui/DetailTOC.astro";
import MediaFrame from "../../components/ui/MediaFrame.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { formatDate, formatLabel, getBlogLocale, getBlogPath, getBlogStaticPaths } from "../../lib/content";
import { getLocaleFromPathname, getLocalizedPageTitle, getPageCopy, localizePath } from "../../lib/i18n";
import { blogSchema } from "../../lib/schema";

export async function getStaticPaths() {
  return getBlogStaticPaths(await getCollection("blog"));
}

interface Props {
  post: CollectionEntry<"blog">;
  previousPost?: CollectionEntry<"blog"> | null;
  nextPost?: CollectionEntry<"blog"> | null;
}

const { post, previousPost, nextPost } = Astro.props;
const { Content, headings } = await post.render();
const publishedTime = post.data.pubDate.toISOString();
const modifiedTime = (post.data.updatedDate ?? post.data.pubDate).toISOString();
const locale = getLocaleFromPathname(Astro.url.pathname);
const copy = getPageCopy(locale);
const showUntranslatedNotice = getBlogLocale(post) !== locale;
---

<BaseLayout
  title={getLocalizedPageTitle(locale, post.data.title, copy.common.writing)}
  description={post.data.description}
  image={post.data.ogImage ?? post.data.cover}
  pathname={Astro.url.pathname}
  type="article"
  schema={blogSchema(post, locale)}
  publishedTime={publishedTime}
  modifiedTime={modifiedTime}
>
  <section class="page-frame">
    <div class="page-stack">
      <div class="page-intro">
        <a href={localizePath("/blog/", locale)} class="quiet-link">
          <span aria-hidden="true">←</span>
          {copy.common.backToWriting}
        </a>
        <span class="eyebrow">{formatLabel(post.data.category, locale)}</span>
        <h1 class="display-title-sm">{post.data.title}</h1>
        <p class="page-summary">{post.data.description}</p>
        <div class="meta-row">
          <span>{formatDate(post.data.pubDate, locale)}</span>
          {post.data.tags.map((tag) => <span class="pill">{tag}</span>)}
        </div>
      </div>

      <MediaFrame src={post.data.cover} alt={`${post.data.title} cover`} imageClass="aspect-[16/8] w-full object-cover" />

      <div class="detail-shell xl:[grid-template-columns:minmax(0,1fr)_18rem]">
        <article class="space-y-6 min-w-0">
          {showUntranslatedNotice && <UntranslatedNotice locale={locale} kind="blog" />}
          <div class="reading-panel">
            <div class="article-body">
              <Content />
            </div>
          </div>
        </article>

        {headings.length > 2 && (
          <DetailTOC
            title={copy.common.onThisPage}
            items={headings.filter((heading) => heading.depth <= 2).map((heading) => ({
              href: `#${heading.slug}`,
              label: heading.text
            }))}
            className="xl:sticky xl:top-28 xl:h-fit"
          />
        )}
      </div>

      <CTASection
        title={copy.common.continueFromThisPiece}
        copy={copy.common.continueFromThisPieceDescription}
        actions={[
          { href: localizePath("/research/", locale), label: copy.common.research, variant: "secondary" },
          { href: localizePath("/projects/", locale), label: copy.common.projects, variant: "secondary" },
          { href: localizePath("/contact/", locale), label: copy.common.contact }
        ]}
      />

      {(previousPost || nextPost) && (
        <div class="grid gap-4 sm:grid-cols-2">
          {previousPost ? (
            <a href={getBlogPath(previousPost, locale)} class="surface-link block p-6">
              <p class="muted-label">{copy.common.previousPiece}</p>
              <p class="mt-3 text-lg font-semibold">{previousPost.data.title}</p>
            </a>
          ) : (
            <div></div>
          )}

          {nextPost && (
            <a href={getBlogPath(nextPost, locale)} class="surface-link block p-6 text-left sm:text-right">
              <p class="muted-label">{copy.common.nextPiece}</p>
              <p class="mt-3 text-lg font-semibold">{nextPost.data.title}</p>
            </a>
          )}
        </div>
      )}
    </div>
  </section>
</BaseLayout>
