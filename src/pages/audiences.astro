---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getSiteV2 } from "../data/siteV2";
import {
  getLocaleFromPathname,
  getLocalizedPageTitle,
  getPageCopy,
  localizePath
} from "../lib/i18n";

const locale = getLocaleFromPathname(Astro.url.pathname);
const copy = getPageCopy(locale);
const siteV2 = getSiteV2(locale);
---

<BaseLayout
  title={getLocalizedPageTitle(locale, siteV2.page.title)}
  description={siteV2.page.description}
  pathname={Astro.url.pathname}
>
  <section class="page-frame">
    <div class="page-stack">
      <div class="page-intro">
        <span class="section-kicker">Website v2.0</span>
        <h1 class="text-4xl font-semibold tracking-tight text-white sm:text-5xl">
          {siteV2.page.title}
        </h1>
        <p class="page-summary">{siteV2.page.description}</p>
      </div>

      <section class="audience-page-board" aria-label={siteV2.audience.title}>
        <div class="dossier-panel p-7 sm:p-8">
          <h2 class="text-2xl font-semibold text-white">{siteV2.audience.title}</h2>
          <p class="mt-4 max-w-3xl text-base leading-8 text-slate-300">{siteV2.audience.description}</p>
          <p class="mt-4 max-w-3xl text-sm leading-7 text-slate-400">{siteV2.audience.note}</p>
        </div>

        <div class="audience-detail-grid">
          {siteV2.audience.cards.map((item) => (
            <article class="audience-detail-card">
              <div class="flex flex-wrap items-center justify-between gap-3">
                <span class="status-token">{item.label}</span>
                <a href={localizePath(item.route, locale)} class="action-link">
                  {item.routeLabel}
                  <span aria-hidden="true">→</span>
                </a>
              </div>
              <h2>{item.question}</h2>
              <p>{item.humanFactor}</p>
              <div class="flex flex-wrap gap-2">
                {item.evidence.map((evidence) => <span class="pill">{evidence}</span>)}
              </div>
            </article>
          ))}
        </div>
      </section>

      <section class="grid gap-8 xl:grid-cols-[0.95fr_1.05fr]">
        <article class="section-card">
          <h2 class="text-2xl font-semibold text-white">{siteV2.operatingTracks.title}</h2>
          <p class="mt-4 text-base leading-8 text-slate-300">{siteV2.operatingTracks.description}</p>
          <div class="mt-6 grid gap-3">
            {siteV2.protocol.boundary.map((item) => (
              <div class="surface-card">
                <p class="text-sm leading-7 text-slate-300">{item}</p>
              </div>
            ))}
          </div>
        </article>

        <article class="section-card">
          <h2 class="text-2xl font-semibold text-white">{siteV2.protocol.title}</h2>
          <p class="mt-4 text-base leading-8 text-slate-300">{siteV2.protocol.description}</p>
          <ol class="mt-6 grid gap-4">
            {siteV2.protocol.steps.map((step, index) => (
              <li class="surface-card">
                <p class="mono-label">{String(index + 1).padStart(2, "0")} · {step.label}</p>
                <p class="mt-3 text-sm leading-7 text-slate-300">{step.text}</p>
              </li>
            ))}
          </ol>
        </article>
      </section>

      <section class="track-map">
        {siteV2.operatingTracks.tracks.map((track, index) => (
          <a href={localizePath(track.route, locale)} class="track-map__item">
            <span class="track-map__index">{String(index + 1).padStart(2, "0")}</span>
            <div>
              <h2>{track.title}</h2>
              <p>{track.source}</p>
            </div>
            <dl>
              <div>
                <dt>{siteV2.labels.surface}</dt>
                <dd>{track.publicSurface}</dd>
              </div>
              <div>
                <dt>{siteV2.labels.audience}</dt>
                <dd>{track.audience}</dd>
              </div>
              <div>
                <dt>{siteV2.labels.maturity}</dt>
                <dd>{track.maturity}</dd>
              </div>
            </dl>
          </a>
        ))}
      </section>

      <section class="dossier-panel flex flex-col gap-5 p-7 lg:flex-row lg:items-center lg:justify-between">
        <div class="space-y-3">
          <h2 class="text-2xl font-semibold text-white">{siteV2.labels.nextUsefulRoute}</h2>
          <p class="max-w-2xl text-base leading-8 text-slate-300">
            {siteV2.labels.nextRouteText}
          </p>
        </div>
        <div class="page-actions">
          <a href={localizePath("/research/", locale)} class="button-secondary">{copy.common.research}</a>
          <a href={localizePath("/projects/", locale)} class="button-secondary">{copy.common.projects}</a>
          <a href={localizePath("/contact/", locale)} class="button-primary">{copy.common.contact}</a>
        </div>
      </section>
    </div>
  </section>
</BaseLayout>
