---
import PageIntro from "../components/common/PageIntro.astro";
import { profile } from "../data/profile";
import { researchApproach } from "../data/research";
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="About"
  description="Background, research interests, and working approach behind Jason Chia-Sheng Lin's work in AI systems, speech intelligence, trustworthy AI, and AI security."
  pathname="/about/"
>
  <section class="section pt-12 sm:pt-16">
    <div class="shell space-y-14">
      <PageIntro
        eyebrow="About"
        title="A research profile shaped by AI systems, security, and operational thinking."
        description="I approach machine intelligence as something that has to survive real workflows, uneven evidence, and institutional constraints, not just perform well in isolation."
      />

      <dl class="grid gap-4 md:grid-cols-3">
        <div class="surface-note">
          <dt class="text-xs uppercase tracking-[0.2em] text-[var(--color-soft)]">Current Role</dt>
          <dd class="mt-3 text-base leading-7 text-[var(--color-ink)]">PhD student since 2026</dd>
        </div>
        <div class="surface-note">
          <dt class="text-xs uppercase tracking-[0.2em] text-[var(--color-soft)]">Institute</dt>
          <dd class="mt-3 text-base leading-7 text-[var(--color-ink)]">Institute of Biophotonics, NYCU</dd>
        </div>
        <div class="surface-note">
          <dt class="text-xs uppercase tracking-[0.2em] text-[var(--color-soft)]">Background</dt>
          <dd class="mt-3 text-base leading-7 text-[var(--color-ink)]">Cybersecurity, investigation logic, and evidence-aware systems</dd>
        </div>
      </dl>

      <div class="grid gap-8 lg:grid-cols-[320px_minmax(0,1fr)]">
        <div class="panel-strong overflow-hidden">
          <img src={profile.avatar} alt={profile.name} class="aspect-[4/5] w-full object-cover" />
        </div>

        <div class="panel space-y-6 p-7 sm:p-8">
          <h2 class="text-2xl font-semibold text-[var(--color-ink)]">Professional Summary</h2>
          {profile.about.map((paragraph) => <p class="text-base leading-8 text-[var(--color-muted)]">{paragraph}</p>)}
        </div>
      </div>

      <div class="grid gap-8 xl:grid-cols-[1.1fr_0.9fr]">
        <section class="panel p-7 sm:p-8">
          <h2 class="text-2xl font-semibold text-[var(--color-ink)]">Narrative</h2>
          <div class="mt-6 space-y-5">
            {profile.narrative.map((paragraph) => <p class="text-base leading-8 text-[var(--color-muted)]">{paragraph}</p>)}
          </div>
        </section>

        <section class="panel p-7 sm:p-8">
          <h2 class="text-2xl font-semibold text-[var(--color-ink)]">Working Principles</h2>
          <div class="mt-6 space-y-6">
            {researchApproach.map((item) => (
              <div class="border-l border-[var(--color-line)] pl-5">
                <p class="text-sm leading-7 text-[var(--color-muted)]">{item}</p>
              </div>
            ))}
          </div>
        </section>
      </div>

      <section class="panel-strong flex flex-col gap-5 p-7 sm:p-8 lg:flex-row lg:items-center lg:justify-between">
        <div class="space-y-3">
          <h2 class="text-2xl font-semibold text-[var(--color-ink)]">Where this leads</h2>
          <p class="max-w-2xl text-base leading-8 text-[var(--color-muted)]">
            I am interested in research and engineering work that treats trust as a systems property: something earned through architecture, evaluation, security posture, and clarity for the people using the system.
          </p>
        </div>
        <div class="flex flex-wrap gap-3">
          <a href="/research/" class="button-primary">Research overview</a>
          <a href="/contact/" class="button-secondary">Contact</a>
        </div>
      </section>
    </div>
  </section>
</BaseLayout>
