---
import { profile } from "../data/profile";
import { speaking } from "../data/speaking";
import BaseLayout from "../layouts/BaseLayout.astro";
import { pageTitle } from "../lib/site";
---

<BaseLayout
  title={pageTitle("About")}
  description="This page provides the professional context behind the portfolio: the doctoral research agenda, the investigation-informed perspective, and the way I approach AI systems intended for serious real-world use."
  image={profile.avatar}
  pathname="/about/"
>
  <section class="section pt-12 sm:pt-16">
    <div class="shell space-y-14">
      <div class="max-w-3xl space-y-5">
        <span class="eyebrow">About</span>
        <h1 class="text-4xl font-semibold tracking-tight text-white sm:text-5xl">
          Researcher, systems builder, and security-minded thinker.
        </h1>
        <p class="text-lg leading-8 text-slate-300">
          This page provides the professional context behind the portfolio: the doctoral research agenda, the investigation-informed perspective, and the way I approach AI systems intended for serious real-world use.
        </p>
      </div>

      <div class="flex flex-wrap gap-3">
        <a href="/research/" class="button-secondary">Research focus</a>
        <a href="/projects/" class="button-secondary">Selected projects</a>
        <a href="/blog/" class="button-secondary">Writing</a>
        <a href="/talks/" class="button-secondary">Talks</a>
        <a href="/contact/" class="button-primary">Contact</a>
      </div>

      <dl class="grid gap-4 md:grid-cols-2 xl:grid-cols-4">
        <div class="panel p-6">
          <dt class="text-xs uppercase tracking-[0.2em] text-slate-500">Current Role</dt>
          <dd class="mt-3 text-base leading-7 text-slate-200">Doctoral Researcher</dd>
        </div>
        <div class="panel p-6">
          <dt class="text-xs uppercase tracking-[0.2em] text-slate-500">Institution</dt>
          <dd class="mt-3 text-base leading-7 text-slate-200">{profile.institution}</dd>
        </div>
        <div class="panel p-6">
          <dt class="text-xs uppercase tracking-[0.2em] text-slate-500">Research Lab</dt>
          <dd class="mt-3 text-base leading-7 text-slate-200">
            <a href={profile.lab.url} target="_blank" rel="noreferrer" class="transition hover:text-white">
              {profile.lab.name}
            </a>
          </dd>
        </div>
        <div class="panel p-6">
          <dt class="text-xs uppercase tracking-[0.2em] text-slate-500">Primary Lens</dt>
          <dd class="mt-3 text-base leading-7 text-slate-200">Trustworthy AI, security, and deployment realism</dd>
        </div>
      </dl>

      <div class="grid gap-8 xl:grid-cols-[1.1fr_0.9fr]">
        <section class="panel p-7 sm:p-8">
          <h2 class="text-2xl font-semibold text-white">Current Areas of Work</h2>
          <div class="mt-6 grid gap-4">
            {profile.interests.map((item) => (
              <div class="rounded-3xl border border-white/[0.08] bg-white/[0.03] p-5">
                <p class="text-base leading-7 text-slate-300">{item}</p>
              </div>
            ))}
          </div>
        </section>

        <section class="panel p-7 sm:p-8">
          <h2 class="text-2xl font-semibold text-white">Professional Path</h2>
          <div class="mt-6 space-y-6">
            {profile.experience.map((item) => (
              <div class="border-l border-white/10 pl-5">
                <p class="text-xs uppercase tracking-[0.2em] text-slate-500">{item.period}</p>
                <h3 class="mt-2 text-lg font-semibold text-white">{item.title}</h3>
                <p class="mt-2 text-sm leading-7 text-slate-300">{item.detail}</p>
              </div>
            ))}
          </div>
        </section>
      </div>

      <div class="grid gap-8 lg:grid-cols-[320px_minmax(0,1fr)]">
        <div class="panel overflow-hidden">
          <img
            src={profile.avatar}
            alt={`Portrait of ${profile.name}`}
            width="1693"
            height="2540"
            class="aspect-[2/3] w-full object-cover"
          />
        </div>

        <div class="panel space-y-6 p-7 sm:p-8">
          <h2 class="text-2xl font-semibold text-white">Professional Narrative</h2>
          {profile.about.map((paragraph) => <p class="text-base leading-8 text-slate-300">{paragraph}</p>)}
          <div class="rounded-3xl border border-white/[0.08] bg-white/[0.03] p-5">
            <p class="text-xs uppercase tracking-[0.2em] text-slate-500">Current speaking and paper activity</p>

            <div class="mt-3 space-y-5">
              <div class="space-y-2">
                <h3 class="text-lg font-semibold text-white">{speaking.featuredEngagement.event}</h3>
                <p class="text-sm leading-7 text-slate-300">{speaking.featuredEngagement.title}</p>
                <div class="flex flex-wrap gap-4">
                  <a
                    href={speaking.featuredEngagement.url}
                    target="_blank"
                    rel="noreferrer"
                    class="inline-flex text-sm font-semibold text-[var(--color-accent)] transition hover:text-[var(--color-accent-strong)]"
                  >
                    View official session page →
                  </a>
                  <a
                    href={profile.externalProfiles.cybersecSpeaker.url}
                    target="_blank"
                    rel="noreferrer"
                    class="inline-flex text-sm font-semibold text-[var(--color-accent)] transition hover:text-[var(--color-accent-strong)]"
                  >
                    View CYBERSEC speaker profile →
                  </a>
                </div>
              </div>

              {speaking.additionalEngagements.map((engagement) => (
                <div class="border-t border-white/10 pt-5">
                  <p class="text-xs uppercase tracking-[0.2em] text-slate-500">{engagement.event}</p>
                  <h4 class="mt-2 text-lg font-semibold text-white">{engagement.title}</h4>
                  <p class="mt-2 text-sm leading-7 text-slate-300">{engagement.summary}</p>
                  <div class="mt-4 flex flex-wrap gap-4">
                    {(engagement.links ?? [{ label: engagement.ctaLabel, url: engagement.url }]).map((link) => (
                      <a
                        href={link.url}
                        target="_blank"
                        rel="noreferrer"
                        class="inline-flex text-sm font-semibold text-[var(--color-accent)] transition hover:text-[var(--color-accent-strong)]"
                      >
                        {link.label} →
                      </a>
                    ))}
                  </div>
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>

      <section class="grid gap-8 xl:grid-cols-[0.9fr_1.1fr]">
        <div class="panel p-7 sm:p-8">
          <h2 class="text-2xl font-semibold text-white">Selected Signals</h2>
          <ul class="mt-6 space-y-4">
            {profile.achievements.map((item) => <li class="text-base leading-7 text-slate-300">{item}</li>)}
          </ul>
        </div>

        <div class="panel p-7 sm:p-8">
          <h2 class="text-2xl font-semibold text-white">Methods / Technical Toolkit</h2>
          <div class="mt-6 grid gap-5 md:grid-cols-2">
            {profile.toolkit.map((group) => (
              <div class="rounded-3xl border border-white/[0.08] bg-white/[0.03] p-5">
                <h3 class="text-lg font-semibold text-white">{group.title}</h3>
                <div class="mt-4 flex flex-wrap gap-2">
                  {group.items.map((item) => <span class="pill">{item}</span>)}
                </div>
              </div>
            ))}
          </div>
        </div>
      </section>

      <section class="panel flex flex-col gap-5 p-7 sm:p-8 lg:flex-row lg:items-center lg:justify-between">
        <div class="space-y-3">
          <h2 class="text-2xl font-semibold text-white">Work together</h2>
          <p class="max-w-2xl text-base leading-8 text-slate-300">{profile.contactPrompt}</p>
        </div>
        <div class="flex flex-wrap gap-3">
          <a href="/research/" class="button-secondary">Research</a>
          <a href="/projects/" class="button-secondary">Projects</a>
          <a href={`mailto:${profile.email}`} class="button-primary">Email</a>
        </div>
      </section>
    </div>
  </section>
</BaseLayout>
