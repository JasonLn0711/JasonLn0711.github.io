---
import BaseLayout from "../layouts/BaseLayout.astro";
import CTASection from "../components/ui/CTASection.astro";
import MediaFrame from "../components/ui/MediaFrame.astro";
import PageHero from "../components/ui/PageHero.astro";
import QuoteBlock from "../components/ui/QuoteBlock.astro";
import SectionIntro from "../components/ui/SectionIntro.astro";
import {
  getLocaleFromPathname,
  getLocalizedPageTitle,
  getLocalizedProfile,
  getLocalizedSpeaking,
  getPageCopy,
  localizePath
} from "../lib/i18n";

const locale = getLocaleFromPathname(Astro.url.pathname);
const profile = getLocalizedProfile(locale);
const speaking = getLocalizedSpeaking(locale);
const copy = getPageCopy(locale);
---

<BaseLayout
  title={getLocalizedPageTitle(locale, copy.common.about)}
  description={copy.aboutPage.description}
  image={profile.avatar}
  pathname={Astro.url.pathname}
>
  <section class="page-frame">
    <div class="page-stack">
      <PageHero
        eyebrow={copy.common.about}
        title={copy.aboutPage.title}
        summary={copy.aboutPage.description}
        split={true}
        titleClass="display-title-sm"
        actions={[
          { href: localizePath("/research/", locale), label: copy.aboutPage.actionResearch, variant: "secondary" },
          { href: localizePath("/projects/", locale), label: copy.aboutPage.actionProjects, variant: "secondary" },
          { href: localizePath("/contact/", locale), label: copy.aboutPage.actionContact }
        ]}
      >
        <MediaFrame
          slot="media"
          src={profile.avatar}
          alt={`Portrait of ${profile.name}`}
          width="1693"
          height="2540"
          imageClass="aspect-[4/5] w-full object-cover object-[center_24%]"
          caption={profile.shortBio}
        />
      </PageHero>

      <div class="grid gap-4 md:grid-cols-2 xl:grid-cols-4">
        <div class="surface-card">
          <p class="muted-label">{copy.common.currentRole}</p>
          <p class="mt-3 text-base leading-7 text-[var(--color-charcoal)]">{copy.aboutPage.currentRoleValue}</p>
        </div>
        <div class="surface-card">
          <p class="muted-label">{copy.common.institution}</p>
          <p class="mt-3 text-base leading-7 text-[var(--color-charcoal)]">{profile.institution}</p>
        </div>
        <div class="surface-card">
          <p class="muted-label">{copy.common.researchLab}</p>
          <p class="mt-3 text-base leading-7 text-[var(--color-charcoal)]">
            <a href={profile.lab.url} target="_blank" rel="noreferrer" class="action-link">
              {profile.lab.name}
            </a>
          </p>
        </div>
        <div class="surface-card">
          <p class="muted-label">{copy.common.primaryLens}</p>
          <p class="mt-3 text-base leading-7 text-[var(--color-charcoal)]">{copy.aboutPage.primaryLensValue}</p>
        </div>
      </div>

      <QuoteBlock quote={profile.shortBio} note={profile.contactPrompt} />

      <div class="grid gap-8 xl:grid-cols-[1.05fr_0.95fr]">
        <section class="section-card">
          <SectionIntro title={copy.common.professionalNarrative} />
          <div class="mt-6 space-y-5">
            {profile.about.map((paragraph) => <p class="text-base leading-8">{paragraph}</p>)}
          </div>
        </section>

        <section class="section-card">
          <SectionIntro title={copy.common.professionalPath} />
          <div class="mt-6 space-y-6">
            {profile.experience.map((item) => (
              <div class="border-l border-[rgba(31,27,23,0.12)] pl-5">
                <p class="muted-label">{item.period}</p>
                <h3 class="mt-2 text-lg font-semibold">{item.title}</h3>
                <p class="mt-2 text-sm leading-7">{item.detail}</p>
              </div>
            ))}
          </div>
        </section>
      </div>

      <div class="grid gap-8 xl:grid-cols-[1fr_1fr]">
        <section class="section-card">
          <SectionIntro title={copy.common.currentAreasOfWork} />
          <div class="mt-6 grid gap-4">
            {profile.interests.map((item) => (
              <div class="surface-card">
                <p class="text-base leading-7">{item}</p>
              </div>
            ))}
          </div>
        </section>

        <section class="section-card">
          <SectionIntro title={copy.common.currentSpeakingAndPaperActivity} />
          <div class="mt-6 space-y-5">
            <div class="surface-card">
              <p class="muted-label">{speaking.featuredEngagement.event}</p>
              <h3 class="mt-3 text-xl font-semibold">{speaking.featuredEngagement.title}</h3>
              <p class="mt-3 text-sm leading-7">{speaking.featuredEngagement.summary}</p>
              <div class="mt-4 flex flex-wrap gap-4">
                <a href={speaking.featuredEngagement.url} target="_blank" rel="noreferrer" class="action-link">
                  {copy.aboutPage.currentSpeakingActivityLinks.official} →
                </a>
                <a href={profile.externalProfiles.cybersecSpeaker.url} target="_blank" rel="noreferrer" class="action-link">
                  {copy.aboutPage.currentSpeakingActivityLinks.profile} →
                </a>
              </div>
            </div>

            {speaking.additionalEngagements.map((engagement) => (
              <div class="surface-card">
                <p class="muted-label">{engagement.event}</p>
                <h4 class="mt-2 text-lg font-semibold">{engagement.title}</h4>
                <p class="mt-2 text-sm leading-7">{engagement.summary}</p>
              </div>
            ))}
          </div>
        </section>
      </div>

      <section class="grid gap-8 xl:grid-cols-[0.9fr_1.1fr]">
        <div class="section-card">
          <SectionIntro title={copy.common.selectedSignals} />
          <ul class="mt-6 compact-list">
            {profile.achievements.map((item) => <li class="text-base leading-7">{item}</li>)}
          </ul>
        </div>

        <div class="section-card">
          <SectionIntro title={copy.common.methodsAndToolkit} />
          <div class="mt-6 grid gap-5 md:grid-cols-2">
            {profile.toolkit.map((group) => (
              <div class="surface-card">
                <h3 class="text-lg font-semibold">{group.title}</h3>
                <div class="mt-4 flex flex-wrap gap-2">
                  {group.items.map((item) => <span class="pill">{item}</span>)}
                </div>
              </div>
            ))}
          </div>
        </div>
      </section>

      <CTASection
        title={copy.common.workTogether}
        copy={profile.contactPrompt}
        actions={[
          { href: localizePath("/research/", locale), label: copy.common.research, variant: "secondary" },
          { href: localizePath("/projects/", locale), label: copy.common.projects, variant: "secondary" },
          { href: `mailto:${profile.email}`, label: copy.common.email }
        ]}
      />
    </div>
  </section>
</BaseLayout>
