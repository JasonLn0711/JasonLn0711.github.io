---
import BaseLayout from "../layouts/BaseLayout.astro";
import {
  getLocaleFromPathname,
  getLocalizedPageTitle,
  getLocalizedProfile,
  getLocalizedSpeaking,
  getPageCopy,
  localizePath
} from "../lib/i18n";

const locale = getLocaleFromPathname(Astro.url.pathname);
const profile = getLocalizedProfile(locale);
const speaking = getLocalizedSpeaking(locale);
const copy = getPageCopy(locale);
---

<BaseLayout
  title={getLocalizedPageTitle(locale, copy.common.about)}
  description={copy.aboutPage.description}
  image={profile.avatar}
  pathname={Astro.url.pathname}
>
  <section class="page-frame">
    <div class="page-stack">
      <div class="page-intro">
        <span class="eyebrow">{copy.common.about}</span>
        <h1 class="text-4xl font-semibold tracking-tight text-white sm:text-5xl">
          {copy.aboutPage.title}
        </h1>
        <p class="page-summary">
          {copy.aboutPage.description}
        </p>
      </div>

      <div class="page-actions">
        <a href={localizePath("/research/", locale)} class="button-secondary">{copy.aboutPage.actionResearch}</a>
        <a href={localizePath("/projects/", locale)} class="button-secondary">{copy.aboutPage.actionProjects}</a>
        <a href={localizePath("/blog/", locale)} class="button-secondary">{copy.aboutPage.actionWriting}</a>
        <a href={localizePath("/talks/", locale)} class="button-secondary">{copy.aboutPage.actionTalks}</a>
        <a href={localizePath("/contact/", locale)} class="button-primary">{copy.aboutPage.actionContact}</a>
      </div>

      <dl class="grid gap-4 md:grid-cols-2 xl:grid-cols-4">
        <div class="panel p-6">
          <dt class="text-xs uppercase tracking-[0.2em] text-slate-500">{copy.common.currentRole}</dt>
          <dd class="mt-3 text-base leading-7 text-slate-200">{copy.aboutPage.currentRoleValue}</dd>
        </div>
        <div class="panel p-6">
          <dt class="text-xs uppercase tracking-[0.2em] text-slate-500">{copy.common.institution}</dt>
          <dd class="mt-3 text-base leading-7 text-slate-200">{profile.institution}</dd>
        </div>
        <div class="panel p-6">
          <dt class="text-xs uppercase tracking-[0.2em] text-slate-500">{copy.common.researchLab}</dt>
          <dd class="mt-3 text-base leading-7 text-slate-200">
            <a href={profile.lab.url} target="_blank" rel="noreferrer" class="transition hover:text-white">
              {profile.lab.name}
            </a>
          </dd>
        </div>
        <div class="panel p-6">
          <dt class="text-xs uppercase tracking-[0.2em] text-slate-500">{copy.common.primaryLens}</dt>
          <dd class="mt-3 text-base leading-7 text-slate-200">{copy.aboutPage.primaryLensValue}</dd>
        </div>
      </dl>

      <div class="grid gap-8 xl:grid-cols-[1.1fr_0.9fr]">
        <section class="section-card">
          <h2 class="text-2xl font-semibold text-white">{copy.common.currentAreasOfWork}</h2>
          <div class="mt-6 grid gap-4">
            {profile.interests.map((item) => (
              <div class="surface-card">
                <p class="text-base leading-7 text-slate-300">{item}</p>
              </div>
            ))}
          </div>
        </section>

        <section class="section-card">
          <h2 class="text-2xl font-semibold text-white">{copy.common.professionalPath}</h2>
          <div class="mt-6 space-y-6">
            {profile.experience.map((item) => (
              <div class="border-l border-white/10 pl-5">
                <p class="text-xs uppercase tracking-[0.2em] text-slate-500">{item.period}</p>
                <h3 class="mt-2 text-lg font-semibold text-white">{item.title}</h3>
                <p class="mt-2 text-sm leading-7 text-slate-300">{item.detail}</p>
              </div>
            ))}
          </div>
        </section>
      </div>

      <div class="grid gap-8 lg:grid-cols-[320px_minmax(0,1fr)]">
        <div class="panel overflow-hidden">
          <img
            src={profile.avatar}
            alt={`Portrait of ${profile.name}`}
            width="1693"
            height="2540"
            class="aspect-[2/3] w-full object-cover"
          />
        </div>

        <div class="section-card space-y-6">
          <h2 class="text-2xl font-semibold text-white">{copy.common.professionalNarrative}</h2>
          {profile.about.map((paragraph) => <p class="text-base leading-8 text-slate-300">{paragraph}</p>)}
          <div class="surface-card">
            <p class="text-xs uppercase tracking-[0.2em] text-slate-500">{copy.common.currentSpeakingAndPaperActivity}</p>

            <div class="mt-3 space-y-5">
              <div class="space-y-2">
                <h3 class="text-lg font-semibold text-white">{speaking.featuredEngagement.event}</h3>
                <p class="text-sm leading-7 text-slate-300">{speaking.featuredEngagement.title}</p>
                <div class="flex flex-wrap gap-4">
                  <a
                    href={speaking.featuredEngagement.url}
                    target="_blank"
                    rel="noreferrer"
                    class="inline-flex text-sm font-semibold text-[var(--color-accent)] transition hover:text-[var(--color-accent-strong)]"
                  >
                    {copy.aboutPage.currentSpeakingActivityLinks.official} →
                  </a>
                  <a
                    href={profile.externalProfiles.cybersecSpeaker.url}
                    target="_blank"
                    rel="noreferrer"
                    class="inline-flex text-sm font-semibold text-[var(--color-accent)] transition hover:text-[var(--color-accent-strong)]"
                  >
                    {copy.aboutPage.currentSpeakingActivityLinks.profile} →
                  </a>
                </div>
              </div>

              {speaking.additionalEngagements.map((engagement) => (
                <div class="border-t border-white/10 pt-5">
                  <p class="text-xs uppercase tracking-[0.2em] text-slate-500">{engagement.event}</p>
                  <h4 class="mt-2 text-lg font-semibold text-white">{engagement.title}</h4>
                  <p class="mt-2 text-sm leading-7 text-slate-300">{engagement.summary}</p>
                  <div class="mt-4 flex flex-wrap gap-4">
                    {(engagement.links ?? [{ label: engagement.ctaLabel, url: engagement.url }]).map((link) => (
                      <a
                        href={link.url}
                        target="_blank"
                        rel="noreferrer"
                        class="inline-flex text-sm font-semibold text-[var(--color-accent)] transition hover:text-[var(--color-accent-strong)]"
                      >
                        {link.label} →
                      </a>
                    ))}
                  </div>
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>

      <section class="grid gap-8 xl:grid-cols-[0.9fr_1.1fr]">
        <div class="section-card">
          <h2 class="text-2xl font-semibold text-white">{copy.common.selectedSignals}</h2>
          <ul class="mt-6 space-y-4">
            {profile.achievements.map((item) => <li class="text-base leading-7 text-slate-300">{item}</li>)}
          </ul>
        </div>

        <div class="section-card">
          <h2 class="text-2xl font-semibold text-white">{copy.common.methodsAndToolkit}</h2>
          <div class="mt-6 grid gap-5 md:grid-cols-2">
            {profile.toolkit.map((group) => (
              <div class="surface-card">
                <h3 class="text-lg font-semibold text-white">{group.title}</h3>
                <div class="mt-4 flex flex-wrap gap-2">
                  {group.items.map((item) => <span class="pill">{item}</span>)}
                </div>
              </div>
            ))}
          </div>
        </div>
      </section>

      <section class="section-card flex flex-col gap-5 lg:flex-row lg:items-center lg:justify-between">
        <div class="space-y-3">
          <h2 class="text-2xl font-semibold text-white">{copy.common.workTogether}</h2>
          <p class="max-w-2xl text-base leading-8 text-slate-300">{profile.contactPrompt}</p>
        </div>
        <div class="page-actions">
          <a href={localizePath("/research/", locale)} class="button-secondary">{copy.common.research}</a>
          <a href={localizePath("/projects/", locale)} class="button-secondary">{copy.common.projects}</a>
          <a href={`mailto:${profile.email}`} class="button-primary">{copy.common.email}</a>
        </div>
      </section>
    </div>
  </section>
</BaseLayout>
